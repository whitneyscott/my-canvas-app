                    </div>
                    <div class="tab-loading hidden" id="loading-pages">Loading pages...</div>
                    <div class="tab-error hidden" id="error-pages"></div>
                    <table class="data-table" id="pagesTable">
                        <thead>
                            <tr>
                                <th class="checkbox-header">
                                    <input type="checkbox" class="select-all-checkbox" id="selectAll-pages" onchange="toggleSelectAll('pages', this.checked)">
                                </th>
                                <th>title</th>
                                <th>url</th>
                                <th>published</th>
                                <th>front_page</th>
                                <th>updated_at</th>
                            </tr>
                        </thead>
                        <tbody id="pagesTableBody"></tbody>
                    </table>
                </div>

                <!-- Announcements Tab -->
                <div class="tab-content" id="tab-announcements">
                    <div class="tab-header">
                        <div class="count-badge" id="announcementsCount">0 announcements</div>
                        <button class="sync-btn" id="sync-announcements" onclick="syncChanges('announcements')" disabled>
                            <span>💾</span>
                            Sync to Canvas
                            <span class="changes-count hidden" id="changesCount-announcements">0</span>
                        </button>
                        <button class="refresh-btn" onclick="refreshTab('announcements')" id="refresh-announcements">
                            <span class="refresh-icon"></span>
                            Refresh
                        </button>
                    </div>
                    <div class="tab-loading hidden" id="loading-announcements">Loading announcements...</div>
                    <div class="tab-error hidden" id="error-announcements"></div>
                    <table class="data-table" id="announcementsTable">
                        <thead>
                            <tr>
                                <th class="checkbox-header">
                                    <input type="checkbox" class="select-all-checkbox" id="selectAll-announcements" onchange="toggleSelectAll('announcements', this.checked)">
                                </th>
                                <th>title</th>
                                <th>posted_at</th>
                                <th>delayed_post_at</th>
