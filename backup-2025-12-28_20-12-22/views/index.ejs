                        </button>
                    </div>
                    <div class="tab-loading hidden" id="loading-modules">Loading modules...</div>
                    <div class="tab-error hidden" id="error-modules"></div>
                    <table class="data-table" id="modulesTable">
                        <thead>
                            <tr>
                                <th class="checkbox-header">
                                    <input type="checkbox" class="select-all-checkbox" id="selectAll-modules" onchange="toggleSelectAll('modules', this.checked)">
                                </th>
