                        <button class="sync-btn" id="sync-pages" onclick="syncChanges('pages')" disabled>
                            <span>💾</span>
                            Sync to Canvas
                            <span class="changes-count hidden" id="changesCount-pages">0</span>
                        </button>
                        <button class="refresh-btn" onclick="refreshTab('pages')" id="refresh-pages">
                            <span class="refresh-icon"></span>
                            Refresh
