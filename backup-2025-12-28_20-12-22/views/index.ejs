                tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No announcements found</td></tr>';
                return;
            }

            announcements.forEach((announcement, index) => {
                const row = document.createElement('tr');
                const itemId = announcement.id || index;
                const isChecked = selectedItems['announcements'].has(itemId);
                const authorName = announcement.author ? (announcement.author.display_name || announcement.author.name || '-') : '-';
                const messagePreview = announcement.message ? announcement.message.replace(/<[^>]*>/g, '').substring(0, 100) + '...' : '-';
                row.innerHTML = `
                    <td class="checkbox-cell">
                        <input type="checkbox" class="row-checkbox" data-tab="announcements" data-id="${itemId}" ${isChecked ? 'checked' : ''} onchange="toggleRowSelection('announcements', '${itemId}', this.checked)">
                    </td>
                    <td data-item-id="${itemId}" data-field="title"></td>
                    <td data-item-id="${itemId}" data-field="posted_at"></td>
                    <td data-item-id="${itemId}" data-field="delayed_post_at"></td>
                    <td class="readonly-cell">${escapeHtml(authorName)}</td>
                    <td class="readonly-cell">${escapeHtml(messagePreview)}</td>
                `;
                if (isChecked) row.classList.add('selected');
                
                if (!originalData['announcements']) originalData['announcements'] = {};
                originalData['announcements'][itemId] = announcement;
                
                const titleCell = row.querySelector('[data-field="title"]');
                const postedAtCell = row.querySelector('[data-field="posted_at"]');
                const delayedPostAtCell = row.querySelector('[data-field="delayed_post_at"]');
                
                makeCellEditable(titleCell, 'announcements', itemId, 'title', announcement.title, 'text');
                makeCellEditable(postedAtCell, 'announcements', itemId, 'posted_at', announcement.posted_at, 'datetime');
                makeCellEditable(delayedPostAtCell, 'announcements', itemId, 'delayed_post_at', announcement.delayed_post_at, 'datetime');
                
                displayCellValue(titleCell, 'announcements', itemId, 'title', announcement.title, 'text');
                displayCellValue(postedAtCell, 'announcements', itemId, 'posted_at', announcement.posted_at, 'datetime');
                displayCellValue(delayedPostAtCell, 'announcements', itemId, 'delayed_post_at', announcement.delayed_post_at, 'datetime');
                
                tbody.appendChild(row);
            });
        }

        function displayStudents(students) {
            const countEl = document.getElementById('studentsCount');
            const tbody = document.getElementById('studentsTableBody');
            
            if (!selectedItems['students']) {
                selectedItems['students'] = new Set();
            }
            
            countEl.textContent = `${students.length} student${students.length !== 1 ? 's' : ''}`;
            tbody.innerHTML = '';
            
            const selectAllCheckbox = document.getElementById('selectAll-students');
            if (selectAllCheckbox) selectAllCheckbox.checked = false;

            const table = document.getElementById('studentsTable');
            if (students.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="empty-state">No students found</td></tr>';
                if (table) table.style.display = '';
                return;
            }

            debugLog(`Rendering ${students.length} student rows...`, 'info');
            students.forEach((student, index) => {
                const row = document.createElement('tr');
                const itemId = student.id || student.enrollment_id || index;
                const isChecked = selectedItems['students'].has(itemId);
                row.innerHTML = `
                    <td class="checkbox-cell">
                        <input type="checkbox" class="row-checkbox" data-tab="students" data-id="${itemId}" ${isChecked ? 'checked' : ''} onchange="toggleRowSelection('students', '${itemId}', this.checked)">
                    </td>
                    <td>${escapeHtml(student.name || '-')}</td>
                    <td>${escapeHtml(student.email || '-')}</td>
                    <td>${escapeHtml(student.sis_user_id || '-')}</td>
                    <td><span class="badge" style="background: ${getStateColor(student.enrollment_state)}; color: white;">${escapeHtml(student.enrollment_state || 'unknown')}</span></td>
                `;
                if (isChecked) row.classList.add('selected');
                tbody.appendChild(row);
            });
            
            if (table) table.style.display = '';
            debugLog(`Successfully displayed ${students.length} students`, 'success');
        }

        function getStateColor(state) {
            const colors = {
                active: '#28a745',
                invited: '#ffc107',
                creation_pending: '#17a2b8',
                deleted: '#dc3545',
                rejected: '#dc3545',
                completed: '#6c757d',
                inactive: '#6c757d'
            };
            return colors[state] || '#6c757d';
        }

        function toggleSelectAll(tabName, checked) {
            if (!selectedItems[tabName]) {
                selectedItems[tabName] = new Set();
            }
            
            const checkboxes = document.querySelectorAll(`#tab-${tabName} .row-checkbox`);
            checkboxes.forEach(cb => {
                cb.checked = checked;
                const itemId = cb.getAttribute('data-id');
                if (checked) {
                    selectedItems[tabName].add(itemId);
                    cb.closest('tr').classList.add('selected');
                } else {
                    selectedItems[tabName].delete(itemId);
                    cb.closest('tr').classList.remove('selected');
                }
            });
        }

        function toggleRowSelection(tabName, itemId, checked) {
            if (!selectedItems[tabName]) {
                selectedItems[tabName] = new Set();
            }
            
            if (checked) {
                selectedItems[tabName].add(itemId);
            } else {
                selectedItems[tabName].delete(itemId);
            }
            
            const row = document.querySelector(`[data-item-id="${itemId}"]`)?.closest('tr');
            if (row) {
                if (checked) {
                    row.classList.add('selected');
                } else {
                    row.classList.remove('selected');
                }
            }
            
            const selectAllCheckbox = document.getElementById(`selectAll-${tabName}`);
            if (selectAllCheckbox) {
                const allCheckboxes = document.querySelectorAll(`#tab-${tabName} .row-checkbox`);
                const checkedCount = Array.from(allCheckboxes).filter(cb => cb.checked).length;
                selectAllCheckbox.checked = checkedCount === allCheckboxes.length && allCheckboxes.length > 0;
            }
        }

        function makeCellEditable(cell, tabName, itemId, fieldName, currentValue, fieldType) {
            if (!cell) return;
            
            cell.classList.add('cell-editable');
            
            const actualCurrentValue = changes[tabName] && changes[tabName][itemId] && changes[tabName][itemId][fieldName] !== undefined
                ? changes[tabName][itemId][fieldName]
                : currentValue;
            
            cell.addEventListener('click', function startEditing() {
                if (cell.querySelector('.cell-input')) return; // Already editing
                
                let input;
                if (fieldType === 'boolean') {
                    input = document.createElement('input');
                    input.type = 'checkbox';
                    input.checked = actualCurrentValue === true || actualCurrentValue === 'true' || actualCurrentValue === 1;
                } else if (fieldType === 'datetime' || fieldName.includes('_at') || fieldName.includes('date')) {
                    input = document.createElement('input');
                    input.type = 'datetime-local';
                    if (actualCurrentValue) {
                        input.value = formatDateForInput(actualCurrentValue);
                    } else {
                        // Default to today at 11:59 PM (local time)
                        const today = new Date();
                        const year = today.getFullYear();
                        const month = String(today.getMonth() + 1).padStart(2, '0');
                        const day = String(today.getDate()).padStart(2, '0');
                        input.value = `${year}-${month}-${day}T23:59`;
                    }
                    
                    // Auto-set time to 11:59 PM when date changes
                    let lastDateValue = input.value ? input.value.split('T')[0] : null;
                    input.addEventListener('change', function() {
                        if (input.value) {
                            const currentDateValue = input.value.split('T')[0];
                            if (currentDateValue !== lastDateValue) {
                                input.value = `${currentDateValue}T23:59`;
                                lastDateValue = currentDateValue;
                            }
                        }
                    });
                } else if (fieldType === 'number') {
                    input = document.createElement('input');
                    input.type = 'number';
                    input.value = actualCurrentValue || '';
                } else {
                    input = document.createElement('input');
                    input.type = 'text';
                    input.value = actualCurrentValue || '';
                }
                
                input.className = 'cell-input';
                cell.innerHTML = '';
                cell.appendChild(input);
                input.focus();
                if (input.type !== 'checkbox') input.select();
                
                const finishEditing = (save = true) => {
                    let newValue;
                    if (input.type === 'checkbox') {
                        newValue = input.checked;
                    } else if (input.type === 'datetime-local') {
                        newValue = formatDateForAPI(input.value);
                    } else if (input.type === 'number') {
                        newValue = input.value ? parseFloat(input.value) : null;
                    } else {
                        newValue = input.value.trim() || null;
                    }
                    
                    const originalValue = originalData[tabName] && originalData[tabName][itemId] 
                        ? originalData[tabName][itemId][fieldName] 
                        : actualCurrentValue;
                    
                    if (save) {
                        const valueChanged = JSON.stringify(newValue) !== JSON.stringify(originalValue);
                        if (valueChanged) {
                            trackChange(tabName, itemId, fieldName, newValue, originalValue);
                        }
                        displayCellValue(cell, tabName, itemId, fieldName, newValue, fieldType);
                    } else {
                        displayCellValue(cell, tabName, itemId, fieldName, originalValue, fieldType);
                    }
                };
                
                input.addEventListener('blur', () => finishEditing(true));
                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        finishEditing(true);
                    } else if (e.key === 'Escape') {
                        e.preventDefault();
                        finishEditing(false);
                    }
                });
            });
        }

        function displayCellValue(cell, tabName, itemId, fieldName, value, fieldType) {
            if (fieldType === 'boolean') {
                cell.textContent = value ? '✓' : '✗';
            } else if (fieldType === 'datetime' || fieldName.includes('_at') || fieldName.includes('date')) {
                cell.textContent = value ? formatDateForDisplay(value) : '-';
            } else {
                cell.textContent = value || '-';
            }
        }

        function trackChange(tabName, itemId, fieldName, newValue, oldValue) {
            if (!changes[tabName]) {
                changes[tabName] = {};
            }
            if (!changes[tabName][itemId]) {
                changes[tabName][itemId] = {};
            }
            
            changes[tabName][itemId][fieldName] = newValue;
            
            debugLog(`Change tracked: ${tabName}[${itemId}].${fieldName} = ${newValue}`, 'info');
            
            const row = document.querySelector(`[data-item-id="${itemId}"]`)?.closest('tr');
            if (row) {
                row.classList.add('modified');
            }
            
            updateSyncButton(tabName);
        }

        function updateSyncButton(tabName) {
            const syncBtn = document.getElementById(`sync-${tabName}`);
            const changesCount = document.getElementById(`changesCount-${tabName}`);
            
            if (!syncBtn) return;
            
            const changeCount = Object.keys(changes[tabName] || {}).length;
            
            if (changeCount > 0) {
                syncBtn.disabled = false;
                syncBtn.classList.add('has-changes');
                if (changesCount) {
                    changesCount.textContent = changeCount;
                    changesCount.classList.remove('hidden');
                }
            } else {
                syncBtn.disabled = true;
                syncBtn.classList.remove('has-changes');
                if (changesCount) {
                    changesCount.classList.add('hidden');
                }
            }
        }

        async function syncChanges(tabName) {
            debugLog(`=== ATTEMPTING TO SYNC TO CANVAS ===`, 'info');
            debugLog(`Tab: ${tabName}`, 'info');
            debugLog(`Course ID: ${currentCourseId}`, 'info');
            
            if (!currentCourseId) {
                debugLog(`ERROR: No course selected for sync`, 'error');
                alert('No course selected');
                return;
            }
            
            const tabChanges = changes[tabName];
            if (!tabChanges || Object.keys(tabChanges).length === 0) {
                debugLog(`No changes to sync for ${tabName}`, 'warn');
                alert('No changes to sync');
                return;
            }
            
            const syncBtn = document.getElementById(`sync-${tabName}`);
            if (syncBtn) {
                syncBtn.disabled = true;
                syncBtn.textContent = 'Syncing...';
            }
            
            const changeCount = Object.keys(tabChanges).length;
            debugLog(`Syncing ${changeCount} changed item(s) for ${tabName}...`, 'info');
            debugLog(`Changes to sync: ${JSON.stringify(tabChanges, null, 2)}`, 'info');
            
            try {
                const updatePromises = Object.keys(tabChanges).map(async (itemId) => {
                    const itemChanges = tabChanges[itemId];
                    let id = itemId;
                    
                    if (tabName === 'pages') {
                        id = itemId;
                    } else {
                        id = parseInt(itemId);
                    }
                    
                    debugLog(`Updating ${tabName} ${id} with changes: ${JSON.stringify(itemChanges)}`, 'info');
                    
                    // Special handling for quiz due_at: route to assignment endpoint
                    // ALL classic quizzes have assignment_id, so due_at must go to assignment endpoint
                    // This includes when due_at is null (to delete the due date)
                    if (tabName === 'quizzes' && itemChanges.due_at !== undefined) {
                        const originalQuiz = originalData['quizzes'] && originalData['quizzes'][itemId];
                        if (!originalQuiz) {
                            debugLog(`ERROR: Cannot find original quiz data for quiz ${id}`, 'error');
                            throw new Error(`Cannot find original quiz data for quiz ${id}`);
                        }
                        
                        const quizAssignmentId = originalQuiz.assignment_id;
                        if (!quizAssignmentId) {
                            debugLog(`ERROR: Quiz ${id} does not have assignment_id (this should not happen for classic quizzes)`, 'error');
                            throw new Error(`Quiz ${id} does not have assignment_id`);
                        }
                        
                        const dueAtChange = itemChanges.due_at;
                        const quizChangesWithoutDueAt = { ...itemChanges };
                        delete quizChangesWithoutDueAt.due_at;
                        
                        debugLog(`Quiz ${id} has assignment_id ${quizAssignmentId}, routing due_at to assignment endpoint`, 'info');
                        
                        let quizData = null;
                        
                        // Update quiz with other fields (if any)
                        if (Object.keys(quizChangesWithoutDueAt).length > 0) {
                            const endpoint = `/canvas/courses/${currentCourseId}/${tabName}/${id}`;
                            debugLog(`=== REQUEST (Quiz Update - Other Fields) ===`, 'info');
                            debugLog(`URL: ${endpoint}`, 'info');
                            debugLog(`Request body: ${JSON.stringify(quizChangesWithoutDueAt, null, 2)}`, 'info');
                            
                            const quizResponse = await fetch(endpoint, {
                                method: 'PUT',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(quizChangesWithoutDueAt),
                            });
                            
                            const quizResponseText = await quizResponse.text();
                            debugLog(`=== RESPONSE (Quiz Update) ===`, quizResponse.ok ? 'success' : 'error');
                            debugLog(`Status: ${quizResponse.status}`, quizResponse.ok ? 'success' : 'error');
                            debugLog(`Body: ${quizResponseText}`, 'info');
                            
                            if (!quizResponse.ok) {
                                throw new Error(`Failed to update quiz ${id}: ${quizResponse.status} - ${quizResponseText}`);
                            }
                            
                            try {
                                quizData = JSON.parse(quizResponseText);
                            } catch (e) {
                                debugLog(`Failed to parse quiz response: ${e.message}`, 'warn');
                            }
                        }
                        
                        // Update assignment with due_at
                        const assignmentEndpoint = `/canvas/courses/${currentCourseId}/assignments/${quizAssignmentId}`;
                        const assignmentBody = { due_at: dueAtChange };
                        
                        debugLog(`=== REQUEST (Assignment Due Date) ===`, 'info');
                        debugLog(`URL: ${assignmentEndpoint}`, 'info');
                        debugLog(`Request body: ${JSON.stringify(assignmentBody, null, 2)}`, 'info');
                        
                        const assignmentResponse = await fetch(assignmentEndpoint, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(assignmentBody),
                        });
                        
                        const assignmentResponseText = await assignmentResponse.text();
                        debugLog(`=== RESPONSE (Assignment Due Date) ===`, assignmentResponse.ok ? 'success' : 'error');
                        debugLog(`Status: ${assignmentResponse.status}`, assignmentResponse.ok ? 'success' : 'error');
                        debugLog(`Body: ${assignmentResponseText}`, 'info');
                        
                        if (!assignmentResponse.ok) {
                            throw new Error(`Failed to update assignment ${quizAssignmentId}: ${assignmentResponse.status} - ${assignmentResponseText}`);
                        }
                        
                        let assignmentData = null;
                        try {
                            assignmentData = JSON.parse(assignmentResponseText);
                        } catch (e) {
                            debugLog(`Failed to parse assignment response: ${e.message}`, 'warn');
                        }
                        
                        return { id, success: true, data: assignmentData || quizData };
                    }
                    
                    const urlId = tabName === 'pages' ? encodeURIComponent(id) : id;
                    const endpoint = `/canvas/courses/${currentCourseId}/${tabName}/${urlId}`;
                    
                    debugLog(`=== REQUEST ===`, 'info');
                    debugLog(`URL: ${endpoint}`, 'info');
                    debugLog(`Method: PUT`, 'info');
                    debugLog(`Request body: ${JSON.stringify(itemChanges, null, 2)}`, 'info');
                    
                    const response = await fetch(endpoint, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(itemChanges),
                    });
                    
                    const responseText = await response.text();
                    debugLog(`=== RESPONSE ===`, response.ok ? 'success' : 'error');
                    debugLog(`Status: ${response.status}`, response.ok ? 'success' : 'error');
                    debugLog(`Body: ${responseText}`, 'info');
                    
                    if (!response.ok) {
                        throw new Error(`Failed to update ${tabName} ${id}: ${response.status} - ${responseText}`);
                    }
                    
                    let data = null;
                    try {
                        data = JSON.parse(responseText);
                    } catch (e) {
                        debugLog(`Failed to parse response: ${e.message}`, 'warn');
                    }
                    
                    debugLog(`Successfully updated ${tabName} ${id}`, 'success');
                    return { id, success: true, data };
                });
                
                const results = await Promise.allSettled(updatePromises);
                const processedResults = results.map((result, index) => {
                    if (result.status === 'fulfilled') {
                        return result.value;
                    } else {
                        const itemId = Object.keys(tabChanges)[index];
                        const errorMsg = result.reason?.message || 'Unknown error';
                        debugLog(`Update failed for item ${itemId}: ${errorMsg}`, 'error');
                        return { id: itemId, success: false, error: errorMsg };
                    }
                });
                
                const successCount = processedResults.filter(r => r.success).length;
                const failCount = processedResults.filter(r => !r.success).length;
                
                debugLog(`Sync complete: ${successCount} succeeded, ${failCount} failed`, successCount > 0 ? 'success' : 'error');
                
                if (failCount > 0) {
                    const failedItems = processedResults.filter(r => !r.success);
                    debugLog(`Failed items: ${JSON.stringify(failedItems)}`, 'error');
                    alert(`Sync completed with ${failCount} error(s). Check debug log for details.`);
                } else {
                    alert(`Successfully synced ${successCount} item(s) to Canvas!`);
                }
                
                changes[tabName] = {};
                updateSyncButton(tabName);
                
                document.querySelectorAll(`#tab-${tabName} tr.modified`).forEach(row => {
                    row.classList.remove('modified');
                });
                
                if (syncBtn) {
                    syncBtn.textContent = '💾 Sync to Canvas';
                }
                
                // Refresh the tab to show updated data
                await refreshTab(tabName);
            } catch (error) {
                debugLog(`Sync error: ${error.message}`, 'error');
                alert(`Sync failed: ${error.message}`);
                if (syncBtn) {
                    syncBtn.disabled = false;
                    syncBtn.textContent = '💾 Sync to Canvas';
                }
            }
        }
    </script>
</body>
</html>