                        <div class="count-badge" id="discussionsCount">0 discussions</div>
                        <button class="sync-btn" id="sync-discussions" onclick="syncChanges('discussions')" disabled>
                            <span>💾</span>
                            Sync to Canvas
                            <span class="changes-count hidden" id="changesCount-discussions">0</span>
                        </button>
                        <button class="refresh-btn" onclick="refreshTab('discussions')" id="refresh-discussions">
                            <span class="refresh-icon"></span>
                            Refresh
                        </button>
                    </div>
                    <div class="tab-loading hidden" id="loading-discussions">Loading discussions...</div>
                    <div class="tab-error hidden" id="error-discussions"></div>
                    <table class="data-table" id="discussionsTable">
                        <thead>
                            <tr>
                                <th class="checkbox-header">
                                    <input type="checkbox" class="select-all-checkbox" id="selectAll-discussions" onchange="toggleSelectAll('discussions', this.checked)">
                                </th>
                                <th>title</th>
                                <th>posted_at</th>
                                <th>delayed_post_at</th>
