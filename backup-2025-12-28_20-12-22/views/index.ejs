                <!-- Modules Tab -->
                <div class="tab-content" id="tab-modules">
                    <div class="tab-header">
                        <div class="count-badge" id="modulesCount">0 modules</div>
                        <button class="sync-btn" id="sync-modules" onclick="syncChanges('modules')" disabled>
                            <span>💾</span>
                            Sync to Canvas
                            <span class="changes-count hidden" id="changesCount-modules">0</span>
                        </button>
                        <button class="refresh-btn" onclick="refreshTab('modules')" id="refresh-modules">
