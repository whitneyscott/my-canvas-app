                <!-- Accommodations Tab -->
                <div class="tab-content" id="tab-accommodations">
                    <div class="tab-header">
                        <div class="count-badge" id="accommodationsCount">0 accommodations</div>
                        <button class="sync-btn" id="sync-accommodations" onclick="syncChanges('accommodations')" disabled>
                            <span>💾</span>
                            Sync to Canvas
                            <span class="changes-count hidden" id="changesCount-accommodations">0</span>
                        </button>
                        <button class="refresh-btn" onclick="refreshTab('accommodations')" id="refresh-accommodations">
                            <span class="refresh-icon"></span>
                            Refresh
                        </button>
