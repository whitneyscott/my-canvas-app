                <!-- Assignments Tab -->
                <div class="tab-content" id="tab-assignments">
                    <div class="tab-header">
                        <div class="count-badge" id="assignmentsCount">0 assignments</div>
                        <button class="sync-btn" id="sync-assignments" onclick="syncChanges('assignments')" disabled>
                            <span>💾</span>
                            Sync to Canvas
                            <span class="changes-count hidden" id="changesCount-assignments">0</span>
                        </button>
                        <button class="refresh-btn" onclick="refreshTab('assignments')" id="refresh-assignments">
                            <span class="refresh-icon"></span>
                            Refresh
