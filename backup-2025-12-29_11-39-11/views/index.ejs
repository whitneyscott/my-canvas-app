        function getCurrentTabName() {
            const activeTab = document.querySelector('.tab-content.active');
            if (!activeTab) return null;
            const tabId = activeTab.id;
            return tabId.replace('tab-', '');
        }

        function getSelectedItems() {
            const tabName = getCurrentTabName();
            if (!tabName) return [];
            
            const selected = selectedItems[tabName] || new Set();
            return Array.from(selected);
        }

        function applyDateShift() {
            const tabName = getCurrentTabName();
            if (!tabName) {
                alert('Please select a tab first.');
                closeModal('dateShiftModal');
                return;
            }

            const selected = getSelectedItems();
            if (selected.length === 0) {
                alert('Please select at least one item.');
                closeModal('dateShiftModal');
                return;
            }

            const field = document.getElementById('dateShiftField').value;
            const days = parseInt(document.getElementById('dateShiftDays').value);
            
            if (isNaN(days)) {
                alert('Please enter a valid number of days.');
                return;
            }

            if (days === 0) {
                alert('Please enter a non-zero number of days.');
                return;
            }

            const millisecondsPerDay = 24 * 60 * 60 * 1000;
            const offsetMs = days * millisecondsPerDay;

            let modifiedCount = 0;
            selected.forEach(itemId => {
                const original = originalData[tabName]?.[itemId];
                if (!original) return;

                const currentValue = original[field];
                if (!currentValue) {
                    debugLog(`Skipping ${itemId}: no ${field} to offset`, 'warn');
                    return;
                }

                const currentDate = new Date(currentValue);
                if (isNaN(currentDate.getTime())) {
                    debugLog(`Skipping ${itemId}: invalid date ${currentValue}`, 'warn');
                    return;
                }

                const newDate = new Date(currentDate.getTime() + offsetMs);
                const newValue = newDate.toISOString();

                // Update the change tracking
                if (!changes[tabName]) changes[tabName] = {};
                if (!changes[tabName][itemId]) changes[tabName][itemId] = {};
                changes[tabName][itemId][field] = newValue;

                // Update the cell display
                const cell = document.querySelector(`#tab-${tabName} [data-item-id="${itemId}"][data-field="${field}"]`);
                if (cell) {
                    displayCellValue(cell, tabName, itemId, field, newValue, 'datetime');
                    const row = cell.closest('tr');
                    if (row) row.classList.add('modified');
                }

                modifiedCount++;
            });

            updateSyncButton(tabName);
            alert(`Date shift applied to ${modifiedCount} item(s). Click "Sync to Canvas" to save changes.`);
            closeModal('dateShiftModal');
        }

        function applySearchReplace() {
            const tabName = getCurrentTabName();
            if (!tabName) {
                alert('Please select a tab first.');
                closeModal('searchReplaceModal');
                return;
            }

            const selected = getSelectedItems();
            if (selected.length === 0) {
                alert('Please select at least one item.');
                closeModal('searchReplaceModal');
                return;
            }

            const field = document.getElementById('searchReplaceField').value;
            const searchText = document.getElementById('searchReplaceFind').value.trim();
            const replaceText = document.getElementById('searchReplaceWith').value;

            if (!searchText) {
                alert('Please enter text to search for.');
                return;
            }

            let modifiedCount = 0;
            selected.forEach(itemId => {
                const original = originalData[tabName]?.[itemId];
                if (!original) return;

                const currentValue = original[field];
                if (!currentValue || typeof currentValue !== 'string') {
                    debugLog(`Skipping ${itemId}: no ${field} or not a string`, 'warn');
                    return;
                }

                if (!currentValue.includes(searchText)) {
                    return; // No match, skip
                }

                const newValue = currentValue.replace(new RegExp(searchText.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), replaceText);

                // Update the change tracking
                if (!changes[tabName]) changes[tabName] = {};
                if (!changes[tabName][itemId]) changes[tabName][itemId] = {};
                changes[tabName][itemId][field] = newValue;

                // Update the cell display
                const cell = document.querySelector(`#tab-${tabName} [data-item-id="${itemId}"][data-field="${field}"]`);
                if (cell) {
                    displayCellValue(cell, tabName, itemId, field, newValue, 'text');
                    const row = cell.closest('tr');
                    if (row) row.classList.add('modified');
                }

                modifiedCount++;
            });

            updateSyncButton(tabName);
            alert(`Search and replace applied to ${modifiedCount} item(s). Click "Sync to Canvas" to save changes.`);
            closeModal('searchReplaceModal');
        }

        function applyPublishStatus(shouldPublish) {
            const tabName = getCurrentTabName();
            if (!tabName) {
                alert('Please select a tab first.');
                closeModal('publishStatusModal');
                return;
            }

            const selected = getSelectedItems();
            if (selected.length === 0) {
                alert('Please select at least one item.');
                closeModal('publishStatusModal');
                return;
            }

            let modifiedCount = 0;
            selected.forEach(itemId => {
                const original = originalData[tabName]?.[itemId];
                if (!original) return;

                // Update the change tracking
                if (!changes[tabName]) changes[tabName] = {};
                if (!changes[tabName][itemId]) changes[tabName][itemId] = {};
                changes[tabName][itemId]['published'] = shouldPublish;

                // Update the cell display
                const cell = document.querySelector(`#tab-${tabName} [data-item-id="${itemId}"][data-field="published"]`);
                if (cell) {
                    displayCellValue(cell, tabName, itemId, 'published', shouldPublish, 'boolean');
                    const row = cell.closest('tr');
                    if (row) row.classList.add('modified');
                }

                modifiedCount++;
            });

            updateSyncButton(tabName);
            alert(`${shouldPublish ? 'Published' : 'Unpublished'} ${modifiedCount} item(s). Click "Sync to Canvas" to save changes.`);
            closeModal('publishStatusModal');
        }

        function displayPages(pages) {
            // Generate custom headers with sort/filter controls
            generateCustomHeaders('pages');
            
            const countEl = document.getElementById('pagesCount');
            const tbody = document.getElementById('pagesTableBody');
            
            if (!selectedItems['pages']) {
                selectedItems['pages'] = new Set();
            }
            
            countEl.textContent = `${pages.length} page${pages.length !== 1 ? 's' : ''}`;
            tbody.innerHTML = '';
            
            const selectAllCheckbox = document.getElementById('selectAll-pages');
            if (selectAllCheckbox) selectAllCheckbox.checked = false;

            if (pages.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" class="empty-state">No pages found</td></tr>';
                return;
            }

            pages.forEach((page, index) => {
                const row = document.createElement('tr');
                const itemId = page.url || index;
                const isChecked = selectedItems['pages'].has(itemId);
                // Build Canvas page URL - use html_url if available, otherwise construct it
                const courseId = getCurrentCourseId();
                const pageUrl = page.url || '';
                let canvasPageUrl = '#';
                if (page.html_url) {
                    canvasPageUrl = page.html_url;
                } else if (courseId && pageUrl) {
                    // Construct URL - we'll need to get base URL, but for now use instructure.com
                    // Note: This might need adjustment based on your Canvas instance
                    canvasPageUrl = `https://canvas.instructure.com/courses/${courseId}/pages/${encodeURIComponent(pageUrl)}`;
                }
                
                // Get page preview (strip HTML and truncate)
                const pageBody = page.body || '';
                let previewText = '';
                let previewDisplay = '-';
                let tooltipText = '';
                
                if (pageBody && typeof pageBody === 'string' && pageBody.trim()) {
                    // Strip HTML tags and normalize whitespace
                    previewText = pageBody
                        .replace(/<[^>]*>/g, '') // Remove HTML tags
                        .replace(/&nbsp;/g, ' ') // Replace &nbsp; with space
                        .replace(/&[a-z]+;/gi, ' ') // Replace other HTML entities
                        .replace(/\s+/g, ' ') // Normalize whitespace
                        .trim();
                    
                    if (previewText.length > 0) {
                        // Tooltip text (up to 1000 chars)
                        tooltipText = previewText.length > 1000 
                            ? previewText.substring(0, 1000) + '...' 
                            : previewText;
                        
                        // Cell display (up to 200 chars for better visibility)
                        if (previewText.length > 200) {
                            previewDisplay = previewText.substring(0, 200) + '...';
                        } else {
                            previewDisplay = previewText;
                        }
                    }
                }
                
                // Create preview cell with tooltip
                let previewCellHtml;
                if (tooltipText && tooltipText.length > 0) {
                    const escapedDisplay = escapeHtml(previewDisplay);
                    const escapedTitle = escapeHtml(page.title || 'Page Preview');
                    const escapedTooltip = escapeHtml(tooltipText);
                    const tooltipId = 'tooltip-' + itemId.replace(/[^a-zA-Z0-9]/g, '-');
                    
                    previewCellHtml = '<div class="preview-cell" style="max-width: 300px; word-wrap: break-word; overflow-wrap: break-word;" ' +
                        'onmouseenter="showPreviewTooltip(event, \'' + tooltipId + '\')" ' +
                        'onmouseleave="hidePreviewTooltip(\'' + tooltipId + '\')" ' +
                        'data-tooltip-id="' + tooltipId + '">' +
                        escapedDisplay +
                        '<div class="preview-tooltip" id="' + tooltipId + '">' +
                        '<div class="preview-tooltip-title">' + escapedTitle + '</div>' +
                        '<div class="preview-tooltip-content">' + escapedTooltip + '</div>' +
                        '</div>' +
                        '</div>';
                } else {
                    previewCellHtml = '<div class="readonly-cell" style="max-width: 300px;">-</div>';
                }
                
                row.innerHTML = `
                    <td class="checkbox-cell">
                        <input type="checkbox" class="row-checkbox" data-tab="pages" data-id="${itemId}" ${isChecked ? 'checked' : ''} onchange="toggleRowSelection('pages', '${itemId}', this.checked)">
                    </td>
                    <td data-item-id="${itemId}" data-field="title"></td>
                    <td class="readonly-cell" data-item-id="${itemId}">${escapeHtml(page.url || '-')}</td>
                    <td>${previewCellHtml}</td>
                    <td class="readonly-cell">
                        <a href="${canvasPageUrl}" target="_blank" rel="noopener noreferrer" style="color: #2196F3; text-decoration: none;" title="Open page in Canvas">
                            🔗 View
                        </a>
                    </td>
                    <td data-item-id="${itemId}" data-field="published"></td>
                    <td data-item-id="${itemId}" data-field="front_page"></td>
                    <td class="readonly-cell" data-item-id="${itemId}">${page.updated_at ? formatDateForDisplay(page.updated_at) : '-'}</td>
                `;
                if (isChecked) row.classList.add('selected');
                
                if (!originalData['pages']) originalData['pages'] = {};
                originalData['pages'][itemId] = page;
                
                const titleCell = row.querySelector('[data-field="title"]');
                const publishedCell = row.querySelector('[data-field="published"]');
                const frontPageCell = row.querySelector('[data-field="front_page"]');
                
                makeCellEditable(titleCell, 'pages', itemId, 'title', page.title, 'text');
                // Published fields use toggle buttons, not editable cells
                // front_page is a toggle button with mutual exclusivity - don't make it editable
                
                displayCellValue(titleCell, 'pages', itemId, 'title', page.title, 'text');
                displayCellValue(publishedCell, 'pages', itemId, 'published', page.published, 'boolean');
                displayCellValue(frontPageCell, 'pages', itemId, 'front_page', page.front_page, 'boolean');
                
                tbody.appendChild(row);
            });
            
            // Apply any existing filters/sorts
            applySortAndFilter('pages');
        }

