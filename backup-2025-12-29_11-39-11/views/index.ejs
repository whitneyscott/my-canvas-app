        function openPublishStatusModal() {
            const selected = getSelectedItems();
            if (selected.length === 0) {
                alert('Please select at least one item.');
                return;
            }
            
            const summary = document.getElementById('publishStatusSummary');
            const btn = document.getElementById('publishStatusBtn');
            if (summary && btn) {
                const tabName = getCurrentTabName();
                const itemType = tabName === 'assignments' ? 'Assignments' : 
                                tabName === 'quizzes' ? 'Quizzes' : 
                                tabName.charAt(0).toUpperCase() + tabName.slice(1);
                
                // Check current publish status to determine action
                let publishCount = 0;
                let unpublishCount = 0;
                selected.forEach(itemId => {
                    const original = originalData[tabName]?.[itemId];
                    if (original) {
                        if (original.published) {
                            unpublishCount++;
                        } else {
                            publishCount++;
                        }
                    }
                });
                
                if (publishCount > 0 && unpublishCount > 0) {
                    summary.innerHTML = `<strong>Mixed Status:</strong> ${publishCount} unpublished, ${unpublishCount} published. Choose an action below.`;
                    btn.textContent = 'Publish All';
                    btn.onclick = () => applyPublishStatus(true);
                } else if (publishCount > 0) {
                    summary.innerHTML = `<strong>Confirm:</strong> Publish <strong>${selected.length} ${itemType}</strong>`;
                    btn.textContent = 'Publish';
                    btn.onclick = () => applyPublishStatus(true);
                } else {
                    summary.innerHTML = `<strong>Confirm:</strong> Unpublish <strong>${selected.length} ${itemType}</strong>`;
                    btn.textContent = 'Unpublish';
                    btn.onclick = () => applyPublishStatus(false);
                }
