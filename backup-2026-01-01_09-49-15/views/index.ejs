        // Store accommodation data globally
        let accommodationGroups = []; // List of available accommodation groups
        let studentAccommodations = {}; // Map of studentId -> array of group names
        let originalAccommodations = {}; // Map of studentId -> array of group names (original state when loaded)

        // Fetch accommodation data and populate dropdowns
        async function loadAccommodations(courseId) {
            try {
                console.log('[loadAccommodations] Fetching accommodation data for course:', courseId);
                
                // First, get the list of accommodation groups
                const categoriesResponse = await fetch(`/canvas/courses/${courseId}/group_categories`);
                if (!categoriesResponse.ok) {
                    console.error('[loadAccommodations] Failed to fetch group categories');
                    return;
                }
                const categories = await categoriesResponse.json();
                const accommodationsCategory = categories.find((cat) => cat.name === 'Accommodations');
                
                if (!accommodationsCategory) {
                    console.log('[loadAccommodations] Accommodations category not found');
                    accommodationGroups = [];
                    studentAccommodations = {};
                    return;
                }
                
                // Get groups in the Accommodations category
                const groupsResponse = await fetch(`/canvas/group_categories/${accommodationsCategory.id}/groups`);
                if (!groupsResponse.ok) {
                    console.error('[loadAccommodations] Failed to fetch groups');
                    return;
                }
                const groups = await groupsResponse.json();
                accommodationGroups = groups.map(g => ({ id: g.id, name: g.name }));
                console.log('[loadAccommodations] Found accommodation groups:', accommodationGroups.map(g => g.name));
                
                // Now sync accommodations to get student-to-groups mapping
                const syncResponse = await fetch(`/canvas/courses/${courseId}/accommodations/sync`);
                if (!syncResponse.ok) {
                    console.error('[loadAccommodations] Failed to sync accommodations');
                    return;
                }
                const accommodationsMap = await syncResponse.json();
                studentAccommodations = accommodationsMap;
                // Store original accommodations for comparison
                originalAccommodations = JSON.parse(JSON.stringify(accommodationsMap)); // Deep copy
                console.log('[loadAccommodations] Loaded accommodations for', Object.keys(accommodationsMap).length, 'students');
                console.log('[loadAccommodations] Accommodation groups:', accommodationGroups);
                console.log('[loadAccommodations] Student accommodations sample:', Object.keys(accommodationsMap).slice(0, 3).map(id => ({ id, groups: accommodationsMap[id] })));
                
                // Re-render the accommodation column with checkboxes
                console.log('[loadAccommodations] Re-rendering accommodation column...');
                renderAccommodationColumn();
                console.log('[loadAccommodations] Accommodation column re-rendered');
            } catch (error) {
                console.error('[loadAccommodations] Error:', error);
            }
        }

        // Re-render accommodation column for all students
        function renderAccommodationColumn() {
            const rows = document.querySelectorAll('#studentsTableBody tr');
            console.log(`[renderAccommodationColumn] Found ${rows.length} rows to update`);
            
            if (accommodationGroups.length === 0) {
                console.log('[renderAccommodationColumn] No accommodation groups available yet');
                return;
            }
            
            rows.forEach(row => {
                const checkbox = row.querySelector('.row-checkbox');
                if (!checkbox) return;
                
                const studentId = checkbox.getAttribute('data-id');
                const currentGroups = studentAccommodations[String(studentId)] || [];
                // For mutually exclusive, we only take the first group
                const selectedGroup = currentGroups.length > 0 ? currentGroups[0] : null;
                
                // Find the accommodation cell (last td or td with class accommodation-cell)
                let accommodationCell = row.querySelector('td.accommodation-cell');
                if (!accommodationCell) {
                    // If no accommodation cell exists, create it (shouldn't happen, but just in case)
                    const lastCell = row.querySelector('td:last-child');
                    if (lastCell && lastCell.nextSibling === null) {
                        accommodationCell = document.createElement('td');
                        accommodationCell.className = 'accommodation-cell';
                        row.appendChild(accommodationCell);
                    } else {
                        return;
                    }
                }
                
                // Build accommodation checkboxes
                let accommodationCheckboxes = '';
                if (accommodationGroups.length === 0) {
                    accommodationCheckboxes = '<span style="color: #999; font-style: italic;">No accommodations available</span>';
                } else {
                    accommodationCheckboxes = '<div class="accommodation-checkboxes">';
                    accommodationGroups.forEach(group => {
                        const checked = selectedGroup === group.name ? 'checked' : '';
                        accommodationCheckboxes += `
                            <label class="accommodation-checkbox-label">
                                <input type="checkbox" 
                                       class="accommodation-checkbox" 
                                       data-student-id="${studentId}" 
                                       value="${escapeHtml(group.name)}" 
                                       ${checked} 
                                       onchange="onAccommodationChange('${studentId}', '${escapeHtml(group.name)}', this)">
                                <span>${escapeHtml(group.name)}</span>
                            </label>
                        `;
                    });
                    accommodationCheckboxes += '</div>';
                }
                
                accommodationCell.innerHTML = accommodationCheckboxes;
            });
        }

        // Update all accommodation checkboxes with current data
        function updateAccommodationCheckboxes() {
            Object.keys(studentAccommodations).forEach(studentId => {
                const currentGroups = studentAccommodations[studentId] || [];
                // For mutually exclusive, we only take the first group
                const selectedGroup = currentGroups.length > 0 ? currentGroups[0] : null;
                
                // Update checkboxes for this student
                const checkboxes = document.querySelectorAll(`.accommodation-checkbox[data-student-id="${studentId}"]`);
                checkboxes.forEach(checkbox => {
                    checkbox.checked = checkbox.value === selectedGroup;
                });
            });
        }

        // Handle accommodation checkbox change (mutually exclusive)
        function onAccommodationChange(studentId, groupName, checkbox) {
            if (checkbox.checked) {
                // Uncheck all other checkboxes for this student
                const allCheckboxes = document.querySelectorAll(`.accommodation-checkbox[data-student-id="${studentId}"]`);
                allCheckboxes.forEach(cb => {
                    if (cb !== checkbox) {
                        cb.checked = false;
                    }
                });
                // Set the accommodation to this single group
                studentAccommodations[studentId] = [groupName];
            } else {
                // If unchecking, clear the accommodation
                studentAccommodations[studentId] = [];
            }
            console.log(`[onAccommodationChange] Student ${studentId} accommodation:`, studentAccommodations[studentId]);
            
            // Mark accommodations as changed for sync
            if (!changes['students']) {
                changes['students'] = {};
            }
            // Use a special key to mark that accommodations have changed
            changes['students']['__accommodations'] = true;
            
            // Mark the row as modified
            const row = document.querySelector(`.row-checkbox[data-id="${studentId}"]`)?.closest('tr');
            if (row) {
                row.classList.add('modified');
            }
            
            // Enable the sync button
            updateSyncButton('students');
        }

        // Sync accommodations to Canvas groups
        async function syncAccommodations() {
            if (!currentCourseId) {
                throw new Error('No course selected');
            }

            debugLog('=== SYNCING ACCOMMODATIONS ===', 'info');
            
            // Find all students whose accommodations have changed
            const studentsToSync = [];
            
            // Get all student IDs from both current and original accommodations
            const allStudentIds = new Set([
                ...Object.keys(studentAccommodations),
                ...Object.keys(originalAccommodations)
            ]);
            
            for (const studentId of allStudentIds) {
                const currentGroups = studentAccommodations[studentId] || [];
                const originalGroups = originalAccommodations[studentId] || [];
                
                // Compare (mutually exclusive, so compare first group)
                const currentGroup = currentGroups.length > 0 ? currentGroups[0] : null;
                const originalGroup = originalGroups.length > 0 ? originalGroups[0] : null;
                
                if (currentGroup !== originalGroup) {
                    studentsToSync.push({
                        studentId: parseInt(studentId),
                        currentGroup: currentGroup,
                        originalGroup: originalGroup
                    });
                }
            }
            
            if (studentsToSync.length === 0) {
                debugLog('No accommodation changes to sync', 'info');
                return 0; // Return count of 0
            }
            
            debugLog(`Syncing accommodations for ${studentsToSync.length} student(s)...`, 'info');
            
            const syncResults = [];
            
            for (const { studentId, currentGroup, originalGroup } of studentsToSync) {
                try {
                    // If student was in a group, remove them from it
                    if (originalGroup) {
                        const originalGroupObj = accommodationGroups.find(g => g.name === originalGroup);
                        if (originalGroupObj) {
                            debugLog(`Removing student ${studentId} from group "${originalGroup}" (ID: ${originalGroupObj.id})`, 'info');
                            
                            const removeResponse = await fetch(`/canvas/groups/${originalGroupObj.id}/users/${studentId}`, {
                                method: 'DELETE',
                                headers: { 'Content-Type': 'application/json' }
                            });
                            
                            if (!removeResponse.ok) {
                                const errorText = await removeResponse.text();
                                throw new Error(`Failed to remove student from group "${originalGroup}": ${removeResponse.status} - ${errorText}`);
                            }
                            
                            debugLog(`Successfully removed student ${studentId} from group "${originalGroup}"`, 'success');
                        }
                    }
                    
                    // If student should be in a new group, add them to it
                    if (currentGroup) {
                        const currentGroupObj = accommodationGroups.find(g => g.name === currentGroup);
                        if (currentGroupObj) {
                            debugLog(`Adding student ${studentId} to group "${currentGroup}" (ID: ${currentGroupObj.id})`, 'info');
                            
                            const addResponse = await fetch(`/canvas/groups/${currentGroupObj.id}/memberships`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ user_id: studentId })
                            });
                            
                            if (!addResponse.ok) {
                                const errorText = await addResponse.text();
                                throw new Error(`Failed to add student to group "${currentGroup}": ${addResponse.status} - ${errorText}`);
                            }
                            
                            debugLog(`Successfully added student ${studentId} to group "${currentGroup}"`, 'success');
                        } else {
                            throw new Error(`Group "${currentGroup}" not found in accommodationGroups`);
                        }
                    }
                    
                    // Update original accommodations to match current (so we don't re-sync)
                    originalAccommodations[String(studentId)] = currentGroup ? [currentGroup] : [];
                    
                    syncResults.push({ studentId, success: true });
                } catch (error) {
                    debugLog(`Failed to sync accommodations for student ${studentId}: ${error.message}`, 'error');
                    syncResults.push({ studentId, success: false, error: error.message });
                }
            }
            
            const successCount = syncResults.filter(r => r.success).length;
            const failCount = syncResults.filter(r => !r.success).length;
            
            debugLog(`Accommodation sync complete: ${successCount} succeeded, ${failCount} failed`, successCount > 0 ? 'success' : 'error');
            
            if (failCount > 0) {
                const failedStudents = syncResults.filter(r => !r.success);
                debugLog(`Failed students: ${JSON.stringify(failedStudents)}`, 'error');
                throw new Error(`Accommodation sync completed with ${failCount} error(s). Check debug log for details.`);
            }
            
            // Return the count of successfully synced accommodations
            return successCount;
        }

