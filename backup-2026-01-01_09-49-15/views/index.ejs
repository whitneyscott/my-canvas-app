            } else if (fieldType === 'boolean' && fieldName === 'front_page') {
                // Use toggle button for front_page with mutual exclusivity
                const isFrontPage = value === true || value === 'true' || value === 1;
                cell.innerHTML = `
                    <button class="toggle-btn ${isFrontPage ? 'active' : 'inactive'}" 
                            onclick="toggleFrontPage('${tabName}', '${itemId}', ${!isFrontPage}); event.stopPropagation();"
                            title="Click to ${isFrontPage ? 'remove from' : 'set as'} front page">
                        ${isFrontPage ? 'Yes' : 'No'}
                    </button>
                `;
            } else if (fieldType === 'boolean') {
                // Use toggle button for other boolean fields
                const isActive = value === true || value === 'true' || value === 1;
                cell.innerHTML = `
                    <button class="toggle-btn ${isActive ? 'active' : 'inactive'}" 
                            onclick="toggleBooleanField('${tabName}', '${itemId}', '${fieldName}', ${!isActive})"
                            title="Click to toggle">
                        ${isActive ? 'Yes' : 'No'}
                    </button>
                `;
            } else if (fieldType === 'select') {
                // Handle prerequisite_module_ids - show module names
                if (fieldName === 'prerequisite_module_ids' && tabName === 'modules') {
                    if (Array.isArray(value) && value.length > 0) {
                        const names = value.map(prereqId => {
                            const prereqModule = courseModules.find(m => m.id === prereqId || String(m.id) === String(prereqId));
                            return prereqModule ? prereqModule.name : `Module ${prereqId}`;
                        });
                        cell.textContent = names.join(', ');
                    } else {
                        cell.textContent = '-';
                    }
                } else if (fieldName === 'assignment_group_id' && fieldDef && fieldDef.dynamicOptions) {
                    // Handle dynamic options for assignment_group_id
                    const group = assignmentGroups.find(g => g.id === value || String(g.id) === String(value));
                    cell.textContent = group ? group.name : (value || '-');
                } else if (fieldDef && fieldDef.options) {
                    // Display select field value using label from options
                    const option = fieldDef.options.find(opt => opt.value === value || String(opt.value) === String(value));
                    cell.textContent = option ? option.label : (value || '-');
                } else {
                    cell.textContent = value || '-';
                }
            } else if (fieldType === 'datetime' || (fieldName.endsWith('_at') && !fieldName.includes('attempts')) || fieldName.includes('date')) {
                cell.textContent = value ? formatDateForDisplay(value) : '-';
            } else if (fieldName === 'allowed_attempts' && (value === -1 || value === '-1' || String(value) === '-1')) {
                // Special handling for allowed_attempts: -1 means unlimited
                cell.textContent = 'Unlimited';
                cell.title = 'Unlimited attempts (-1)';
            } else {
                cell.textContent = value || '-';
            }
        }
        
        function getStateButtonClass(state) {
            if (!state) return 'other';
            const stateLower = state.toLowerCase();
            if (stateLower === 'active') return 'active';
            if (stateLower === 'invited' || stateLower === 'creation_pending') return 'pending';
            if (stateLower === 'deleted' || stateLower === 'rejected' || stateLower === 'inactive') return 'inactive';
            return 'other';
        }
        
        function toggleEnrollmentState(tabName, itemId, currentState) {
            // For now, just show an alert - enrollment state changes might need special handling
            alert(`Enrollment state toggle for ${itemId}: ${currentState}\n\nNote: Enrollment state changes may require special Canvas API endpoints.`);
        }
        
        function togglePublished(tabName, itemId, newValue) {
            const original = originalData[tabName]?.[itemId];
            if (!original) return;
            
            const oldValue = original.published;
            
            // Track the change
            if (!changes[tabName]) changes[tabName] = {};
            if (!changes[tabName][itemId]) changes[tabName][itemId] = {};
            changes[tabName][itemId]['published'] = newValue;
            
            // Update the display
            const cell = document.querySelector(`#tab-${tabName} [data-item-id="${itemId}"][data-field="published"]`);
            if (cell) {
                displayCellValue(cell, tabName, itemId, 'published', newValue, 'boolean');
                const row = cell.closest('tr');
                if (row) {
                    if (JSON.stringify(newValue) !== JSON.stringify(oldValue)) {
                        row.classList.add('modified');
                    } else {
                        row.classList.remove('modified');
                    }
                }
            }
            
            updateSyncButton(tabName);
        }
        
        function toggleBooleanField(tabName, itemId, fieldName, newValue) {
            const original = originalData[tabName]?.[itemId];
            if (!original) return;
            
            const oldValue = original[fieldName];
            
            // Track the change
            if (!changes[tabName]) changes[tabName] = {};
            if (!changes[tabName][itemId]) changes[tabName][itemId] = {};
            changes[tabName][itemId][fieldName] = newValue;
            
            // Update the display
            const cell = document.querySelector(`#tab-${tabName} [data-item-id="${itemId}"][data-field="${fieldName}"]`);
            if (cell) {
                // Get field type from FIELD_DEFINITIONS
                const fieldDefs = FIELD_DEFINITIONS[tabName];
                const fieldDef = fieldDefs ? fieldDefs.find(f => f.key === fieldName) : null;
                const fieldType = fieldDef ? fieldDef.type : 'boolean';
                
                displayCellValue(cell, tabName, itemId, fieldName, newValue, fieldType);
                const row = cell.closest('tr');
                if (row) {
                    if (JSON.stringify(newValue) !== JSON.stringify(oldValue)) {
                        row.classList.add('modified');
                    } else {
                        row.classList.remove('modified');
                    }
                }
            }
            
            updateSyncButton(tabName);
        }
        
        function toggleFrontPage(tabName, itemId, newValue) {
            // If setting to true, first set all other pages to false
            if (newValue === true) {
                const allPages = originalData[tabName] || {};
                Object.keys(allPages).forEach(otherItemId => {
                    if (otherItemId !== itemId) {
                        const otherPage = allPages[otherItemId];
                        if (otherPage && otherPage.front_page === true) {
                            // Track the change for other pages
                            if (!changes[tabName]) changes[tabName] = {};
                            if (!changes[tabName][otherItemId]) changes[tabName][otherItemId] = {};
                            changes[tabName][otherItemId]['front_page'] = false;
                            
                            // Update the display for other pages
                            const otherCell = document.querySelector(`#tab-${tabName} [data-item-id="${otherItemId}"][data-field="front_page"]`);
                            if (otherCell) {
                                displayCellValue(otherCell, tabName, otherItemId, 'front_page', false, 'boolean');
                                const otherRow = otherCell.closest('tr');
                                if (otherRow) otherRow.classList.add('modified');
                            }
                            
                            // Update original data
                            if (originalData[tabName] && originalData[tabName][otherItemId]) {
                                originalData[tabName][otherItemId].front_page = false;
                            }
                        }
                    }
                });
            }
            
            // Now handle the clicked page
            const original = originalData[tabName]?.[itemId];
            if (!original) return;
            
            const oldValue = original.front_page;
            
            // Track the change
            if (!changes[tabName]) changes[tabName] = {};
            if (!changes[tabName][itemId]) changes[tabName][itemId] = {};
            changes[tabName][itemId]['front_page'] = newValue;
            
            // Update the display
            const cell = document.querySelector(`#tab-${tabName} [data-item-id="${itemId}"][data-field="front_page"]`);
            if (cell) {
                displayCellValue(cell, tabName, itemId, 'front_page', newValue, 'boolean');
                const row = cell.closest('tr');
                if (row) {
                    if (JSON.stringify(newValue) !== JSON.stringify(oldValue)) {
                        row.classList.add('modified');
                    } else {
                        row.classList.remove('modified');
                    }
                }
            }
            
            // Update original data
            if (originalData[tabName] && originalData[tabName][itemId]) {
                originalData[tabName][itemId].front_page = newValue;
            }
            
            updateSyncButton(tabName);
        }

        function trackChange(tabName, itemId, fieldName, newValue, oldValue) {
            if (!changes[tabName]) {
                changes[tabName] = {};
            }
            if (!changes[tabName][itemId]) {
                changes[tabName][itemId] = {};
            }
            
            changes[tabName][itemId][fieldName] = newValue;
            
            debugLog(`Change tracked: ${tabName}[${itemId}].${fieldName} = ${newValue}`, 'info');
            
            const row = document.querySelector(`[data-item-id="${itemId}"]`)?.closest('tr');
            if (row) {
                row.classList.add('modified');
            }
            
            updateSyncButton(tabName);
        }

        function updateSyncButton(tabName) {
            const syncBtn = document.getElementById(`sync-${tabName}`);
            const changesCount = document.getElementById(`changesCount-${tabName}`);
            
            if (!syncBtn) return;
            
            const changeCount = Object.keys(changes[tabName] || {}).length;
            
            if (changeCount > 0) {
                syncBtn.disabled = false;
                syncBtn.classList.add('has-changes');
                if (changesCount) {
                    changesCount.textContent = changeCount;
                    changesCount.classList.remove('hidden');
                }
            } else {
                syncBtn.disabled = true;
                syncBtn.classList.remove('has-changes');
                if (changesCount) {
                    changesCount.classList.add('hidden');
                }
            }
        }

        async function syncChanges(tabName) {
            debugLog(`=== ATTEMPTING TO SYNC TO CANVAS ===`, 'info');
            debugLog(`Tab: ${tabName}`, 'info');
            debugLog(`Course ID: ${currentCourseId}`, 'info');
            
            if (!currentCourseId) {
                debugLog(`ERROR: No course selected for sync`, 'error');
                alert('No course selected');
                return;
            }
            
            const tabChanges = changes[tabName];
            if (!tabChanges || Object.keys(tabChanges).length === 0) {
                debugLog(`No changes to sync for ${tabName}`, 'warn');
                alert('No changes to sync');
                return;
            }
            
            const syncBtn = document.getElementById(`sync-${tabName}`);
            if (syncBtn) {
                syncBtn.disabled = true;
                syncBtn.textContent = 'Syncing...';
            }
            
            const changeCount = Object.keys(tabChanges).length;
            debugLog(`Syncing ${changeCount} changed item(s) for ${tabName}...`, 'info');
            debugLog(`Changes to sync: ${JSON.stringify(tabChanges, null, 2)}`, 'info');
            
            try {
                let accommodationSyncCount = 0;
                let accommodationSyncFailed = false;
                
                // Handle accommodations separately for students tab
                if (tabName === 'students' && tabChanges['__accommodations']) {
                    try {
                        const syncResult = await syncAccommodations();
                        accommodationSyncCount = syncResult || 0;
                        // Reload accommodations to get fresh state from Canvas
                        await loadAccommodations(currentCourseId);
                        // Remove the marker from changes
                        delete tabChanges['__accommodations'];
                    } catch (error) {
                        debugLog(`Accommodation sync failed: ${error.message}`, 'error');
                        accommodationSyncFailed = true;
                        throw error; // Re-throw to be caught by outer try-catch
                    }
                }
                
                const updatePromises = Object.keys(tabChanges).filter(itemId => itemId !== '__accommodations').map(async (itemId) => {
                    const itemChanges = tabChanges[itemId];
                    let id = itemId;
                    
                    if (tabName === 'pages') {
                        id = itemId;
                    } else {
                        id = parseInt(itemId);
                    }
                    
                    debugLog(`Updating ${tabName} ${id} with changes: ${JSON.stringify(itemChanges)}`, 'info');
                    
                    // Special handling for quiz due_at: route to assignment endpoint
                    // ALL classic quizzes have assignment_id, so due_at must go to assignment endpoint
                    // This includes when due_at is null (to delete the due date)
                    if (tabName === 'quizzes' && itemChanges.due_at !== undefined) {
                        const originalQuiz = originalData['quizzes'] && originalData['quizzes'][itemId];
                        if (!originalQuiz) {
                            debugLog(`ERROR: Cannot find original quiz data for quiz ${id}`, 'error');
                            throw new Error(`Cannot find original quiz data for quiz ${id}`);
                        }
                        
                        const quizAssignmentId = originalQuiz.assignment_id;
                        if (!quizAssignmentId) {
                            debugLog(`ERROR: Quiz ${id} does not have assignment_id (this should not happen for classic quizzes)`, 'error');
                            throw new Error(`Quiz ${id} does not have assignment_id`);
                        }
                        
                        const dueAtChange = itemChanges.due_at;
                        const quizChangesWithoutDueAt = { ...itemChanges };
                        delete quizChangesWithoutDueAt.due_at;
                        
                        debugLog(`Quiz ${id} has assignment_id ${quizAssignmentId}, routing due_at to assignment endpoint`, 'info');
                        
                        let quizData = null;
                        
                        // Update quiz with other fields (if any)
                        if (Object.keys(quizChangesWithoutDueAt).length > 0) {
                            const endpoint = `/canvas/courses/${currentCourseId}/${tabName}/${id}`;
                            debugLog(`=== REQUEST (Quiz Update - Other Fields) ===`, 'info');
                            debugLog(`URL: ${endpoint}`, 'info');
                            debugLog(`Request body: ${JSON.stringify(quizChangesWithoutDueAt, null, 2)}`, 'info');
                            
                            const quizResponse = await fetch(endpoint, {
                                method: 'PUT',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(quizChangesWithoutDueAt),
                            });
                            
                            const quizResponseText = await quizResponse.text();
                            debugLog(`=== RESPONSE (Quiz Update) ===`, quizResponse.ok ? 'success' : 'error');
                            debugLog(`Status: ${quizResponse.status}`, quizResponse.ok ? 'success' : 'error');
                            debugLog(`Body: ${quizResponseText}`, 'info');
                            
                            if (!quizResponse.ok) {
                                throw new Error(`Failed to update quiz ${id}: ${quizResponse.status} - ${quizResponseText}`);
                            }
                            
                            try {
                                quizData = JSON.parse(quizResponseText);
                            } catch (e) {
                                debugLog(`Failed to parse quiz response: ${e.message}`, 'warn');
                            }
                        }
                        
                        // Update assignment with due_at
                        const assignmentEndpoint = `/canvas/courses/${currentCourseId}/assignments/${quizAssignmentId}`;
                        const assignmentBody = { due_at: dueAtChange };
                        
                        debugLog(`=== REQUEST (Assignment Due Date) ===`, 'info');
                        debugLog(`URL: ${assignmentEndpoint}`, 'info');
                        debugLog(`Request body: ${JSON.stringify(assignmentBody, null, 2)}`, 'info');
                        
                        const assignmentResponse = await fetch(assignmentEndpoint, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(assignmentBody),
                        });
                        
                        const assignmentResponseText = await assignmentResponse.text();
                        debugLog(`=== RESPONSE (Assignment Due Date) ===`, assignmentResponse.ok ? 'success' : 'error');
                        debugLog(`Status: ${assignmentResponse.status}`, assignmentResponse.ok ? 'success' : 'error');
                        debugLog(`Body: ${assignmentResponseText}`, 'info');
                        
                        if (!assignmentResponse.ok) {
                            throw new Error(`Failed to update assignment ${quizAssignmentId}: ${assignmentResponse.status} - ${assignmentResponseText}`);
                        }
                        
                        let assignmentData = null;
                        try {
                            assignmentData = JSON.parse(assignmentResponseText);
                        } catch (e) {
                            debugLog(`Failed to parse assignment response: ${e.message}`, 'warn');
                        }
                        
                        return { id, success: true, data: assignmentData || quizData };
                    }
                    
                    const urlId = tabName === 'pages' ? encodeURIComponent(id) : id;
                    const endpoint = `/canvas/courses/${currentCourseId}/${tabName}/${urlId}`;
                    
                    debugLog(`=== REQUEST ===`, 'info');
                    debugLog(`URL: ${endpoint}`, 'info');
                    debugLog(`Method: PUT`, 'info');
                    debugLog(`Request body: ${JSON.stringify(itemChanges, null, 2)}`, 'info');
                    
                    const response = await fetch(endpoint, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(itemChanges),
                    });
                    
                    const responseText = await response.text();
                    debugLog(`=== RESPONSE ===`, response.ok ? 'success' : 'error');
                    debugLog(`Status: ${response.status}`, response.ok ? 'success' : 'error');
                    debugLog(`Body: ${responseText}`, 'info');
                    
                    if (!response.ok) {
                        throw new Error(`Failed to update ${tabName} ${id}: ${response.status} - ${responseText}`);
                    }
                    
                    let data = null;
                    try {
                        data = JSON.parse(responseText);
                    } catch (e) {
                        debugLog(`Failed to parse response: ${e.message}`, 'warn');
                    }
                    
                    debugLog(`Successfully updated ${tabName} ${id}`, 'success');
                    return { id, success: true, data };
                });
                
                const results = await Promise.allSettled(updatePromises);
                const processedResults = results.map((result, index) => {
                    if (result.status === 'fulfilled') {
                        return result.value;
                    } else {
                        const itemId = Object.keys(tabChanges)[index];
                        const errorMsg = result.reason?.message || 'Unknown error';
                        debugLog(`Update failed for item ${itemId}: ${errorMsg}`, 'error');
                        return { id: itemId, success: false, error: errorMsg };
                    }
                });
                
                const successCount = processedResults.filter(r => r.success).length;
                const failCount = processedResults.filter(r => !r.success).length;
                
                // Include accommodation sync in totals
                const totalSuccessCount = successCount + accommodationSyncCount;
                const totalFailCount = failCount + (accommodationSyncFailed ? 1 : 0);
                
                debugLog(`Sync complete: ${totalSuccessCount} succeeded (${successCount} items + ${accommodationSyncCount} accommodations), ${totalFailCount} failed`, totalSuccessCount > 0 ? 'success' : 'error');
                
                if (totalFailCount > 0) {
                    const failedItems = processedResults.filter(r => !r.success);
                    debugLog(`Failed items: ${JSON.stringify(failedItems)}`, 'error');
                    let errorMsg = `Sync completed with ${totalFailCount} error(s). Check debug log for details.`;
                    if (accommodationSyncFailed) {
                        errorMsg += '\n\nAccommodation sync failed.';
                    }
                    alert(errorMsg);
                } else {
                    let successMsg = `Successfully synced ${totalSuccessCount} item(s) to Canvas!`;
                    if (accommodationSyncCount > 0 && successCount > 0) {
                        successMsg = `Successfully synced ${successCount} item(s) and ${accommodationSyncCount} accommodation(s) to Canvas!`;
                    } else if (accommodationSyncCount > 0) {
                        successMsg = `Successfully synced ${accommodationSyncCount} accommodation(s) to Canvas!`;
                    }
                    alert(successMsg);
                }
                
                changes[tabName] = {};
                updateSyncButton(tabName);
                
                document.querySelectorAll(`#tab-${tabName} tr.modified`).forEach(row => {
                    row.classList.remove('modified');
                });
                
                if (syncBtn) {
                    syncBtn.textContent = '💾 Sync to Canvas';
                }
                
                // Refresh the tab to show updated data
                await refreshTab(tabName);
            } catch (error) {
                debugLog(`Sync error: ${error.message}`, 'error');
                alert(`Sync failed: ${error.message}`);
                if (syncBtn) {
                    syncBtn.disabled = false;
                    syncBtn.textContent = '💾 Sync to Canvas';
                }
            }
        }

        // Test function for fetching group categories and their groups
        async function testGroupFetch(courseId) {
            try {
                console.log('Starting test fetch for Course:', courseId);
                
                // First fetch: Get all group categories
                const categoriesResponse = await fetch(`/canvas/courses/${courseId}/group_categories`);
                if (!categoriesResponse.ok) {
                    const errorText = await categoriesResponse.text();
                    throw new Error(`HTTP ${categoriesResponse.status}: ${errorText}`);
                }
                const categories = await categoriesResponse.json();
                console.log('Group Categories Found:', categories);
                
                // Find the 'Accommodations' category
                const accommodationsCategory = categories.find((cat) => cat.name === 'Accommodations');
                
                if (!accommodationsCategory) {
                    console.log('Accommodations category not found');
                    return { categories, accommodationsCategory: null, groups: null, users: null };
                }
                
                console.log('Found Accommodations category with ID:', accommodationsCategory.id);
                
                // Second fetch: Get groups within the Accommodations category
                const groupsResponse = await fetch(`/canvas/group_categories/${accommodationsCategory.id}/groups`);
                if (!groupsResponse.ok) {
                    const errorText = await groupsResponse.text();
                    throw new Error(`HTTP ${groupsResponse.status}: ${errorText}`);
                }
                const groups = await groupsResponse.json();
                console.log('Groups in Accommodations category:', groups);
                console.log('Looking for groups: Time 1.25x, Time 1.5x, Time 2.0x, Extra Attempt');
                
                // Check for expected groups
                const expectedGroups = ['Time 1.25x', 'Time 1.5x', 'Time 2.0x', 'Extra Attempt'];
                const foundGroups = groups.filter((g) => expectedGroups.includes(g.name));
                console.log('Found expected groups:', foundGroups.map((g) => g.name));
                
                // Create a map of group ID to group name for easy lookup
                const groupIdToName = new Map();
                foundGroups.forEach(group => {
                    groupIdToName.set(String(group.id), group.name);
                });
                
                // Third fetch: Use the definitive 'Users in Group' endpoint
                // Pick a group we know exists (e.g., 'Extra Attempt')
                const extraAttemptGroup = foundGroups.find((g) => g.name === 'Extra Attempt');
                if (extraAttemptGroup) {
                    console.log(`\n=== Using 'Users in Group' Endpoint (Definitive) ===`);
                    console.log(`Fetching users for group: "${extraAttemptGroup.name}" (ID: ${extraAttemptGroup.id})`);
                    console.log(`Endpoint: /canvas/groups/${extraAttemptGroup.id}/users?per_page=100`);
                    console.log(`Note: This is /users, not /memberships`);
                    
                    try {
                        const groupUsersResponse = await fetch(`/canvas/groups/${extraAttemptGroup.id}/users?per_page=100`);
                        if (!groupUsersResponse.ok) {
                            const errorText = await groupUsersResponse.text();
                            console.error(`Failed to fetch users in group: HTTP ${groupUsersResponse.status}: ${errorText}`);
                        } else {
                            const groupUsers = await groupUsersResponse.json();
                            console.log(`\n✅ SUCCESS! Found ${groupUsers.length} user(s) in group "${extraAttemptGroup.name}":`);
                            console.log('Raw result:', groupUsers);
                            
                            if (groupUsers.length > 0) {
                                console.log('\n=== Users in Group (Names) ===');
                                groupUsers.forEach((user, index) => {
                                    console.log(`${index + 1}. ${user.name || 'Unknown'} (ID: ${user.id})`);
                                });
                                console.log('\n✅ DEFINITIVE: This endpoint returns the actual list of users!');
                            } else {
                                console.log('⚠️  Group exists but has no users');
                            }
                        }
                    } catch (error) {
                        console.error('Error fetching users in group:', error);
                    }
                } else {
                    console.log('⚠️  "Extra Attempt" group not found, cannot test Users in Group endpoint');
                }
                
                // Fourth fetch: Get course users with group_ids (most reliable course-level fetch)
                console.log('\n=== Fetching Course Users with group_ids ===');
                console.log(`Endpoint: /canvas/courses/${courseId}/users?include[]=group_ids&per_page=100`);
                const usersResponse = await fetch(`/canvas/courses/${courseId}/users?include[]=group_ids&per_page=100`);
                if (!usersResponse.ok) {
                    const errorText = await usersResponse.text();
                    throw new Error(`Failed to fetch users: HTTP ${usersResponse.status}: ${errorText}`);
                }
                const students = await usersResponse.json();
                console.log(`Found ${students.length} students`);
                
                // Check first few student objects for group_ids
                console.log('\n=== Checking First Few Student Objects ===');
                const firstFew = students.slice(0, 5);
                firstFew.forEach((student, index) => {
                    console.log(`\nStudent ${index + 1}:`, student);
                    if (student.group_ids && Array.isArray(student.group_ids) && student.group_ids.length > 0) {
                        console.log(`FOUND GROUPS FOR: ${student.name} IDs: ${student.group_ids.join(', ')}`);
                    } else {
                        console.log(`No group_ids found for: ${student.name || 'Unknown'}`);
                    }
                });
                
                // Build roster of students with groups
                const Roster = [];
                students.forEach((student) => {
                    if (student.group_ids && Array.isArray(student.group_ids) && student.group_ids.length > 0) {
                        // Convert group IDs to group names
                        const groupNames = student.group_ids
                            .map(gid => {
                                const gidStr = String(gid);
                                return groupIdToName.get(gidStr) || gidStr;
                            })
                            .filter(name => foundGroups.some(g => g.name === name || String(g.id) === name)) // Only accommodation groups
                            .join(', ');
                        
                        if (groupNames) {
                            console.log(`FOUND GROUPS FOR: ${student.name} IDs: ${student.group_ids.join(', ')}`);
                            Roster.push({
                                'Student ID': student.id,
                                'Name': student.name || 'Unknown',
                                'Group IDs': student.group_ids.join(', '),
                                'Groups': groupNames
                            });
                        }
                    }
                });
                
                // Display using console.table for clean spreadsheet view
                console.log('\n=== Accommodation Roster ===');
                console.log(`Total students with accommodation groups: ${Roster.length}`);
                if (Roster.length > 0) {
                    console.table(Roster);
                    console.log('SUCCESS: Found ' + Roster.length + ' students with accommodations');
                } else {
                    console.log('No students found with accommodation groups.');
                }
                
                return {
                    categories,
                    accommodationsCategory,
                    groups,
                    foundGroups: foundGroups.map((g) => g.name),
                    studentsWithGroups: Roster
                };
            } catch (error) {
                console.error('Test Fetch Failed:', error);
                return null;
            }
        }

        // Handler for the Test API Connection button
        async function handleTestApiConnection() {
            const courseId = getCurrentCourseId();
            if (!courseId) {
                alert('Please select a course first');
                return;
            }
            
            const button = event.target;
            const originalText = button.textContent;
            button.disabled = true;
            button.textContent = 'Testing...';
            
            try {
                const result = await testGroupFetch(courseId);
                if (result) {
                    alert(`Success! Found ${result.length} group categor${result.length !== 1 ? 'ies' : 'y'}. Check console for details.`);
                } else {
                    alert('Test completed but no data returned. Check console for details.');
                }
            } catch (error) {
                alert(`Test failed: ${error.message}. Check console for details.`);
            } finally {
                button.disabled = false;
                button.textContent = originalText;
            }
        }

        // Make test function available globally for console testing
        window.testGroupFetch = testGroupFetch;
    </script>
</body>
