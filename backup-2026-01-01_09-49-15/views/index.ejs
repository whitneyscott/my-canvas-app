        function updateDrawerContent() {
            const selected = getSelectedItems();
            const emptyState = document.getElementById('drawerEmptyState');
            const editMode = document.getElementById('drawerEditMode');
            const dropdown = document.getElementById('editModeDropdown');
            
            if (selected.length === 0) {
                if (emptyState) emptyState.classList.remove('hidden');
                if (editMode) editMode.classList.add('hidden');
                if (dropdown) dropdown.value = '';
            } else {
                if (emptyState) emptyState.classList.add('hidden');
                if (editMode) editMode.classList.remove('hidden');
            }
        }

        function handleEditModeChange() {
            const dropdown = document.getElementById('editModeDropdown');
            if (!dropdown) return;
            
            const value = dropdown.value;
            
            // Reset dropdown after a short delay to allow modal to open
            setTimeout(() => {
                dropdown.value = '';
            }, 100);
            
            if (value === 'dateShift') {
                openDateShiftModal();
            } else if (value === 'publishStatus') {
                openPublishStatusModal();
            } else if (value === 'searchReplace') {
                openSearchReplaceModal();
            }
        }

