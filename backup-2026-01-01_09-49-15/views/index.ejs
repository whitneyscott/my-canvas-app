                displayCellValue(publishedCell, 'pages', itemId, 'published', page.published, 'boolean');
                displayCellValue(frontPageCell, 'pages', itemId, 'front_page', page.front_page, 'boolean');
                displayCellValue(editingRolesCell, 'pages', itemId, 'editing_roles', page.editing_roles, 'text');
