        // Store pending duplication info
        let pendingDuplication = null;
        let pendingModuleClone = null;

        // Helper function to generate incremented name/title
        function generateIncrementedName(originalName, tabName, copyIndex = 1, pendingItems = []) {
            // Extract base name from original name (e.g., "Assignment 1" -> "Assignment", "Lab" -> "Lab")
            // Match pattern: text followed by space(s) followed by number at the end
            const match = originalName.match(/(.+?)\s+(\d+)$/);
            let baseName;
            if (match) {
                baseName = match[1].trim();
            } else {
                baseName = originalName.trim();
            }
            
            // Get all existing items of this type to find the highest number
            // Check both originalData (current state) and pendingItems (items being created in this batch)
            const existingItems = originalData[tabName] || {};
            const nameField = getNameFieldName(tabName);
            let highestNumber = 0;
            
            // Check if base name matches any existing items (with or without numbers)
            const baseNameLower = baseName.toLowerCase();
            const baseNameEscaped = baseName.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            const baseNamePattern = new RegExp(`^${baseNameEscaped}\\s+(\\d+)$`, 'i');
            
            // Helper function to check an item's name
            const checkItemName = (item) => {
                const itemName = (item[nameField] || item.title || item.name || '').trim();
                if (!itemName) return;
                
                const itemNameLower = itemName.toLowerCase();
                
                // Check for exact match (base name with no number)
                if (itemNameLower === baseNameLower) {
                    highestNumber = Math.max(highestNumber, 0);
                }
                // Check for "BaseName Number" format
                else if (itemNameLower.startsWith(baseNameLower + ' ')) {
                    const itemMatch = itemName.match(baseNamePattern);
                    if (itemMatch) {
                        const itemNum = parseInt(itemMatch[1], 10);
                        if (!isNaN(itemNum) && itemNum > highestNumber) {
                            highestNumber = itemNum;
                        }
                    }
                }
            };
            
            // Check existing items in originalData (current state)
            Object.values(existingItems).forEach(checkItemName);
            
            // Check pending items (items being created in this batch)
            pendingItems.forEach(checkItemName);
            
            // Return base name with next available number
            return `${baseName} ${highestNumber + copyIndex}`;
        }

        // Helper function to sanitize item data (remove forbidden keys)
        function sanitizeItemForDuplication(item) {
            const forbiddenKeys = ['id', 'created_at', 'updated_at', 'html_url', 'url', 'assignment_id', 'quiz_id', 'workflow_state'];
            const sanitized = { ...item };
            
            forbiddenKeys.forEach(key => {
                delete sanitized[key];
            });
            
            return sanitized;
        }

        // Helper function to get the name/title field name for a tab
        function getNameFieldName(tabName) {
            const nameFieldMap = {
                'assignments': 'name',
                'quizzes': 'title',
                'discussions': 'title',
                'pages': 'title',
                'announcements': 'title',
                'modules': 'name'
            };
            return nameFieldMap[tabName] || 'name';
        }

        // Helper function to get Canvas endpoint for a specific item (for GET/DELETE operations)
        function getCanvasItemEndpoint(tabName, itemId) {
            const courseId = getCurrentCourseId();
            if (!courseId) {
                throw new Error('No course selected');
            }
            
            // For pages, use URL encoding
            if (tabName === 'pages') {
                return `/canvas/courses/${courseId}/pages/${encodeURIComponent(itemId)}`;
            }
            
            const endpointMap = {
                'assignments': `/canvas/courses/${courseId}/assignments/${itemId}`,
                'quizzes': `/canvas/courses/${courseId}/quizzes/${itemId}`,
                'discussions': `/canvas/courses/${courseId}/discussions/${itemId}`,
                'announcements': `/canvas/courses/${courseId}/announcements/${itemId}`,
                'modules': `/canvas/courses/${courseId}/modules/${itemId}`
            };
            
            const endpoint = endpointMap[tabName];
            if (!endpoint) {
                throw new Error(`Operation not supported for tab: ${tabName}`);
            }
            
            return endpoint;
        }

        // Helper function to get Canvas POST endpoint
        function getCanvasCreateEndpoint(tabName) {
            const courseId = getCurrentCourseId();
            if (!courseId) {
                throw new Error('No course selected');
            }
            
            const endpointMap = {
                'assignments': `/canvas/courses/${courseId}/assignments`,
                'quizzes': `/canvas/courses/${courseId}/quizzes`,
                'discussions': `/canvas/courses/${courseId}/discussions`,
                'pages': `/canvas/courses/${courseId}/pages`,
                'announcements': `/canvas/courses/${courseId}/announcements`,
                'modules': `/canvas/courses/${courseId}/modules`
            };
            
            const endpoint = endpointMap[tabName];
            if (!endpoint) {
                throw new Error(`Duplicate not supported for tab: ${tabName}`);
            }
            
            return endpoint;
        }

