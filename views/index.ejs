        // Helper function: Determine if a field should have a filter
        function shouldAddFilter(tabName, field) {
            // Add search filter for title/name fields
            if (field.key === 'title' || field.key === 'name') {
                return true;
            }
            // Add dropdown filter for fields with limited values
            if (field.key === 'quiz_type' || field.key === 'discussion_type' || field.key === 'submission_types') {
                return true;
            }
            return false;
        }
        
        // Helper function: Create filter menu
        function createFilterMenu(tabName, field) {
            // Get the field key (either field.key for FIELD_DEFINITIONS or field.field for CUSTOM_HEADER_FIELDS)
            const fieldKey = field.field || field.key;
            if (!fieldKey) return null; // No field key, can't filter/sort
            
            const menu = document.createElement('div');
            menu.className = 'filter-menu';
            menu.id = `filter-menu-${tabName}-${fieldKey}`;
            
            // Sort section
            const sortSection = document.createElement('div');
            sortSection.className = 'filter-menu-section';
            sortSection.innerHTML = '<h4>Sort</h4>';
            
            const sortAscBtn = document.createElement('button');
            sortAscBtn.className = 'filter-menu-btn';
            sortAscBtn.textContent = 'Sort A → Z';
            sortAscBtn.onclick = () => {
                setSort(tabName, fieldKey, 'asc');
                closeFilterMenu(tabName, fieldKey);
            };
            sortSection.appendChild(sortAscBtn);
            
            const sortDescBtn = document.createElement('button');
            sortDescBtn.className = 'filter-menu-btn';
            sortDescBtn.textContent = 'Sort Z → A';
            sortDescBtn.onclick = () => {
                setSort(tabName, fieldKey, 'desc');
                closeFilterMenu(tabName, fieldKey);
            };
            sortSection.appendChild(sortDescBtn);
            
            const clearSortBtn = document.createElement('button');
            clearSortBtn.className = 'filter-menu-btn';
            clearSortBtn.textContent = 'Clear Sort';
            clearSortBtn.onclick = () => {
                setSort(tabName, fieldKey, null);
                closeFilterMenu(tabName, fieldKey);
            };
            sortSection.appendChild(clearSortBtn);
            
            menu.appendChild(sortSection);
            
            // Filter section
            const filterSection = document.createElement('div');
            filterSection.className = 'filter-menu-section';
            
            const filterButton = document.createElement('button');
            filterButton.className = 'filter-menu-btn';
            filterButton.style.cursor = 'pointer';
            filterButton.textContent = 'Filter';
            filterButton.onclick = () => {
                openAdvancedFilterModal(tabName, fieldKey);
                    closeFilterMenu(tabName, fieldKey);
                };
            filterSection.appendChild(filterButton);
            
            menu.appendChild(filterSection);
            
            const clearFiltersSection = document.createElement('div');
            clearFiltersSection.className = 'filter-menu-section';
            
            const clearFiltersBtn = document.createElement('button');
            clearFiltersBtn.className = 'filter-menu-btn';
            clearFiltersBtn.style.cursor = 'pointer';
            clearFiltersBtn.textContent = 'Clear Column Filters';
            clearFiltersBtn.onclick = () => {
                const menuElement = document.getElementById(`filter-menu-${tabName}-${fieldKey}`);
                if (menuElement) {
                    const th = menuElement.closest('th');
                    if (th) {
                        const table = th.closest('table');
                        if (table) {
                            const thead = table.querySelector('thead');
                            if (thead) {
                                const headers = Array.from(thead.querySelectorAll('th'));
                                const columnIndex = headers.indexOf(th);
                                if (columnIndex !== -1) {
                                    clearColumnFilters(columnIndex);
                                }
                            }
                        }
                    }
                }
                    closeFilterMenu(tabName, fieldKey);
                };
            clearFiltersSection.appendChild(clearFiltersBtn);
            
            menu.appendChild(clearFiltersSection);
            
            return menu;
        }
        
        // Helper function: Toggle filter menu
        function toggleFilterMenu(tabName, field, icon) {
            // Get the field key (either field.key for FIELD_DEFINITIONS or field.field for CUSTOM_HEADER_FIELDS)
            const fieldKey = field.field || field.key;
            if (!fieldKey) return;
            
            const menuId = `filter-menu-${tabName}-${fieldKey}`;
            const menu = document.getElementById(menuId);
            if (!menu) return;
            
            // Close all other menus
            document.querySelectorAll('.filter-menu').forEach(m => {
                if (m.id !== menuId) {
                    m.classList.remove('active');
                }
            });
            
            // Toggle this menu
            const isOpening = !menu.classList.contains('active');
            menu.classList.toggle('active');
            
            // Position the menu if opening
            if (isOpening && menu.classList.contains('active')) {
                const iconRect = icon.getBoundingClientRect();
                const menuWidth = 200; // min-width from CSS
                
                // Position below the icon, aligned to left edge
                let left = iconRect.left;
                let top = iconRect.bottom + 4;
                
                // Adjust if menu would go off right edge of screen
                if (left + menuWidth > window.innerWidth - 10) {
                    left = window.innerWidth - menuWidth - 10;
                }
                
                // Adjust if menu would go off left edge of screen
                if (left < 10) {
                    left = 10;
                }
                
                // Adjust if menu would go off bottom of screen
                if (top + menu.offsetHeight > window.innerHeight - 10) {
                    // Position above the icon instead
                    top = iconRect.top - menu.offsetHeight - 4;
                    if (top < 10) {
                        top = 10;
                    }
                }
                
                menu.style.left = left + 'px';
                menu.style.top = top + 'px';
            }
            
            // Update icon state
            if (menu.classList.contains('active')) {
                icon.classList.add('active');
            } else {
                icon.classList.remove('active');
            }
            
            // Update dropdown options if needed
            if (fieldKey === 'quiz_type' || fieldKey === 'discussion_type' || fieldKey === 'submission_types') {
                updateFilterMenuDropdown(tabName, field);
            }
        }
        
        // Helper function: Close filter menu
        function closeFilterMenu(tabName, fieldKey) {
            const menuId = `filter-menu-${tabName}-${fieldKey}`;
            const menu = document.getElementById(menuId);
            if (menu) {
                menu.classList.remove('active');
            }
            
            const icon = document.querySelector(`.filter-icon[data-field="${fieldKey}"]`);
            if (icon) {
                icon.classList.remove('active');
            }
        }
        
        // Helper function: Update filter menu dropdown options
        function updateFilterMenuDropdown(tabName, field) {
            const selectId = `select-filter-${tabName}-${field.key}`;
            const select = document.getElementById(selectId);
            if (!select) return;
            
            const currentValue = select.value;
            
            const values = field.key === 'submission_types' 
                ? getUniqueSubmissionTypes(tabName)
                : getUniqueValuesForField(tabName, field.key);
            
            select.innerHTML = '';
            const optionAll = document.createElement('option');
            optionAll.value = '';
            optionAll.textContent = 'All';
            select.appendChild(optionAll);
            
            values.forEach(value => {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = value;
                select.appendChild(option);
            });
            
            if (currentValue && values.includes(currentValue)) {
                select.value = currentValue;
            }
        }
        
        // Helper function: Create filter input element (legacy - keeping for compatibility)
        function createFilterInput(tabName, field) {
            const filterId = `filter-${tabName}-${field.key}`;
            
            // Initialize filter state
            if (!filters[tabName]) filters[tabName] = {};
            if (filters[tabName][field.key] === undefined) {
                filters[tabName][field.key] = '';
            }
            
            if (field.key === 'title' || field.key === 'name') {
                // Text search input
                const input = document.createElement('input');
                input.type = 'text';
                input.className = 'header-filter';
                input.id = filterId;
                input.placeholder = `Filter ${field.key}...`;
                input.value = filters[tabName][field.key] || '';
                input.addEventListener('input', (e) => {
                    filters[tabName][field.key] = e.target.value;
                    applyFilters(tabName);
                });
                return input;
            } else if (field.key === 'quiz_type' || field.key === 'discussion_type') {
                // Dropdown filter
                const select = document.createElement('select');
                select.className = 'header-filter';
                select.id = filterId;
                
                // Get unique values from current data
                const options = getUniqueValuesForField(tabName, field.key);
                const optionAll = document.createElement('option');
                optionAll.value = '';
                optionAll.textContent = 'All';
                select.appendChild(optionAll);
                
                options.forEach(value => {
                    const option = document.createElement('option');
                    option.value = value;
                    option.textContent = value;
                    select.appendChild(option);
                });
                
                select.value = filters[tabName][field.key] || '';
                select.addEventListener('change', (e) => {
                    filters[tabName][field.key] = e.target.value;
                    applyFilters(tabName);
                });
                return select;
            } else if (field.key === 'submission_types') {
                // Dropdown for submission types (array field)
                const select = document.createElement('select');
                select.className = 'header-filter';
                select.id = filterId;
                
                const options = getUniqueSubmissionTypes(tabName);
                const optionAll = document.createElement('option');
                optionAll.value = '';
                optionAll.textContent = 'All';
                select.appendChild(optionAll);
                
                options.forEach(value => {
                    const option = document.createElement('option');
                    option.value = value;
                    option.textContent = value;
                    select.appendChild(option);
                });
                
                select.value = filters[tabName][field.key] || '';
                select.addEventListener('change', (e) => {
                    filters[tabName][field.key] = e.target.value;
                    applyFilters(tabName);
                });
                return select;
            }
            
            return null;
        }
        
        // Helper function: Get unique values for a field
        function getUniqueValuesForField(tabName, fieldKey) {
            if (!originalData[tabName]) return [];
            const values = new Set();
            Object.values(originalData[tabName]).forEach(item => {
                const value = item[fieldKey];
                if (value !== null && value !== undefined && value !== '') {
                    values.add(String(value));
                }
            });
            return Array.from(values).sort();
        }
        
        // Helper function: Get unique submission types
        function getUniqueSubmissionTypes(tabName) {
            if (!originalData[tabName]) return [];
            const types = new Set();
            Object.values(originalData[tabName]).forEach(item => {
                if (item.submission_types && Array.isArray(item.submission_types)) {
                    item.submission_types.forEach(type => {
                        if (type) types.add(String(type));
                    });
                }
            });
            return Array.from(types).sort();
        }
        
        // Sorting Functions
        function toggleSort(tabName, fieldKey) {
            if (!sortState[tabName]) {
                sortState[tabName] = { field: null, direction: null };
            }
            
            const currentSort = sortState[tabName];
            
            // Cycle: none -> asc -> desc -> none
            if (currentSort.field !== fieldKey) {
                currentSort.field = fieldKey;
                currentSort.direction = 'asc';
            } else if (currentSort.direction === 'asc') {
                currentSort.direction = 'desc';
            } else if (currentSort.direction === 'desc') {
                currentSort.field = null;
                currentSort.direction = null;
            }
            
            applySortAndFilter(tabName);
            updateSortIndicators(tabName);
        }
        
        function setSort(tabName, fieldKey, direction) {
            if (!sortState[tabName]) {
                sortState[tabName] = { field: null, direction: null };
            }
            
            if (direction === null) {
                sortState[tabName].field = null;
                sortState[tabName].direction = null;
            } else {
                sortState[tabName].field = fieldKey;
                sortState[tabName].direction = direction;
            }
            
            applySortAndFilter(tabName);
            updateSortIndicators(tabName);
        }
        
        function applySortAndFilter(tabName) {
            const tbody = document.querySelector(`#${tabName}Table tbody`);
            if (!tbody) return;
            
            const rows = Array.from(tbody.querySelectorAll('tr'));
            
            // Sort rows if sort is active
            if (sortState[tabName] && sortState[tabName].field && sortState[tabName].direction) {
                const sortField = sortState[tabName].field;
                const sortDirection = sortState[tabName].direction;
                
                rows.sort((a, b) => {
                    const itemIdA = a.querySelector('[data-item-id]')?.getAttribute('data-item-id');
                    const itemIdB = b.querySelector('[data-item-id]')?.getAttribute('data-item-id');
                    
                    if (!itemIdA || !itemIdB) return 0;
                    
                    const itemA = originalData[tabName]?.[itemIdA];
                    const itemB = originalData[tabName]?.[itemIdB];
                    
                    if (!itemA || !itemB) return 0;
                    
                    let valueA = itemA[sortField];
                    let valueB = itemB[sortField];
                    
                    // Handle null/undefined
                    if (valueA === null || valueA === undefined) valueA = '';
                    if (valueB === null || valueB === undefined) valueB = '';
                    
                    // Handle dates
                    if ((sortField.endsWith('_at') && !sortField.includes('attempts')) || sortField.includes('date')) {
                        valueA = valueA ? new Date(valueA).getTime() : 0;
                        valueB = valueB ? new Date(valueB).getTime() : 0;
                    }
                    
                    // Handle arrays
                    if (Array.isArray(valueA)) valueA = valueA.join(', ');
                    if (Array.isArray(valueB)) valueB = valueB.join(', ');
                    
                    // Convert to strings for comparison
                    valueA = String(valueA).toLowerCase();
                    valueB = String(valueB).toLowerCase();
                    
                    let comparison = 0;
                    if (valueA < valueB) comparison = -1;
                    else if (valueA > valueB) comparison = 1;
                    
                    return sortDirection === 'asc' ? comparison : -comparison;
                });
                
                // Re-append sorted rows
                rows.forEach(row => tbody.appendChild(row));
            }
            
            // Apply filters
            applyFilters(tabName);
        }
        
        function updateSortIndicators(tabName) {
            if (!sortState[tabName]) return;
            
            const indicators = document.querySelectorAll(`#${tabName}Table .sort-indicator`);
            indicators.forEach(indicator => {
                const fieldKey = indicator.getAttribute('data-field');
                const currentSort = sortState[tabName];
                
                indicator.classList.remove('active', 'asc', 'desc');
                
                if (currentSort.field === fieldKey && currentSort.direction) {
                    indicator.classList.add('active', currentSort.direction);
                }
            });
        }
        
        // Filter Functions
        function applyDateFilter(tabName, fieldKey) {
            if (!filters[tabName]) filters[tabName] = {};
            
            const fromInput = document.getElementById(`date-filter-from-${tabName}-${fieldKey}`);
            const toInput = document.getElementById(`date-filter-to-${tabName}-${fieldKey}`);
            
            const fromDate = fromInput?.value || null;
            const toDate = toInput?.value || null;
            
            if (fromDate || toDate) {
                filters[tabName][fieldKey] = { type: 'date', from: fromDate, to: toDate };
            } else {
                delete filters[tabName][fieldKey];
            }
            
            applySortAndFilter(tabName);
            updateFilterHeaderStyling(tabName);
        }
        
        function clearDateFilter(tabName, fieldKey) {
            if (filters[tabName]) {
                delete filters[tabName][fieldKey];
            }
            
            const fromInput = document.getElementById(`date-filter-from-${tabName}-${fieldKey}`);
            const toInput = document.getElementById(`date-filter-to-${tabName}-${fieldKey}`);
            if (fromInput) fromInput.value = '';
            if (toInput) toInput.value = '';
            
            applySortAndFilter(tabName);
            updateFilterHeaderStyling(tabName);
        }
        
        function applyTextFilter(tabName, fieldKey) {
            if (!filters[tabName]) filters[tabName] = {};
            
            const input = document.getElementById(`text-filter-${tabName}-${fieldKey}`);
            const value = input?.value?.trim() || '';
            
            if (value) {
                filters[tabName][fieldKey] = { type: 'text', value: value };
            } else {
                delete filters[tabName][fieldKey];
            }
            
            applySortAndFilter(tabName);
            updateFilterHeaderStyling(tabName);
        }
        
        function clearTextFilter(tabName, fieldKey) {
            if (filters[tabName]) {
                delete filters[tabName][fieldKey];
            }
            
            const input = document.getElementById(`text-filter-${tabName}-${fieldKey}`);
            if (input) input.value = '';
            
            applySortAndFilter(tabName);
            updateFilterHeaderStyling(tabName);
        }
        
        function applySelectFilter(tabName, fieldKey) {
            if (!filters[tabName]) filters[tabName] = {};
            
            const select = document.getElementById(`select-filter-${tabName}-${fieldKey}`);
            const value = select?.value || '';
            
            if (value) {
                filters[tabName][fieldKey] = { type: 'select', value: value };
            } else {
                delete filters[tabName][fieldKey];
            }
            
            applySortAndFilter(tabName);
            updateFilterHeaderStyling(tabName);
        }
        
        function clearSelectFilter(tabName, fieldKey) {
            if (filters[tabName]) {
                delete filters[tabName][fieldKey];
            }
            
            const select = document.getElementById(`select-filter-${tabName}-${fieldKey}`);
            if (select) select.value = '';
            
            applySortAndFilter(tabName);
            updateFilterHeaderStyling(tabName);
        }
        
        function clearColumnFilters(columnIndex) {
            const activeMenu = document.querySelector('.filter-menu.active');
            if (!activeMenu) return;
            
            const menuId = activeMenu.id;
            const match = menuId.match(/filter-menu-([^-]+)-(.+)/);
            if (!match) return;
            
            const tabName = match[1];
            const fieldKey = match[2];
            
            if (filters[tabName] && filters[tabName][fieldKey]) {
                delete filters[tabName][fieldKey];
                if (Object.keys(filters[tabName]).length === 0) {
                    delete filters[tabName];
                }
            }
            
            const table = document.getElementById(`${tabName}Table`);
            if (table) {
                const tbody = table.querySelector('tbody');
                if (tbody) {
                    const rows = tbody.querySelectorAll('tr');
                    rows.forEach(row => {
                        row.style.display = '';
                    });
                }
            }
            
            applySortAndFilter(tabName);
            updateFilterHeaderStyling(tabName);
        }
        
        // Helper function: Apply filters to table rows
        function applyFilters(tabName) {
            if (!filters[tabName]) return;
            
            const tbody = document.querySelector(`#${tabName}Table tbody`);
            if (!tbody) return;
            
            const rows = tbody.querySelectorAll('tr');
            let visibleCount = 0;
            
            rows.forEach(row => {
                let shouldShow = true;
                
                // Check each filter
                if (filters[tabName]) {
                    Object.keys(filters[tabName]).forEach(fieldKey => {
                        const filter = filters[tabName][fieldKey];
                        if (!filter) return; // No filter applied
                        
                        const itemId = row.querySelector('[data-item-id]')?.getAttribute('data-item-id');
                        if (!itemId) return;
                        
                        const item = originalData[tabName]?.[itemId];
                        if (!item) return;
                        
                        const cellValue = item[fieldKey];
                        
                        if (filter.type === 'text') {
                            // Text search - case insensitive
                            const searchText = String(cellValue || '').toLowerCase();
                            const filterText = filter.value.toLowerCase();
                            if (!searchText.includes(filterText)) {
                                shouldShow = false;
                            }
                        } else if (filter.type === 'select') {
                            // Exact match
                            if (fieldKey === 'submission_types') {
                                // Check if array contains the value
                                if (!Array.isArray(cellValue) || !cellValue.includes(filter.value)) {
                                    shouldShow = false;
                                }
                            } else {
                                if (String(cellValue) !== filter.value) {
                                    shouldShow = false;
                                }
                            }
                        } else if (filter.type === 'date') {
                            // Date range filter
                            if (cellValue) {
                                const cellDate = new Date(cellValue).getTime();
                                if (filter.from) {
                                    const fromDate = new Date(filter.from).getTime();
                                    if (cellDate < fromDate) {
                                        shouldShow = false;
                                    }
                                }
                                if (filter.to) {
                                    const toDate = new Date(filter.to + 'T23:59:59').getTime();
                                    if (cellDate > toDate) {
                                        shouldShow = false;
                                    }
                                }
                            } else {
                                // No date value, hide if filter requires a date
                                if (filter.from || filter.to) {
                                    shouldShow = false;
                                }
                            }
                        } else if (filter.operator === 'contains') {
                            // Contains - case insensitive
                            const cellText = String(cellValue || '').toLowerCase();
                            const filterValue = String(filter.value || '').toLowerCase();
                            if (!cellText.includes(filterValue)) {
                                shouldShow = false;
                            }
                        } else if (filter.operator === 'not_contains') {
                            // Does not contain - case insensitive
                            const cellText = String(cellValue || '').toLowerCase();
                            const filterValue = String(filter.value || '').toLowerCase();
                            if (cellText.includes(filterValue)) {
                                shouldShow = false;
                            }
                        } else if (filter.operator === 'equals') {
                            // Equals - exact match
                            if (String(cellValue) !== String(filter.value)) {
                                shouldShow = false;
                            }
                        } else if (filter.operator === 'begins_with') {
                            // Begins with - case insensitive
                            const cellText = String(cellValue || '').toLowerCase();
                            const filterValue = String(filter.value || '').toLowerCase();
                            if (!cellText.startsWith(filterValue)) {
                                shouldShow = false;
                            }
                        } else if (filter.operator === 'ends_with') {
                            // Ends with - case insensitive
                            const cellText = String(cellValue || '').toLowerCase();
                            const filterValue = String(filter.value || '').toLowerCase();
                            if (!cellText.endsWith(filterValue)) {
                                shouldShow = false;
                            }
                        } else if (filter.operator === 'greater_than') {
                            // Greater than - numeric comparison
                            const cellNum = parseFloat(cellValue);
                            const filterNum = parseFloat(filter.value);
                            if (isNaN(cellNum) || isNaN(filterNum) || cellNum <= filterNum) {
                                shouldShow = false;
                            }
                        } else if (filter.operator === 'less_than') {
                            // Less than - numeric comparison
                            const cellNum = parseFloat(cellValue);
                            const filterNum = parseFloat(filter.value);
                            if (isNaN(cellNum) || isNaN(filterNum) || cellNum >= filterNum) {
                                shouldShow = false;
                            }
                        } else if (filter.operator === 'is_empty') {
                            // Is empty - check if empty string, null, or undefined
                            const isEmpty = cellValue === null || cellValue === undefined || String(cellValue).trim() === '';
                            if (!isEmpty) {
                                shouldShow = false;
                            }
                        } else if (filter.operator === 'is_not_empty') {
                            // Is not empty - check if has content
                            const isEmpty = cellValue === null || cellValue === undefined || String(cellValue).trim() === '';
                            if (isEmpty) {
                                shouldShow = false;
                            }
                        }
                    });
                }
                
                if (shouldShow) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });
            
            // Update filter header styling
            updateFilterHeaderStyling(tabName);
            
            debugLog(`Filter applied: ${visibleCount} of ${rows.length} rows visible`, 'info');
        }
        
        // Helper function: Update filter header styling to show active filters
        function updateFilterHeaderStyling(tabName) {
            if (!filters[tabName]) {
                // No filters for this tab, remove all filter-active classes
                const table = document.getElementById(`${tabName}Table`);
                if (table) {
                    const headers = table.querySelectorAll('th');
                    headers.forEach(th => th.classList.remove('filter-active'));
                }
                return;
            }
            
            const table = document.getElementById(`${tabName}Table`);
            if (!table) return;
            
            const headers = table.querySelectorAll('th');
            headers.forEach((th, index) => {
                // Skip checkbox header (index 0)
                if (index === 0) return;
                
                // Try FIELD_DEFINITIONS first
                let fieldDefs = FIELD_DEFINITIONS[tabName];
                let fieldKey = null;
                
                if (fieldDefs && index - 1 < fieldDefs.length && index - 1 >= 0) {
                const field = fieldDefs[index - 1];
                    if (field && field.key) {
                        fieldKey = field.key;
                    }
                }
                
                // If not found in FIELD_DEFINITIONS, try CUSTOM_HEADER_FIELDS
                if (!fieldKey) {
                    fieldDefs = CUSTOM_HEADER_FIELDS[tabName];
                    if (fieldDefs && index - 1 < fieldDefs.length && index - 1 >= 0) {
                        const field = fieldDefs[index - 1];
                        if (field && field.field) {
                            fieldKey = field.field;
                        }
                    }
                }
                
                // If we have a field key, check if filter exists
                if (fieldKey) {
                    const filterValue = filters[tabName][fieldKey];
                if (filterValue) {
                    th.classList.add('filter-active');
                } else {
                        th.classList.remove('filter-active');
                    }
                } else {
                    // No field key found, ensure filter-active is removed
                    th.classList.remove('filter-active');
                }
            });
        }
        
        // Helper function: Generate table headers dynamically from FIELD_DEFINITIONS
        function generateTableHeaders(tabName) {
            const fieldDefs = FIELD_DEFINITIONS[tabName];
            if (!fieldDefs) return;

            const table = document.getElementById(`${tabName}Table`);
            if (!table) return;

            const thead = table.querySelector('thead');
            if (thead && thead.dataset.generated === 'true') {
                restoreFilterValues(tabName);
                return;
            }

            let theadElement = thead || document.createElement('thead');
            if (!thead) table.appendChild(theadElement);

            const headerRow = document.createElement('tr');
            
            // Checkbox header
            const checkboxHeader = document.createElement('th');
            checkboxHeader.className = 'checkbox-header';
            checkboxHeader.innerHTML = `<input type="checkbox" class="select-all-checkbox" id="selectAll-${tabName}" onchange="toggleSelectAll('${tabName}', this.checked)">`;
            headerRow.appendChild(checkboxHeader);

            fieldDefs.forEach(field => {
                const th = document.createElement('th');
                th.style.position = 'relative';
                th.dataset.field = field.key; // Store key for visibility toggling
                if (field.cssClass) th.className = field.cssClass;
                
                const label = document.createElement('div');
                label.className = 'header-label';
                
                // 1. Eye Icon for Visibility
                const visibilityToggle = document.createElement('span');
                visibilityToggle.className = 'column-toggle-icon';
                visibilityToggle.innerHTML = '👁';
                visibilityToggle.style.cursor = 'pointer';
                visibilityToggle.style.marginRight = '4px';
                visibilityToggle.title = 'Hide Column';
                visibilityToggle.onclick = (e) => {
                    e.stopPropagation();
                    const isHidden = toggleColumnVisibility(tabName, field.key);
                    
                    if (isHidden) {
                        visibilityToggle.innerHTML = '&mdash;';
                        visibilityToggle.style.opacity = '0.5';
                        visibilityToggle.title = 'Show Column';
                    } else {
                        visibilityToggle.innerHTML = '👁'; 
                        visibilityToggle.style.opacity = '1';
                        visibilityToggle.title = 'Hide Column';
                    }
                };
                label.appendChild(visibilityToggle);

                const labelText = document.createElement('span');
                labelText.className = 'header-label-text';
                labelText.textContent = field.label || field.key;
                label.appendChild(labelText);
                
                const controls = document.createElement('div');
                controls.className = 'header-controls';
                
                // Sort indicator
                const sortIndicator = document.createElement('span');
                sortIndicator.className = 'sort-indicator';
                sortIndicator.setAttribute('data-field', field.key);
                controls.appendChild(sortIndicator);
                
                // 2. Filter icon
                const filterIcon = document.createElement('span');
                filterIcon.className = 'filter-icon';
                filterIcon.setAttribute('data-field', field.key);
                filterIcon.title = 'Filter';
                filterIcon.onclick = (e) => {
                    e.stopPropagation();
                    toggleFilterMenu(tabName, field, filterIcon);
                };
                controls.appendChild(filterIcon);
                
                label.appendChild(controls);

                label.onclick = () => toggleSort(tabName, field.key);
                th.appendChild(label);
                
                const filterMenu = createFilterMenu(tabName, field);
                if (filterMenu) th.appendChild(filterMenu);
                
                headerRow.appendChild(th);
            });

            theadElement.innerHTML = '';
            theadElement.appendChild(headerRow);
            theadElement.dataset.generated = 'true';
        }

        // Helper function: Generate custom headers with sort and filter controls
        function generateCustomHeaders(tabName) {
            const fieldDefs = CUSTOM_HEADER_FIELDS[tabName];
            if (!fieldDefs) {
                return; // No custom field definitions
            }

            const table = document.getElementById(`${tabName}Table`);
            if (!table) {
                debugLog(`Table not found for ${tabName}`, 'error');
                return;
            }

            // Check if headers already generated
            const thead = table.querySelector('thead');
            if (thead && thead.dataset.generated === 'true') {
                // Headers already exist, but restore filter values
                restoreFilterValues(tabName);
                return;
            }

            // Create or get thead
            let theadElement = thead;
            if (!theadElement) {
                theadElement = document.createElement('thead');
                table.appendChild(theadElement);
            }

            // Create header row
            const headerRow = document.createElement('tr');
            
            // Add checkbox header
            const checkboxHeader = document.createElement('th');
            checkboxHeader.className = 'checkbox-header';
            checkboxHeader.innerHTML = `<input type="checkbox" class="select-all-checkbox" id="selectAll-${tabName}" onchange="toggleSelectAll('${tabName}', this.checked)">`;
            headerRow.appendChild(checkboxHeader);

            // Add headers for each field
            fieldDefs.forEach(field => {
                const th = document.createElement('th');
                th.style.position = 'relative';
                if (field.cssClass) {
                    th.className = field.cssClass;
                }
                
                // Create header label
                const label = document.createElement('div');
                label.className = 'header-label';
                
                const labelText = document.createElement('span');
                labelText.className = 'header-label-text';
                labelText.textContent = field.label;
                label.appendChild(labelText);
                
                // Only add sort/filter controls if field is sortable/filterable and has a data field
                if ((field.sortable || field.filterable) && field.field) {
                    const controls = document.createElement('div');
                    controls.className = 'header-controls';
                    
                    // Sort indicator (only if sortable)
                    if (field.sortable) {
                        const sortIndicator = document.createElement('span');
                        sortIndicator.className = 'sort-indicator';
                        sortIndicator.setAttribute('data-field', field.field);
                        controls.appendChild(sortIndicator);
                    }
                    
                    // Filter icon (only if filterable)
                    if (field.filterable) {
                        const filterIcon = document.createElement('span');
                        filterIcon.className = 'filter-icon';
                        filterIcon.setAttribute('data-field', field.field);
                        filterIcon.title = 'Filter';
                        filterIcon.onclick = (e) => {
                            e.stopPropagation();
                            toggleFilterMenu(tabName, field, filterIcon);
                        };
                        controls.appendChild(filterIcon);
                    }
                    
                    label.appendChild(controls);
                    
                    // Make header clickable for sorting (only if sortable)
                    if (field.sortable) {
                        label.onclick = () => {
                            toggleSort(tabName, field.field);
                        };
                    }
                }
                
                th.appendChild(label);
                
                // Add filter menu (only if filterable and has a field)
                if (field.filterable && field.field) {
                    const filterMenu = createFilterMenu(tabName, field);
                    if (filterMenu) {
                        th.appendChild(filterMenu);
                    }
                }
                
                headerRow.appendChild(th);
            });

            // Clear existing headers and add new ones
            theadElement.innerHTML = '';
            theadElement.appendChild(headerRow);
            theadElement.dataset.generated = 'true';
        }

        // Helper function: Initialize table state
        function initializeTableState(tabName, items, fieldDefs) {
            const countEl = document.getElementById(`${tabName}Count`);
            const tbody = document.getElementById(`${tabName}TableBody`);
            
            if (!countEl || !tbody) {
                debugLog(`Missing elements for ${tabName} tab`, 'error');
                return null;
            }
            
            // Initialize selectedItems
            if (!selectedItems[tabName]) {
                selectedItems[tabName] = new Set();
            }
            
            // Update count badge
            let plural;
            if (tabName === 'quizzes') {
                plural = 'quiz' + (items.length !== 1 ? 'zes' : '');
            } else {
                const itemName = tabName.slice(0, -1); // Remove 's' from plural
                plural = itemName + (items.length !== 1 ? 's' : '');
            }
            countEl.textContent = `${items.length} ${plural}`;
            
            // Clear tbody
            tbody.innerHTML = '';
            
            // Reset select-all checkbox
            const selectAllCheckbox = document.getElementById(`selectAll-${tabName}`);
            if (selectAllCheckbox) selectAllCheckbox.checked = false;

            // Handle empty state
            if (items.length === 0) {
                const colspan = fieldDefs.length + 1; // +1 for checkbox column
                tbody.innerHTML = `<tr><td colspan="${colspan}" class="empty-state">No ${tabName} found</td></tr>`;
                return null;
            }

            return tbody;
        }

        // Helper function: Create table row
        function createTableRow(tabName, item, itemId, isChecked, fieldDefs) {
            const row = document.createElement('tr');
            
            // Build row HTML
            let rowHTML = `
                <td class="checkbox-cell">
                    <input type="checkbox" class="row-checkbox" data-tab="${tabName}" data-id="${itemId}" ${isChecked ? 'checked' : ''} onchange="toggleRowSelection('${tabName}', '${itemId}', this.checked)">
                </td>
            `;
            
            // Add cells for each field
            fieldDefs.forEach(field => {
                const cssClass = field.cssClass ? ` class="${field.cssClass}"` : '';
                if (field.editable) {
                    // Editable field - use data-field attribute
                    rowHTML += `<td data-item-id="${itemId}" data-field="${field.key}"${cssClass}></td>`;
                } else {
                    // Readonly field - render directly
                    const value = item[field.key];
                    let cellContent;
                    if (field.render) {
                        // Render function returns HTML - don't escape
                        cellContent = field.render(value);
                    } else {
                        // No render function - escape the value
                        cellContent = escapeHtml(value || '-');
                    }
                    const readonlyClass = `readonly-cell${field.cssClass ? ' ' + field.cssClass : ''}`;
                    rowHTML += `<td class="${readonlyClass}" data-item-id="${itemId}" data-field="${field.key}">${cellContent}</td>`;
                }
            });
            
            row.innerHTML = rowHTML;
            
            if (isChecked) row.classList.add('selected');
            
            return row;
        }

        // Helper function: Initialize editable cells
        function initializeEditableCells(row, tabName, itemId, item, fieldDefs) {
            fieldDefs.forEach(field => {
                if (field.editable) {
                    const cell = row.querySelector(`[data-field="${field.key}"]`);
                    if (cell) {
                        const value = item[field.key];
                        // For published fields, just display as toggle button (don't make editable with click)
                        if (field.key === 'published' && field.type === 'boolean') {
                            displayCellValue(cell, tabName, itemId, field.key, value, field.type, field);
                        } else {
                            makeCellEditable(cell, tabName, itemId, field.key, value, field.type, field);
                            displayCellValue(cell, tabName, itemId, field.key, value, field.type, field);
                        }
                    }
                }
            });
        }

        // Generic display function using FIELD_DEFINITIONS
        function displayDataTable(tabName, items) {
            const fieldDefs = FIELD_DEFINITIONS[tabName];
            if (!fieldDefs) {
                debugLog(`No field definitions found for ${tabName}`, 'error');
                return;
            }

            // Generate headers dynamically if not already done
            generateTableHeaders(tabName);

            // Initialize table state (returns tbody if successful, null if empty/error)
            const tbody = initializeTableState(tabName, items, fieldDefs);
            if (!tbody) {
                return; // Empty state or error already handled
            }

            // Process each item
            items.forEach((item, index) => {
                const itemId = item.id || index;
                const isChecked = selectedItems[tabName].has(itemId);
                
                // Create row using helper function
                const row = createTableRow(tabName, item, itemId, isChecked, fieldDefs);
                
                // Store original data
                if (!originalData[tabName]) originalData[tabName] = {};
                originalData[tabName][itemId] = item;
                
                // Initialize editable cells using helper function
                initializeEditableCells(row, tabName, itemId, item, fieldDefs);
                
                tbody.appendChild(row);
            });
            
            // Apply existing filters and sorting after data is loaded
            setTimeout(() => {
                applySortAndFilter(tabName);
                updateSortIndicators(tabName);
                // Update dropdown options with new data
                updateFilterDropdowns(tabName);
                
                // Restore column visibility from localStorage
                restoreColumnVisibility(tabName);
                
                // Initialize keyboard navigation for this table (use body table)
                const table = document.querySelector(`#${tabName}Table`);
                if (table) {
                    initializeTableKeyboard(table);
                }
                
            }, 0);
        }
        
        // Helper function: Toggle column visibility
        function toggleColumnVisibility(tabName, fieldKey) {
            const table = document.getElementById(`${tabName}Table`);
            if (!table) return false;

            const headers = Array.from(table.querySelectorAll('thead th'));
            const columnIndex = headers.findIndex(th => th.dataset.field === fieldKey);

            if (columnIndex === -1) return false;

            const header = headers[columnIndex];
            const isCollapsed = header.classList.contains('column-collapsed');

            // Toggle collapsed class on header
            if (isCollapsed) {
                header.classList.remove('column-collapsed');
            } else {
                header.classList.add('column-collapsed');
            }

            // Toggle collapsed class on all cells in that column
            const rows = table.querySelectorAll('tbody tr');
            rows.forEach(row => {
                const cell = row.cells[columnIndex];
                if (cell) {
                    if (isCollapsed) {
                        cell.classList.remove('column-collapsed-cell');
                    } else {
                        cell.classList.add('column-collapsed-cell');
                    }
                }
            });

            // Persist visibility state in localStorage
            const storageKey = `columnVisibility_${tabName}`;
            let visibilityState = {};
            try {
                const stored = localStorage.getItem(storageKey);
                if (stored) {
                    visibilityState = JSON.parse(stored);
                }
            } catch (e) {
                console.warn('Failed to parse column visibility state from localStorage', e);
            }
            
            visibilityState[fieldKey] = !isCollapsed; // Store as collapsed state
            try {
                localStorage.setItem(storageKey, JSON.stringify(visibilityState));
            } catch (e) {
                console.warn('Failed to save column visibility state to localStorage', e);
            }

            debugLog(`Column ${fieldKey} visibility set to: ${isCollapsed ? 'expanded' : 'collapsed'}`);
            
            // Return the new collapsed state (after toggle)
            return !isCollapsed;
        }

        // Helper function: Restore column visibility from localStorage
        function restoreColumnVisibility(tabName) {
            const table = document.getElementById(`${tabName}Table`);
            if (!table) return;

            const storageKey = `columnVisibility_${tabName}`;
            let visibilityState = {};
            try {
                const stored = localStorage.getItem(storageKey);
                if (stored) {
                    visibilityState = JSON.parse(stored);
                }
            } catch (e) {
                console.warn('Failed to parse column visibility state from localStorage', e);
                return;
            }

            const headers = Array.from(table.querySelectorAll('thead th'));
            
            Object.keys(visibilityState).forEach(fieldKey => {
                const columnIndex = headers.findIndex(th => th.dataset.field === fieldKey);
                if (columnIndex === -1) return;

                const isCollapsed = visibilityState[fieldKey];
                const header = headers[columnIndex];

                // Set collapsed class on header
                if (isCollapsed) {
                    header.classList.add('column-collapsed');
                } else {
                    header.classList.remove('column-collapsed');
                }

                // Set collapsed class on all cells in that column
                const rows = table.querySelectorAll('tbody tr');
                rows.forEach(row => {
                    const cell = row.cells[columnIndex];
                    if (cell) {
                        if (isCollapsed) {
                            cell.classList.add('column-collapsed-cell');
                        } else {
                            cell.classList.remove('column-collapsed-cell');
                        }
                    }
                });

                // Update eye icon state
                const visibilityToggle = header.querySelector('.column-toggle-icon');
                if (visibilityToggle) {
                    if (isCollapsed) {
                        visibilityToggle.innerHTML = '&mdash;';
                        visibilityToggle.style.opacity = '0.5';
                        visibilityToggle.title = 'Show Column';
                    } else {
                        visibilityToggle.innerHTML = '👁';
                        visibilityToggle.style.opacity = '1';
                        visibilityToggle.title = 'Hide Column';
                    }
                }
            });
        }

        // Helper function: Restore filter values to inputs after headers are regenerated
        function restoreFilterValues(tabName) {
            if (!filters[tabName]) return;
            
            const fieldDefs = FIELD_DEFINITIONS[tabName];
            if (!fieldDefs) return;
            
            fieldDefs.forEach(field => {
                const filter = filters[tabName][field.key];
                if (!filter) return;
                
                if (filter.type === 'text') {
                    const input = document.getElementById(`text-filter-${tabName}-${field.key}`);
                    if (input) input.value = filter.value;
                } else if (filter.type === 'select') {
                    const select = document.getElementById(`select-filter-${tabName}-${field.key}`);
                    if (select) select.value = filter.value;
                } else if (filter.type === 'date') {
                    const fromInput = document.getElementById(`date-filter-from-${tabName}-${field.key}`);
                    const toInput = document.getElementById(`date-filter-to-${tabName}-${field.key}`);
                    if (fromInput && filter.from) fromInput.value = filter.from;
                    if (toInput && filter.to) toInput.value = filter.to;
                }
            });
        }
        
        // Close filter menus when clicking outside
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.filter-menu') && !e.target.closest('.filter-icon')) {
                document.querySelectorAll('.filter-menu').forEach(menu => {
                    menu.classList.remove('active');
                });
                document.querySelectorAll('.filter-icon').forEach(icon => {
                    icon.classList.remove('active');
                });
            }
        });
        
        // Preview tooltip functions
        function showPreviewTooltip(event, tooltipId) {
            const tooltip = document.getElementById(tooltipId);
            if (!tooltip) return;
            
            const cell = event.currentTarget;
            const rect = cell.getBoundingClientRect();
            
            // Position tooltip above the cell, centered
            let left = rect.left + (rect.width / 2) - (tooltip.offsetWidth / 2);
            let top = rect.top - tooltip.offsetHeight - 8;
            
            // Adjust if tooltip would go off screen
            if (left < 10) left = 10;
            if (left + tooltip.offsetWidth > window.innerWidth - 10) {
                left = window.innerWidth - tooltip.offsetWidth - 10;
            }
            
            // If not enough room above, show below
            if (top < 10) {
                top = rect.bottom + 8;
            }
            
            tooltip.style.left = left + 'px';
            tooltip.style.top = top + 'px';
            tooltip.style.display = 'block';
        }
        
        function hidePreviewTooltip(tooltipId) {
            const tooltip = document.getElementById(tooltipId);
            if (tooltip) {
                tooltip.style.display = 'none';
            }
        }
        
        // Helper function: Update filter dropdown options after data loads
        function updateFilterDropdowns(tabName) {
            const fieldDefs = FIELD_DEFINITIONS[tabName];
            if (!fieldDefs) return;
            
            fieldDefs.forEach(field => {
                if (field.key === 'quiz_type' || field.key === 'discussion_type' || field.key === 'submission_types') {
                    const filterId = `filter-${tabName}-${field.key}`;
                    const select = document.getElementById(filterId);
                    if (!select) return;
                    
                    // Get current selection
                    const currentValue = select.value;
                    
                    // Get unique values
                    const values = field.key === 'submission_types' 
                        ? getUniqueSubmissionTypes(tabName)
                        : getUniqueValuesForField(tabName, field.key);
                    
                    // Clear and rebuild options
                    select.innerHTML = '';
                    const optionAll = document.createElement('option');
                    optionAll.value = '';
                    optionAll.textContent = 'All';
                    select.appendChild(optionAll);
                    
                    values.forEach(value => {
                        const option = document.createElement('option');
                        option.value = value;
                        option.textContent = value;
                        select.appendChild(option);
                    });
                    
                    // Restore selection if it still exists
                    if (currentValue && values.includes(currentValue)) {
                        select.value = currentValue;
                    }
                }
            });
        }

        function getCurrentCourseId() {
            if (currentCourseId) return currentCourseId;
            if (window.currentCourseId) {
                debugLog('Recovering currentCourseId from window object', 'warn');
                currentCourseId = window.currentCourseId;
                return currentCourseId;
            }
            return null;
        }

        function initializeAdvancedFilterModal() {
            const modal = document.createElement('div');
            modal.id = 'advancedFilterModal';
            modal.className = 'modal-overlay';
            modal.innerHTML = `
                <div class="modal">
                    <div class="modal-header">
                        <h2 id="modalTitle">Filter Column</h2>
                        <button class="modal-close" onclick="closeAdvancedFilterModal()">&times;</button>
                    </div>
                    <div class="modal-content">
                        <div id="filterCriteriaContainer"></div>
                        <button type="button" class="add-criteria-btn" onclick="addFilterRow()">
                            + Add Condition
                        </button>
                    </div>
                    <div class="modal-footer">
                        <button class="modal-btn modal-btn-secondary" onclick="clearAdvancedFilters()">Clear All</button>
                        <button class="modal-btn modal-btn-primary" onclick="saveAdvancedFilters()">Apply Filter</button>
                    </div>
                </div>
            `;
            document.body.appendChild(modal);
        }

        function openAdvancedFilterModal(tabName, fieldKey) {
            const modal = document.getElementById('advancedFilterModal');
            if (!modal) return;
            
            modal.dataset.tabName = tabName;
            modal.dataset.fieldKey = fieldKey;
            
            const modalTitle = document.getElementById('modalTitle');
            if (modalTitle) {
                const fieldDefs = FIELD_DEFINITIONS[tabName];
                const field = fieldDefs ? fieldDefs.find(f => f.key === fieldKey) : null;
                const fieldLabel = field ? field.label : fieldKey;
                modalTitle.textContent = `Filter: ${fieldLabel}`;
            }
            
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeAdvancedFilterModal() {
            const modal = document.getElementById('advancedFilterModal');
            if (modal) {
                modal.classList.remove('active');
                document.body.style.overflow = '';
            }
        }

        function saveAdvancedFilters() {
            const modal = document.getElementById('advancedFilterModal');
            if (!modal) return;
            
            const tabName = modal.dataset.tabName;
            const fieldKey = modal.dataset.fieldKey;
            
            if (!tabName || !fieldKey) {
                alert('Error: Missing filter context');
                return;
            }
            
            const container = document.getElementById('filterCriteriaContainer');
            if (!container) return;
            
            const filterRows = container.querySelectorAll('.filter-row');
            const activeFilters = [];
            
            filterRows.forEach(row => {
                const operatorSelect = row.querySelector('.filter-operator');
                const valueInput = row.querySelector('.filter-value');
                
                if (!operatorSelect) return;
                
                const operator = operatorSelect.value;
                const value = valueInput && !valueInput.disabled ? valueInput.value.trim() : '';
                
                if (operator && (value || operator === 'is_empty' || operator === 'is_not_empty')) {
                    activeFilters.push({
                        operator: operator,
                        value: value
                    });
                }
            });
            
            if (activeFilters.length === 0) {
                closeAdvancedFilterModal();
                return;
            }
            
            const table = document.getElementById(`${tabName}Table`);
            if (!table) {
                alert('Error: Table not found');
                return;
            }
            
            const tbody = table.querySelector('tbody');
            if (!tbody) return;
            
            const rows = tbody.querySelectorAll('tr');
            let visibleCount = 0;
            
            rows.forEach(row => {
                let shouldShow = true;
                const itemId = row.querySelector('[data-item-id]')?.getAttribute('data-item-id');
                
                if (!itemId) {
                    row.style.display = 'none';
                    return;
                }
                
                const item = originalData[tabName]?.[itemId];
                if (!item) {
                    row.style.display = 'none';
                    return;
                }
                
                const cellValue = item[fieldKey];
                
                activeFilters.forEach(filter => {
                    if (!shouldShow) return;
                    
                    if (filter.operator === 'contains') {
                        const cellText = String(cellValue || '').toLowerCase();
                        const filterValue = String(filter.value || '').toLowerCase();
                        if (!cellText.includes(filterValue)) {
                            shouldShow = false;
                        }
                    } else if (filter.operator === 'not_contains') {
                        const cellText = String(cellValue || '').toLowerCase();
                        const filterValue = String(filter.value || '').toLowerCase();
                        if (cellText.includes(filterValue)) {
                            shouldShow = false;
                        }
                    } else if (filter.operator === 'equals') {
                        if (String(cellValue) !== String(filter.value)) {
                            shouldShow = false;
                        }
                    } else if (filter.operator === 'begins_with') {
                        const cellText = String(cellValue || '').toLowerCase();
                        const filterValue = String(filter.value || '').toLowerCase();
                        if (!cellText.startsWith(filterValue)) {
                            shouldShow = false;
                        }
                    } else if (filter.operator === 'ends_with') {
                        const cellText = String(cellValue || '').toLowerCase();
                        const filterValue = String(filter.value || '').toLowerCase();
                        if (!cellText.endsWith(filterValue)) {
                            shouldShow = false;
                        }
                    } else if (filter.operator === 'greater_than') {
                        const cellNum = parseFloat(cellValue);
                        const filterNum = parseFloat(filter.value);
                        if (isNaN(cellNum) || isNaN(filterNum) || cellNum <= filterNum) {
                            shouldShow = false;
                        }
                    } else if (filter.operator === 'less_than') {
                        const cellNum = parseFloat(cellValue);
                        const filterNum = parseFloat(filter.value);
                        if (isNaN(cellNum) || isNaN(filterNum) || cellNum >= filterNum) {
                            shouldShow = false;
                        }
                    } else if (filter.operator === 'is_empty') {
                        const isEmpty = cellValue === null || cellValue === undefined || String(cellValue).trim() === '';
                        if (!isEmpty) {
                            shouldShow = false;
                        }
                    } else if (filter.operator === 'is_not_empty') {
                        const isEmpty = cellValue === null || cellValue === undefined || String(cellValue).trim() === '';
                        if (isEmpty) {
                            shouldShow = false;
                        }
                    }
                });
                
                if (shouldShow) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });
            
            if (activeFilters.length > 0) {
                if (!filters[tabName]) filters[tabName] = {};
                filters[tabName][fieldKey] = {
                    type: 'advanced',
                    operator: activeFilters[0].operator,
                    value: activeFilters[0].value,
                    filters: activeFilters
                };
            } else {
                if (filters[tabName] && filters[tabName][fieldKey]) {
                    delete filters[tabName][fieldKey];
                    if (Object.keys(filters[tabName]).length === 0) {
                        delete filters[tabName];
                    }
                }
            }
            
            updateFilterHeaderStyling(tabName);
            closeAdvancedFilterModal();
            debugLog(`Advanced filter applied: ${visibleCount} of ${rows.length} rows visible`, 'info');
        }

        function clearAdvancedFilters() {
            const modal = document.getElementById('advancedFilterModal');
            if (!modal) return;
            
            const tabName = modal.dataset.tabName;
            const fieldKey = modal.dataset.fieldKey;
            
            const container = document.getElementById('filterCriteriaContainer');
            if (container) {
                container.innerHTML = '';
            }
            
            if (tabName && fieldKey) {
                if (filters[tabName] && filters[tabName][fieldKey]) {
                    delete filters[tabName][fieldKey];
                    if (Object.keys(filters[tabName]).length === 0) {
                        delete filters[tabName];
                    }
                }
                
                const table = document.getElementById(`${tabName}Table`);
                if (table) {
                    const tbody = table.querySelector('tbody');
                    if (tbody) {
                        const rows = tbody.querySelectorAll('tr');
                        rows.forEach(row => {
                            row.style.display = '';
                        });
                    }
                }
                
                updateFilterHeaderStyling(tabName);
            }
            
            addFilterRow();
        }

        function addFilterRow() {
            const container = document.getElementById('filterCriteriaContainer');
            if (!container) return;

            const row = document.createElement('div');
            row.className = 'filter-row';

            const operatorSelect = document.createElement('select');
            operatorSelect.className = 'filter-operator';
            operatorSelect.innerHTML = `
                <option value="contains">Contains</option>
                <option value="not_contains">Does Not Contain</option>
                <option value="equals">Equals</option>
                <option value="begins_with">Begins With</option>
                <option value="ends_with">Ends With</option>
                <option value="greater_than">Greater Than</option>
                <option value="less_than">Less Than</option>
                <option value="is_empty">Is Empty</option>
                <option value="is_not_empty">Is Not Empty</option>
            `;
            row.appendChild(operatorSelect);

            const valueInput = document.createElement('input');
            valueInput.type = 'text';
            valueInput.className = 'filter-value';
            valueInput.placeholder = 'Value';
            row.appendChild(valueInput);

            const removeBtn = document.createElement('span');
            removeBtn.className = 'remove-row-btn';
            removeBtn.textContent = '×';
            removeBtn.onclick = () => {
                row.remove();
                applyAdvancedFiltersFromModal();
            };
            row.appendChild(removeBtn);

            function toggleValueInput() {
                const operator = operatorSelect.value;
                if (operator === 'is_empty' || operator === 'is_not_empty') {
                    valueInput.style.display = 'none';
                    valueInput.disabled = true;
                } else {
                    valueInput.style.display = '';
                    valueInput.disabled = false;
                }
            }

            operatorSelect.addEventListener('change', toggleValueInput);
            toggleValueInput();

            container.appendChild(row);
        }

        function applyAdvancedFiltersFromModal() {
            const modal = document.getElementById('advancedFilterModal');
            if (!modal) return;
            
            const tabName = modal.dataset.tabName;
            const fieldKey = modal.dataset.fieldKey;
            
            if (!tabName || !fieldKey) return;
            
            const container = document.getElementById('filterCriteriaContainer');
            if (!container) return;
            
            const filterRows = container.querySelectorAll('.filter-row');
            const activeFilters = [];
            
            filterRows.forEach(row => {
                const operatorSelect = row.querySelector('.filter-operator');
                const valueInput = row.querySelector('.filter-value');
                
                if (!operatorSelect) return;
                
                const operator = operatorSelect.value;
                const value = valueInput && !valueInput.disabled ? valueInput.value.trim() : '';
                
                if (operator && (value || operator === 'is_empty' || operator === 'is_not_empty')) {
                    activeFilters.push({
                        operator: operator,
                        value: value
                    });
                }
            });
            
            const table = document.getElementById(`${tabName}Table`);
            if (!table) return;
            
            const tbody = table.querySelector('tbody');
            if (!tbody) return;
            
            const rows = tbody.querySelectorAll('tr');
            let visibleCount = 0;
            
            rows.forEach(row => {
                let shouldShow = true;
                const itemId = row.querySelector('[data-item-id]')?.getAttribute('data-item-id');
                
                if (!itemId) {
                    row.style.display = 'none';
                    return;
                }
                
                const item = originalData[tabName]?.[itemId];
                if (!item) {
                    row.style.display = 'none';
                    return;
                }
                
                const cellValue = item[fieldKey];
                
                const containsFilters = activeFilters.filter(f => f.operator === 'contains');
                const otherFilters = activeFilters.filter(f => f.operator !== 'contains');
                
                let matchesContains = containsFilters.length === 0;
                
                if (containsFilters.length > 0) {
                    const cellText = String(cellValue || '').toLowerCase();
                    matchesContains = containsFilters.some(filter => {
                        const filterValue = String(filter.value || '').toLowerCase();
                        return cellText.includes(filterValue);
                    });
                }
                
                let matchesOther = true;
                otherFilters.forEach(filter => {
                    if (!matchesOther) return;
                    
                    if (filter.operator === 'not_contains') {
                        const cellText = String(cellValue || '').toLowerCase();
                        const filterValue = String(filter.value || '').toLowerCase();
                        if (cellText.includes(filterValue)) {
                            matchesOther = false;
                        }
                    } else if (filter.operator === 'equals') {
                        if (String(cellValue) !== String(filter.value)) {
                            matchesOther = false;
                        }
                    } else if (filter.operator === 'begins_with') {
                        const cellText = String(cellValue || '').toLowerCase();
                        const filterValue = String(filter.value || '').toLowerCase();
                        if (!cellText.startsWith(filterValue)) {
                            matchesOther = false;
                        }
                    } else if (filter.operator === 'ends_with') {
                        const cellText = String(cellValue || '').toLowerCase();
                        const filterValue = String(filter.value || '').toLowerCase();
                        if (!cellText.endsWith(filterValue)) {
                            matchesOther = false;
                        }
                    } else if (filter.operator === 'greater_than') {
                        const cellNum = parseFloat(cellValue);
                        const filterNum = parseFloat(filter.value);
                        if (isNaN(cellNum) || isNaN(filterNum) || cellNum <= filterNum) {
                            matchesOther = false;
                        }
                    } else if (filter.operator === 'less_than') {
                        const cellNum = parseFloat(cellValue);
                        const filterNum = parseFloat(filter.value);
                        if (isNaN(cellNum) || isNaN(filterNum) || cellNum >= filterNum) {
                            matchesOther = false;
                        }
                    } else if (filter.operator === 'is_empty') {
                        const isEmpty = cellValue === null || cellValue === undefined || String(cellValue).trim() === '';
                        if (!isEmpty) {
                            matchesOther = false;
                        }
                    } else if (filter.operator === 'is_not_empty') {
                        const isEmpty = cellValue === null || cellValue === undefined || String(cellValue).trim() === '';
                        if (isEmpty) {
                            matchesOther = false;
                        }
                    }
                });
                
                shouldShow = matchesContains && matchesOther;
                
                if (shouldShow) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });
            
            if (activeFilters.length > 0) {
                if (!filters[tabName]) filters[tabName] = {};
                filters[tabName][fieldKey] = {
                    type: 'advanced',
                    operator: activeFilters[0].operator,
                    value: activeFilters[0].value,
                    filters: activeFilters
                };
            } else {
                if (filters[tabName] && filters[tabName][fieldKey]) {
                    delete filters[tabName][fieldKey];
                    if (Object.keys(filters[tabName]).length === 0) {
                        delete filters[tabName];
                    }
                }
            }
            
            updateFilterHeaderStyling(tabName);
        }

