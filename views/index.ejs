            const activeTab = document.querySelector('.tab-content.active');
            if (!activeTab) return null;
            const tabId = activeTab.id;
            return tabId.replace('tab-', '');
        }

        function syncCurrentTab() {
            const tabName = getCurrentTabName();
            if (!tabName) {
                alert('Please select a tab first.');
                return;
            }
            syncChanges(tabName);
        }

        function getSelectedItems() {
            const tabName = getCurrentTabName();
            if (!tabName) return [];
            
            const selected = selectedItems[tabName] || new Set();
            return Array.from(selected);
        }

        function applyDateShift() {
            const tabName = getCurrentTabName();
            if (!tabName) {
                alert('Please select a tab first.');
                closeModal('dateShiftModal');
                return;
            }

            // Get scope (all vs selected)
            const scopeRadio = document.querySelector('input[name="dateShiftScope"]:checked');
            const scope = scopeRadio ? scopeRadio.value : 'selected';
            
            // Get selected items
            const selected = getSelectedItems();
            if (scope === 'selected' && selected.length === 0) {
                alert('Please select at least one item, or choose "Apply to All Rows".');
                closeModal('dateShiftModal');
                return;
            }

            // Get shift value
            const days = parseInt(document.getElementById('dateShiftDays').value);
            
            if (isNaN(days)) {
                alert('Please enter a valid number of days.');
                return;
            }

            if (days === 0) {
                alert('Please enter a non-zero number of days.');
                return;
            }

            // Get selected date fields from checkboxes
            const dateFieldsContainer = document.getElementById('dateShiftFieldsContainer');
            if (!dateFieldsContainer) {
                alert('Date fields container not found.');
                closeModal('dateShiftModal');
                return;
            }
            
            const checkedBoxes = dateFieldsContainer.querySelectorAll('input[type="checkbox"]:checked');
            const dateFields = Array.from(checkedBoxes).map(checkbox => checkbox.value).filter(value => value);
            
            if (dateFields.length === 0) {
                alert('Please select at least one date field to shift.');
                closeModal('dateShiftModal');
                return;
            }
            
            // Get field definitions for display purposes
            const fieldDefs = FIELD_DEFINITIONS[tabName];
            if (!fieldDefs) {
                alert('No field definitions found for this tab.');
                closeModal('dateShiftModal');
                return;
            }

            // Determine target items
            let targetItems = [];
            if (scope === 'all') {
                // Get all item IDs from originalData
                targetItems = Object.keys(originalData[tabName] || {});
            } else {
                targetItems = selected;
            }

            if (targetItems.length === 0) {
                alert('No items found to apply date shift to.');
                closeModal('dateShiftModal');
                return;
            }

            const millisecondsPerDay = 24 * 60 * 60 * 1000;
            const offsetMs = days * millisecondsPerDay;

            let modifiedCount = 0;
            let totalFieldChanges = 0;

            targetItems.forEach(itemId => {
                const original = originalData[tabName]?.[itemId];
                if (!original) return;

                let itemModified = false;

                // Apply shift to all date fields
                dateFields.forEach(field => {
                    const currentValue = original[field];
                    if (!currentValue) {
                        debugLog(`Skipping ${itemId}: no ${field} to offset`, 'warn');
                        return;
                    }

                    const currentDate = new Date(currentValue);
                    if (isNaN(currentDate.getTime())) {
                        debugLog(`Skipping ${itemId}: invalid date ${currentValue} for field ${field}`, 'warn');
                        return;
                    }

                    const newDate = new Date(currentDate.getTime() + offsetMs);
                    const newValue = newDate.toISOString();

                    // Update the change tracking
                    if (!changes[tabName]) changes[tabName] = {};
                    if (!changes[tabName][itemId]) changes[tabName][itemId] = {};
                    changes[tabName][itemId][field] = newValue;

                    // Update the cell display
                    const cell = document.querySelector(`#tab-${tabName} [data-item-id="${itemId}"][data-field="${field}"]`);
                    if (cell) {
                        const fieldDef = fieldDefs.find(f => f.key === field);
                        const fieldType = fieldDef ? fieldDef.type : 'datetime';
                        displayCellValue(cell, tabName, itemId, field, newValue, fieldType, fieldDef);
                        const row = cell.closest('tr');
                        if (row) row.classList.add('modified');
                    }

                    itemModified = true;
                    totalFieldChanges++;
                });

                if (itemModified) {
                    modifiedCount++;
                }
            });

            updateSyncButton(tabName);
            alert(`Date shift applied to ${modifiedCount} item(s) with ${totalFieldChanges} total field change(s). Click "Sync to Canvas" to save changes.`);
            closeModal('dateShiftModal');
        }

        function applySearchReplace() {
            const tabName = getCurrentTabName();
            if (!tabName) {
                alert('Please select a tab first.');
                closeModal('searchReplaceModal');
                return;
            }

            const selected = getSelectedItems();
            if (selected.length === 0) {
                alert('Please select at least one item.');
                closeModal('searchReplaceModal');
                return;
            }

            const searchText = document.getElementById('searchReplaceFind').value.trim();
            const replaceText = document.getElementById('searchReplaceWith').value;

            if (!searchText) {
                alert('Please enter text to search for.');
                return;
            }

            // Get field definitions for type checking - check both FIELD_DEFINITIONS and CUSTOM_HEADER_FIELDS
            let fieldDefs = FIELD_DEFINITIONS[tabName];
            let isCustomHeader = false;
            
            if (!fieldDefs) {
                fieldDefs = CUSTOM_HEADER_FIELDS[tabName];
                isCustomHeader = true;
            }
            
            if (!fieldDefs) {
                alert('No field definitions found for this tab.');
                closeModal('searchReplaceModal');
                return;
            }

            // Get all editable text/numeric fields
            // For FIELD_DEFINITIONS: check field.editable and use field.key
            // For CUSTOM_HEADER_FIELDS: include text/number fields (modules: name, position are editable)
            const eligibleFields = fieldDefs.filter(field => {
                if (isCustomHeader) {
                    const fieldKey = field.field;
                    if (!fieldKey) return false;
                    // For modules, name and position are editable text/number fields
                    // Exclude boolean, datetime, and other non-text/number types
                    return (field.type === 'text' || field.type === 'number' || field.type === 'textarea');
                } else {
                    return field.editable && (field.type === 'text' || field.type === 'number' || field.type === 'textarea');
                }
            });

            if (eligibleFields.length === 0) {
                alert('No editable text/numeric fields available in this tab.');
                closeModal('searchReplaceModal');
                return;
            }

            let modifiedCount = 0;
            let totalFieldChanges = 0;

            selected.forEach(itemId => {
                const original = originalData[tabName]?.[itemId];
                if (!original) return;

                let itemModified = false;

                // Apply search/replace to all eligible fields
                eligibleFields.forEach(fieldDef => {
                    const fieldKey = isCustomHeader ? fieldDef.field : fieldDef.key;
                    if (!fieldKey) return;

                    let currentValue = original[fieldKey];
                    if (currentValue === null || currentValue === undefined) {
                        return; // Skip null/undefined values
                    }

                    // Convert to string for searching (handles both text and numbers)
                    const currentValueStr = String(currentValue);
                    
                    if (!currentValueStr.includes(searchText)) {
                        return; // No match, skip
                    }

                    // Perform replace
                    const newValueStr = currentValueStr.replace(
                        new RegExp(searchText.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), 
                        replaceText
                    );

                    // Convert back to appropriate type
                    let newValue;
                    if (fieldDef.type === 'number') {
                        // For numeric fields, try to parse as number
                        const parsed = parseFloat(newValueStr);
                        newValue = isNaN(parsed) ? newValueStr : parsed;
                    } else {
                        // For text/textarea fields, keep as string
                        newValue = newValueStr;
                    }

                    // Update the change tracking
                    if (!changes[tabName]) changes[tabName] = {};
                    if (!changes[tabName][itemId]) changes[tabName][itemId] = {};
                    changes[tabName][itemId][fieldKey] = newValue;

                    // Update the cell display
                    const cell = document.querySelector(`#tab-${tabName} [data-item-id="${itemId}"][data-field="${fieldKey}"]`);
                    if (cell) {
                        displayCellValue(cell, tabName, itemId, fieldKey, newValue, fieldDef.type, fieldDef);
                        const row = cell.closest('tr');
                        if (row) row.classList.add('modified');
                    }

                    itemModified = true;
                    totalFieldChanges++;
                });

                if (itemModified) {
                    modifiedCount++;
                }
            });

            updateSyncButton(tabName);
            alert(`Search and replace applied to ${modifiedCount} item(s) with ${totalFieldChanges} total field change(s). Click "Sync to Canvas" to save changes.`);
            closeModal('searchReplaceModal');
        }

