<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canvas Bulk Editor</title>
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community/dist/ag-grid-community.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div id="token-overlay" style="display: none;">
        <div class="login-modal">
            <div class="login-content">
                <h2>Canvas Bulk Editor</h2>
                <p>Enter your Canvas API token to access your courses.</p>
                
                <form id="loginForm">
                    <div class="form-group">
                        <label for="canvasUrl">Canvas Base URL:</label>
                        <input type="url" id="canvasUrl" name="canvasUrl" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="canvasToken">Canvas API Token:</label>
                        <input type="password" id="canvasToken" name="canvasToken" required>
                        <small>Get your token from Canvas Account > Settings > Approved Integrations</small>
                    </div>
                    
                    <div id="loginError" class="error-message" style="display: none;"></div>
                    
                    <div class="form-actions">
                        <button type="submit" class="primary-btn">Connect</button>
                        <button type="button" class="secondary-btn" onclick="closeLoginModal()">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="main-app-wrapper" style="display: none;">
        <div class="app-container">
            <div class="debug-panel collapsed" id="debugPanel">
                <div class="debug-panel-header" onclick="toggleDebugPanel()">
                    <span>System Debug Monitor</span>
                    <span id="debugToggle">▲</span>
                </div>
                <div class="debug-panel-content" id="debugContent"></div>
            </div>
            
            <aside class="sidebar">
                <nav class="tab-container" id="tabContainer">
                    <button class="tab-btn active" onclick="switchTab('assignments')">Assignments</button>
                    <button class="tab-btn" onclick="switchTab('modules')">Modules</button>
                    <button class="tab-btn" onclick="switchTab('pages')">Pages</button>
                    <button class="tab-btn" onclick="switchTab('quizzes')">Quizzes</button>
                    <button class="tab-btn" onclick="switchTab('discussions')">Discussions</button>
                    <button class="tab-btn" onclick="switchTab('ada_compliance')">ADA Compliance Sync</button>
                    <button class="tab-btn" onclick="switchTab('standards_sync')">Standards Sync</button>
                </nav>
            </aside>

            <main class="main-content">
                <header class="toolbar">
                    <select id="courseSelect" onchange="onCourseSelected()">
                        <option value="">Select a Course</option>
                    </select>
                    <button class="primary-btn" onclick="syncChanges()">Sync Changes</button>
                    <button class="primary-btn" onclick="refreshCurrentTab()">Refresh</button>
                </header>
                <div id="myGrid" class="ag-theme-quartz" style="height: 500px; width: 100%;"></div>
            </main>
        </div>
    </div>

    <script>
        // Wrapping the EJS tag in quotes tells the JS engine this is a string,
        // which usually stops the 'identifier expected' red squiggles.
        window.SERVER_DATA = {
            courseId: "<%= typeof courseId !== 'undefined' ? courseId : '' %>"
        };
    </script>

    <script src="/js/auth.js"></script>
    <script src="/js/config.js"></script>
    <script src="/js/helpers.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>