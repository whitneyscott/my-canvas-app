        function toggleSelectAll(tabName, checked) {
            if (!selectedItems[tabName]) {
                selectedItems[tabName] = new Set();
            }
            
            const checkboxes = document.querySelectorAll(`#tab-${tabName} .row-checkbox`);
            checkboxes.forEach(cb => {
                const row = cb.closest('tr');
                if (!row) return;
                
                const isVisible = row.style.display !== 'none' && window.getComputedStyle(row).display !== 'none';
                
                if (checked) {
                    if (isVisible) {
                        cb.checked = true;
                        const itemId = cb.getAttribute('data-id');
                        selectedItems[tabName].add(itemId);
                        row.classList.add('selected');
                    } else {
                        cb.checked = false;
                    }
                } else {
                    cb.checked = false;
                    const itemId = cb.getAttribute('data-id');
                    selectedItems[tabName].delete(itemId);
                    row.classList.remove('selected');
                }
            });
            
            // Update sidebar content when selections change
            updateSidebarContent();
        }

        function toggleRowSelection(tabName, itemId, checked) {
            if (!selectedItems[tabName]) {
                selectedItems[tabName] = new Set();
            }
            
            if (checked) {
                selectedItems[tabName].add(itemId);
            } else {
                selectedItems[tabName].delete(itemId);
            }
            
            const row = document.querySelector(`[data-item-id="${itemId}"]`)?.closest('tr');
            if (row) {
                if (checked) {
                    row.classList.add('selected');
                } else {
                    row.classList.remove('selected');
                }
            }
            
            const selectAllCheckbox = document.getElementById(`selectAll-${tabName}`);
            if (selectAllCheckbox) {
                const allCheckboxes = document.querySelectorAll(`#tab-${tabName} .row-checkbox`);
                const checkedCount = Array.from(allCheckboxes).filter(cb => cb.checked).length;
                selectAllCheckbox.checked = checkedCount === allCheckboxes.length && allCheckboxes.length > 0;
            }
            
            // Update sidebar content when selections change
            updateSidebarContent();
        }

        function makeCellEditable(cell, tabName, itemId, fieldName, currentValue, fieldType, fieldDef = null) {
            if (!cell) return;
            
            // Don't make published fields editable with click - they use toggle buttons
            if (fieldName === 'published' && fieldType === 'boolean') {
                return; // Published fields are handled by toggle buttons
            }
            
            cell.classList.add('cell-editable');
            
            const actualCurrentValue = changes[tabName] && changes[tabName][itemId] && changes[tabName][itemId][fieldName] !== undefined
                ? changes[tabName][itemId][fieldName]
                : currentValue;
            
            cell.addEventListener('click', function startEditing() {
                if (cell.querySelector('.cell-input, .cell-select')) return; // Already editing
                
                // Preserve the currently displayed text from the cell before we clear it
                const displayedText = cell.textContent || cell.innerText || '';
                
                let input;
                if (fieldType === 'boolean') {
                    input = document.createElement('input');
                    input.type = 'checkbox';
                    input.checked = actualCurrentValue === true || actualCurrentValue === 'true' || actualCurrentValue === 1;
                } else if (fieldType === 'select') {
                    input = document.createElement('select');
                    input.className = 'cell-select';
                    
                    if (fieldName === 'prerequisite_module_ids' && tabName === 'modules') {
                        input.multiple = true;
                        input.size = Math.min(courseModules.length + 1, 8);
                        input.style.minHeight = '120px';
                        courseModules.forEach(module => {
                            if (module.id !== itemId) {
                                const optionEl = document.createElement('option');
                                optionEl.value = module.id;
                                optionEl.textContent = module.name;
                                const currentPrereqs = Array.isArray(actualCurrentValue) ? actualCurrentValue : 
                                    (actualCurrentValue ? [actualCurrentValue] : []);
                                if (currentPrereqs.includes(module.id) || currentPrereqs.includes(String(module.id))) {
                                    optionEl.selected = true;
                                }
                                input.appendChild(optionEl);
                            }
                        });
                    } else {
                        if (fieldDef && fieldDef.dynamicOptions) {
                            let dataArray = null;
                            if (fieldDef.dataSource === 'assignmentGroups') {
                                dataArray = assignmentGroups;
                            } else if (fieldDef.dataSource === 'courseModules') {
                                dataArray = courseModules;
                            }
                            
                            if (fieldDef.customOptions) {
                                const topOptions = fieldDef.customOptions.filter(opt => opt.position === 'top');
                                topOptions.forEach(customOpt => {
                                    const optionEl = document.createElement('option');
                                    optionEl.value = customOpt.value;
                                    optionEl.textContent = customOpt.label;
                                    if (customOpt.style) {
                                        optionEl.style.cssText = customOpt.style;
                                    }
                                    input.appendChild(optionEl);
                                });
                            }
                            
                            const emptyOption = document.createElement('option');
                            emptyOption.value = '';
                            emptyOption.textContent = '-- Select --';
                            input.appendChild(emptyOption);
                            
                            if (dataArray) {
                                const sortedData = [...dataArray].sort((a, b) => (a.name || '').localeCompare(b.name || ''));
                                sortedData.forEach(item => {
                                    const optionEl = document.createElement('option');
                                    optionEl.value = item.id;
                                    optionEl.textContent = item.name;
                                    if (item.id === actualCurrentValue || String(item.id) === String(actualCurrentValue)) {
                                        optionEl.selected = true;
                                    }
                                    input.appendChild(optionEl);
                                });
                            }
                            
                            if (fieldDef.customOptions) {
                                const bottomOptions = fieldDef.customOptions.filter(opt => opt.position === 'bottom');
                                bottomOptions.forEach(customOpt => {
                                    const optionEl = document.createElement('option');
                                    optionEl.value = customOpt.value;
                                    optionEl.textContent = customOpt.label;
                                    if (customOpt.style) {
                                        optionEl.style.cssText = customOpt.style;
                                    }
                                    input.appendChild(optionEl);
                                });
                            }
                        } else if (fieldDef && fieldDef.options) {
                            fieldDef.options.forEach(option => {
                                const optionEl = document.createElement('option');
                                optionEl.value = option.value;
                                optionEl.textContent = option.label;
                                if (option.value === actualCurrentValue || String(option.value) === String(actualCurrentValue)) {
                                    optionEl.selected = true;
                                }
                                input.appendChild(optionEl);
                            });
                        }
                    }
                } else if (fieldType === 'datetime' || (fieldName.endsWith('_at') && !fieldName.includes('attempts')) || fieldName.includes('date')) {
                    input = document.createElement('input');
                    input.type = 'datetime-local';
                    if (actualCurrentValue) {
                        input.value = formatDateForInput(actualCurrentValue);
                    } else {
                        // Default to today at 11:59 PM (local time)
                        const today = new Date();
                        const year = today.getFullYear();
                        const month = String(today.getMonth() + 1).padStart(2, '0');
                        const day = String(today.getDate()).padStart(2, '0');
                        input.value = `${year}-${month}-${day}T23:59`;
                    }
                    
                    // Auto-set time to 11:59 PM when date changes
                    let lastDateValue = input.value ? input.value.split('T')[0] : null;
                    input.addEventListener('change', function() {
                        if (input.value) {
                            const currentDateValue = input.value.split('T')[0];
                            if (currentDateValue !== lastDateValue) {
                                input.value = `${currentDateValue}T23:59`;
                                lastDateValue = currentDateValue;
                            }
                        }
                    });
                } else if (fieldType === 'number') {
                    input = document.createElement('input');
                    input.type = 'number';
                    // Use displayed text if available (preserves what user sees), otherwise use actualCurrentValue
                    input.value = displayedText.trim() || actualCurrentValue || '';
                    if (fieldName === 'allowed_attempts') {
                        input.placeholder = 'Enter number (-1 for unlimited)';
                        input.title = 'Enter number of attempts allowed. Use -1 for unlimited attempts.';
                    }
                } else {
                    input = document.createElement('input');
                    input.type = 'text';
                    // Use displayed text if available (preserves what user sees), otherwise use actualCurrentValue
                    input.value = displayedText.trim() || actualCurrentValue || '';
                }
                
                input.className = input.className || 'cell-input';
                cell.innerHTML = '';
                cell.appendChild(input);
                
                input.focus();
                if (input.type !== 'checkbox' && input.tagName !== 'SELECT') input.select();
                
                const finishEditing = async (save = true) => {
                    let newValue;
                    if (input.type === 'checkbox') {
                        newValue = input.checked;
                    } else if (input.tagName === 'SELECT') {
                        if (fieldName === 'prerequisite_module_ids' && input.multiple) {
                            const selectedOptions = Array.from(input.selectedOptions);
                            newValue = selectedOptions.map(opt => parseInt(opt.value));
                        } else if (fieldDef && fieldDef.customOptions) {
                            const matchingCustomOption = fieldDef.customOptions.find(opt => opt.value === input.value);
                            if (matchingCustomOption) {
                                if (typeof openAssignmentGroupModal === 'function') {
                                    openAssignmentGroupModal(itemId, tabName);
                                }
                                finishEditing(false);
                                return;
                            }
                            newValue = input.value || null;
                        } else {
                            newValue = input.value || null;
                        }
                    } else if (input.type === 'datetime-local') {
                        newValue = formatDateForAPI(input.value);
                    } else if (input.type === 'number') {
                        newValue = input.value ? parseFloat(input.value) : null;
                    } else {
                        newValue = input.value.trim() || null;
                    }
                    
                    const originalValue = originalData[tabName] && originalData[tabName][itemId] 
                        ? originalData[tabName][itemId][fieldName] 
                        : actualCurrentValue;
                    
                    if (save) {
                        const valueChanged = JSON.stringify(newValue) !== JSON.stringify(originalValue);
                        if (valueChanged) {
                            trackChange(tabName, itemId, fieldName, newValue, originalValue);
                        }
                        displayCellValue(cell, tabName, itemId, fieldName, newValue, fieldType, fieldDef);
                    } else {
                        displayCellValue(cell, tabName, itemId, fieldName, originalValue, fieldType, fieldDef);
                    }
                };
                
                input.addEventListener('blur', () => {
                    if (input.tagName === 'SELECT' && input.value === '__CREATE_NEW__') {
                        return;
                    }
                    finishEditing(true);
                });
                input.addEventListener('keydown', async (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        await finishEditing(true);
                    } else if (e.key === 'Escape') {
                        e.preventDefault();
                        await finishEditing(false);
                    }
                });
                // For select, also finish on change (but handle async for assignment_group_id)
                if (input.tagName === 'SELECT') {
                    input.addEventListener('change', async () => {
                        if (input.value === '__CREATE_NEW__') {
                            openAssignmentGroupModal(itemId, tabName);
                            return;
                        }
                        if (fieldDef && fieldDef.customOptions) {
                            const matchingCustomOption = fieldDef.customOptions.find(opt => opt.value === input.value);
                            if (matchingCustomOption) {
                                return;
                            }
                        }
                        await finishEditing(true);
                    });
                }
            });
        }

        let pendingAssignmentGroupCreation = null;

        function openAssignmentGroupModal(itemId, tabName) {
            pendingAssignmentGroupCreation = { itemId, tabName };
            const modal = document.getElementById('assignmentGroupModal');
            
            if (modal) {
                renderModalTable();
                updateMergeButtonState();
                updateTotalWeightDisplay();
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
        }

        function renderModalTable() {
            const container = document.getElementById('modalGroupTableContainer');
            if (!container) return;
            
            container.innerHTML = '';
            
            const table = document.createElement('table');
            table.className = 'data-table';
            table.id = 'modalAssignmentGroupsTable';
            
            const thead = document.createElement('thead');
            const headerRow = document.createElement('tr');
            
            const checkboxHeader = document.createElement('th');
            checkboxHeader.className = 'checkbox-header';
            checkboxHeader.innerHTML = `<input type="checkbox" class="select-all-checkbox" id="selectAll-modalGroups" onchange="toggleSelectAll('modalGroups', this.checked)">`;
            headerRow.appendChild(checkboxHeader);
            
            const fieldDefs = FIELD_DEFINITIONS['assignment_groups'];
            if (fieldDefs) {
                fieldDefs.forEach(field => {
                    const th = document.createElement('th');
                    th.textContent = field.label;
                    headerRow.appendChild(th);
                });
            }
            
            thead.appendChild(headerRow);
            table.appendChild(thead);
            
            const tbody = document.createElement('tbody');
            tbody.id = 'modalAssignmentGroupsTableBody';
            
            if (!selectedItems['modalGroups']) {
                selectedItems['modalGroups'] = new Set();
            }
            
            assignmentGroups.forEach(group => {
                const itemId = group.id;
                const isChecked = selectedItems['modalGroups'].has(itemId);
                const row = document.createElement('tr');
                
                let rowHTML = `
                    <td class="checkbox-cell">
                        <input type="checkbox" class="row-checkbox" data-tab="modalGroups" data-id="${itemId}" ${isChecked ? 'checked' : ''} onchange="toggleRowSelection('modalGroups', '${itemId}', this.checked); updateMergeButtonState();">
                    </td>
                `;
                
                fieldDefs.forEach(field => {
                    if (field.editable) {
                        rowHTML += `<td data-item-id="${itemId}" data-field="${field.key}"></td>`;
                    } else {
                        const value = group[field.key];
                        rowHTML += `<td class="readonly-cell" data-item-id="${itemId}" data-field="${field.key}">${escapeHtml(value || '-')}</td>`;
                    }
                });
                
                row.innerHTML = rowHTML;
                
                if (isChecked) row.classList.add('selected');
                
                if (!originalData['modalGroups']) originalData['modalGroups'] = {};
                originalData['modalGroups'][itemId] = group;
                
                fieldDefs.forEach(field => {
                    if (field.editable) {
                        const cell = row.querySelector(`[data-field="${field.key}"]`);
                        if (cell) {
                            const value = group[field.key];
                            makeCellEditable(cell, 'modalGroups', itemId, field.key, value, field.type, field);
                            displayCellValue(cell, 'modalGroups', itemId, field.key, value, field.type, field);
                        }
                    }
                });
                
                tbody.appendChild(row);
            });
            
            table.appendChild(tbody);
            container.appendChild(table);
            
            const weightCells = tbody.querySelectorAll('[data-field="group_weight"]');
            weightCells.forEach(cell => {
                const input = cell.querySelector('input');
                if (input) {
                    input.addEventListener('input', updateTotalWeightDisplay);
                    input.addEventListener('change', updateTotalWeightDisplay);
                }
            });
        }

        function updateMergeButtonState() {
            const mergeBtn = document.getElementById('mergeGroupsBtn');
            if (!mergeBtn) return;
            
            const selected = selectedItems['modalGroups'] ? Array.from(selectedItems['modalGroups']) : [];
            mergeBtn.disabled = selected.length < 2;
        }

        function addNewGroupRow() {
            const tbody = document.getElementById('modalAssignmentGroupsTableBody');
            if (!tbody) {
                renderModalTable();
                return;
            }
            
            const tempId = 'new-' + Date.now();
            const newGroup = {
                id: tempId,
                name: '',
                group_weight: 0
            };
            
            assignmentGroups.push(newGroup);
            
            if (!originalData['modalGroups']) originalData['modalGroups'] = {};
            originalData['modalGroups'][tempId] = newGroup;
            
            const fieldDefs = FIELD_DEFINITIONS['assignment_groups'];
            const row = document.createElement('tr');
            
            let rowHTML = `
                <td class="checkbox-cell">
                    <input type="checkbox" class="row-checkbox" data-tab="modalGroups" data-id="${tempId}" onchange="toggleRowSelection('modalGroups', '${tempId}', this.checked); updateMergeButtonState();">
                </td>
            `;
            
            fieldDefs.forEach(field => {
                if (field.editable) {
                    rowHTML += `<td data-item-id="${tempId}" data-field="${field.key}"></td>`;
