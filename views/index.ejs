<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canvas Bulk Editor</title>
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community/dist/ag-grid-community.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <% if (typeof error !== 'undefined' && error) { %>
    <div id="error-overlay" style="display: flex; position: fixed; inset: 0; background: rgba(0,0,0,0.9); align-items: center; justify-content: center;">
        <div style="background: white; padding: 2rem; border-radius: 8px; text-align: center;">
            <h2 style="color: #c00;">Access Error</h2>
            <p><%= error %></p>
            <p><a href="/lti/debug?error=<%= encodeURIComponent(error) %>">View debug log</a></p>
        </div>
    </div>
    <% } %>
    <div id="oauth-overlay" style="display: none;">
        <div class="login-modal">
            <div class="login-content">
                <h2>Canvas Bulk Editor</h2>
                <p>Authorize access to your Canvas courses to continue.</p>
                <a href="/oauth/canvas" class="primary-btn" style="display: inline-block; text-decoration: none; margin-top: 1rem;">Authorize with Canvas</a>
                <p style="margin-top: 1rem; font-size: 0.9rem;"><a href="/lti/debug">View debug log</a></p>
            </div>
        </div>
    </div>
    <div id="token-overlay" style="display: none;">
        <div class="login-modal">
            <div class="login-content">
                <h2>Canvas Bulk Editor</h2>
                <p>Enter your Canvas API token to access your courses.</p>
                
                <form id="loginForm">
                    <div class="form-group">
                        <label for="canvasUrl">Canvas Base URL:</label>
                        <input type="url" id="canvasUrl" name="canvasUrl" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="canvasToken">Canvas API Token:</label>
                        <input type="password" id="canvasToken" name="canvasToken" required>
                        <small>Get your token from Canvas Account > Settings > Approved Integrations</small>
                    </div>
                    
                    <div id="loginError" class="error-message" style="display: none;"></div>
                    
                    <div class="form-actions">
                        <button type="submit" class="primary-btn">Connect</button>
                        <button type="button" class="secondary-btn" onclick="closeLoginModal()">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="main-app-wrapper" style="display: none;">
        <div class="app-container">
            <div class="debug-panel collapsed" id="debugPanel">
                <div class="debug-panel-header" onclick="toggleDebugPanel()">
                    <span>System Debug Monitor</span>
                    <span class="debug-panel-header-right" onclick="event.stopPropagation()">
                        <button type="button" class="debug-copy-btn" onclick="clearDebugLog(event)" title="Clear debug log">Clear</button>
                        <button type="button" id="debugCopyBtn" class="debug-copy-btn" onclick="copyDebugLogToClipboard(event)" title="Copy all log lines">Copy</button>
                        <span id="debugToggle">▲</span>
                    </span>
                </div>
                <div class="debug-panel-content" id="debugContent"></div>
            </div>
            
            <aside class="sidebar">
                <nav class="tab-container" id="tabContainer">
                    <div class="tab-card">
                        <span class="tab-card-label">Canvas Objects</span>
                        <button class="tab-btn active" onclick="switchTab('assignments')">Assignments</button>
                        <button class="tab-btn" onclick="switchTab('modules')">Modules</button>
                        <button class="tab-btn" onclick="switchTab('pages')">Pages</button>
                        <button class="tab-btn" onclick="switchTab('quizzes')">Quizzes</button>
                        <button class="tab-btn" onclick="switchTab('new_quizzes')">New Quizzes</button>
                        <button class="tab-btn" onclick="switchTab('discussions')">Discussions</button>
                        <button class="tab-btn" onclick="switchTab('announcements')">Announcements</button>
                        <button class="tab-btn" onclick="switchTab('files')">Files</button>
                    </div>
                    <div class="tab-card">
                        <span class="tab-card-label">Review and Alignment</span>
                        <button class="tab-btn" onclick="switchTab('ada_compliance')">ADA Compliance Sync</button>
                        <button class="tab-btn" onclick="switchTab('standards_sync')">Standards Sync</button>
                    </div>
                </nav>
            </aside>

            <main class="main-content">
                <header class="toolbar">
                    <select id="courseSelect" onchange="onCourseSelected()">
                        <option value="">Select a Course</option>
                    </select>
                    <div class="toolbar-actions">
                        <div class="dropdown-container">
                            <button class="primary-btn dropdown-trigger" onclick="toggleDropdown('bulkActionsDropdown')">
                                Bulk Actions ▼
                            </button>
                            <div id="bulkActionsDropdown" class="dropdown-menu">
                                <div class="dropdown-item" onclick="openModal('searchReplaceModal'); closeDropdown('bulkActionsDropdown')">Search & Replace</div>
                                <div class="dropdown-item" onclick="openModal('dateShiftModal'); closeDropdown('bulkActionsDropdown')">Date Shift</div>
                                <div id="pointsMenuItem" class="dropdown-item" onclick="openModal('pointsModal'); closeDropdown('bulkActionsDropdown')">Points</div>
                                <div id="positionMenuItem" class="dropdown-item" onclick="openModal('pointsModal'); closeDropdown('bulkActionsDropdown')" style="display: none;">Position</div>
                                <div id="timeLimitMenuItem" class="dropdown-item" onclick="openModal('timeLimitModal'); closeDropdown('bulkActionsDropdown')" style="display: none;">Time Limit</div>
                                <div id="allowedAttemptsMenuItem" class="dropdown-item" onclick="openModal('allowedAttemptsModal'); closeDropdown('bulkActionsDropdown')" style="display: none;">Allowed Attempts</div>
                                <div id="allowRatingMenuItem" class="dropdown-item" onclick="openModal('allowRatingModal'); closeDropdown('bulkActionsDropdown')" style="display: none;">Add Rating</div>
                                <div id="assignmentGroupMenuItem" class="dropdown-item" onclick="openModal('assignmentGroupModal'); closeDropdown('bulkActionsDropdown')">Assignment Group</div>
                                <div id="publishMenuItem" class="dropdown-item" onclick="openModal('publishModal'); closeDropdown('bulkActionsDropdown')">Publish</div>
                                <div class="dropdown-item" onclick="handleCloneClick(); closeDropdown('bulkActionsDropdown')">Clone</div>
                                <div id="mergeMenuItem" class="dropdown-item" onclick="populateMergeSelector(); openModal('mergeModal'); closeDropdown('bulkActionsDropdown')" style="display: none;">Merge Modules</div>
                                <div id="deleteMenuItem" class="dropdown-item" onclick="handleDeleteClick(); closeDropdown('bulkActionsDropdown')">Delete</div>
                                <div id="fixMenuItem" class="dropdown-item" onclick="generateAccessibilityFixPreview(); closeDropdown('bulkActionsDropdown')" style="display: none;">Fix</div>
                            </div>
                        </div>
                        <button class="primary-btn" onclick="openModal('columnVisibilityModal')">Columns</button>
                    </div>
                    <button class="primary-btn" onclick="syncChanges()">Sync Changes</button>
                    <button id="revertLastSyncBtn" class="primary-btn" onclick="openRevertLastSyncModal()" style="display: none;">Revert Last Sync</button>
                    <button id="syncHistoryIndicator" class="primary-btn" onclick="openSyncHistoryModal()" style="display: none;">Last sync: none</button>
                    <button class="primary-btn" onclick="refreshCurrentTab()">Refresh</button>
                    <button class="primary-btn" onclick="openModal('modeSelectionModal')" title="Application Mode Settings">⚙️ Mode</button>
                </header>
                <div id="safetyBanner" style="margin: 10px 0 12px 0; padding: 10px 12px; border: 1px solid #d9b300; background: #fff8db; border-radius: 6px; color: #4a3d00; font-size: 14px; line-height: 1.4; display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;">
                    <div style="flex: 1;">
                        ⚠️ <strong>Important:</strong> This tool makes direct changes to your Canvas courses via the API. Cell edits and bulk actions can be reverted using the Sync History panel. Delete operations are permanent and cannot be undone — folder deletion is disabled entirely due to its recursive nature. Always verify your selections before syncing or deleting. Use a sandbox course for testing.
                        <div style="margin-top: 8px;">
                            <label style="display: inline-flex; align-items: center; gap: 6px; cursor: pointer; font-weight: normal;">
                                <input type="checkbox" id="safetyBannerDontShowAgain">
                                Do not show again
                            </label>
                        </div>
                    </div>
                    <button type="button" id="safetyBannerDismiss" style="flex-shrink: 0; padding: 4px 10px; background: #d9b300; border: 1px solid #b89400; border-radius: 4px; color: #4a3d00; cursor: pointer; font-size: 13px;">Hide</button>
                </div>
                <div id="tabContentArea">
                    <div id="myGrid" class="ag-theme-quartz" style="height: 500px; width: 100%;"></div>
                    <div id="accessibilityPanel" class="standards-sync-panel" style="display: none;">
                        <section class="acc-section acc-profile">
                            <h3>Accessibility Scan</h3>
                            <div id="accessibilitySummaryContent">
                                <p>Select a course, then run an accessibility scan.</p>
                            </div>
                        </section>
                        <section class="acc-section acc-outcomes">
                            <h3>Findings</h3>
                            <div id="accessibilityFindingsContent">
                                <p>No scan has been run yet.</p>
                            </div>
                        </section>
                    </div>
                    <div id="standardsSyncPanel" class="standards-sync-panel" style="display: none;">
                        <section class="acc-section acc-profile">
                            <h3>Accreditation Profile</h3>
                            <div id="accProfileContent">Loading...</div>
                        </section>
                        <section class="acc-section acc-workflow">
                            <h3>Workflow</h3>
                            <div id="accWorkflowContent">Loading...</div>
                        </section>
                        <section class="acc-section acc-outcomes">
                            <h3>Outcomes &amp; Standards</h3>
                            <div id="accOutcomesContent">Loading...</div>
                        </section>
                        <section class="acc-section acc-placeholder">
                            <h3>Content Alignment</h3>
                            <div id="accAlignmentContent">Loading...</div>
                        </section>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Include Modals Partial -->
    <%- include('partials/modals.ejs') %>

    <script>
        // Wrapping the EJS tag in quotes tells the JS engine this is a string,
        // which usually stops the 'identifier expected' red squiggles.
        window.SERVER_DATA = {
            courseId: "<%= typeof courseId !== 'undefined' ? courseId : '' %>"
        };
        window.MODE_PASSWORD = "<%= typeof modePassword !== 'undefined' ? modePassword : 'dev2025' %>";
    </script>

    <script src="/js/auth.js"></script>
    <script src="/js/config.js"></script>
    <script src="/js/helpers.js"></script>
    <script src="/js/utils.js"></script>
    <script src="/js/main.js"></script>
    <script>
        (function() {
            var key = 'bulkeditor:safetyBannerHidden';
            document.addEventListener('DOMContentLoaded', function() {
                var banner = document.getElementById('safetyBanner');
                var dismiss = document.getElementById('safetyBannerDismiss');
                var checkbox = document.getElementById('safetyBannerDontShowAgain');
                if (!banner || !dismiss) return;
                if (localStorage.getItem(key) === 'true') {
                    banner.style.display = 'none';
                    return;
                }
                dismiss.addEventListener('click', function() {
                    if (checkbox && checkbox.checked) localStorage.setItem(key, 'true');
                    banner.style.display = 'none';
                });
            });
        })();
    </script>
</body>
</html>