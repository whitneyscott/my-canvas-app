<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canvas LMS Bulk Editor</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <h1>Canvas LMS Bulk Editor</h1>
        
        <div class="course-selector">
            <select id="courseSelect" onchange="loadCourseData()">
                <option value="">-- Select a Course --</option>
            </select>
            <div class="course-loading hidden" id="courseLoading">
                <span class="spinner"></span>
                <span>Loading courses...</span>
            </div>
            <div class="course-details hidden" id="courseDetails">
                <div class="course-details-loading hidden" id="courseDetailsLoading">
                    <span class="spinner"></span>
                    <span>Loading course details...</span>
                </div>
                <h2 id="courseName"></h2>
                <p><strong>Course Code:</strong> <span id="courseCode"></span></p>
                <p><strong>Start Date:</strong> <span id="startDate"></span></p>
                <p><strong>End Date:</strong> <span id="endDate"></span></p>
                <p><strong>Created:</strong> <span id="createdAt"></span></p>
            </div>
            <button 
                id="testButton"
                class="btn-test-disabled"
                disabled
                onclick="handleRunAutomatedTest()"
            >
                Run Editing Test
            </button>
        </div>
        
        <!-- Date Shift Modal -->
        <div class="modal-overlay" id="dateShiftModal" onclick="if(event.target === this) closeModal('dateShiftModal')">
            <div class="modal" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <h2>Date Shift</h2>
                    <button class="modal-close" onclick="closeModal('dateShiftModal')">×</button>
                </div>
                <div class="modal-content">
                    <!-- Section A: Calculator -->
                    <div class="modal-form-group" style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #ddd;">
                        <h3 style="margin-bottom: 15px; color: #2d3e50; font-size: 16px;">Calculator</h3>
                        <div class="modal-form-group">
                            <label for="oldSemesterStart">Old Semester Start:</label>
                            <input type="date" id="oldSemesterStart">
                        </div>
                        <div class="modal-form-group">
                            <label for="newSemesterStart">New Semester Start:</label>
                            <input type="date" id="newSemesterStart">
                        </div>
                        <button class="modal-btn modal-btn-secondary" onclick="calculateDateDiff()" style="width: 100%; margin-top: 10px;">Calculate Shift</button>
                    </div>
                    
                    <!-- Section B: Shift Value -->
                    <div class="modal-form-group" style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #ddd;">
                        <h3 style="margin-bottom: 15px; color: #2d3e50; font-size: 16px;">Shift Value</h3>
                        <div class="modal-form-group">
                            <label for="dateShiftDays">Total Days to Shift:</label>
                            <input type="number" id="dateShiftDays" value="0" step="1">
                            <small style="color: #666; display: block; margin-top: 5px;">Positive values add days, negative subtracts</small>
                        </div>
                    </div>
                    
                    <!-- Section C: Date Fields -->
                    <div class="modal-form-group" style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #ddd;">
                        <h3 style="margin-bottom: 15px; color: #2d3e50; font-size: 16px;">Date Fields</h3>
                        <div class="modal-form-group">
                            <label style="display: block; margin-bottom: 10px; color: #555; font-weight: 500;">Select Date Fields to Shift:</label>
                            <div id="dateShiftFieldsContainer" style="display: flex; flex-direction: column; gap: 8px; max-height: 200px; overflow-y: auto; padding: 10px; border: 1px solid #ddd; border-radius: 4px; background: #f9f9f9;">
                                <!-- Checkboxes will be populated dynamically -->
                            </div>
                        </div>
                    </div>
                    
                    <!-- Section D: Scope -->
                    <div class="modal-form-group">
                        <h3 style="margin-bottom: 15px; color: #2d3e50; font-size: 16px;">Scope</h3>
                        <div style="display: flex; flex-direction: column; gap: 12px;">
                            <label style="display: flex; align-items: center; cursor: pointer; padding: 8px; border-radius: 4px; transition: background 0.2s;">
                                <input type="radio" name="dateShiftScope" value="selected" checked style="margin-right: 10px; width: 18px; height: 18px; cursor: pointer; flex-shrink: 0;">
                                <span style="font-size: 14px; color: #333;">Apply to Selected Rows</span>
                            </label>
                            <label style="display: flex; align-items: center; cursor: pointer; padding: 8px; border-radius: 4px; transition: background 0.2s;">
                                <input type="radio" name="dateShiftScope" value="all" style="margin-right: 10px; width: 18px; height: 18px; cursor: pointer; flex-shrink: 0;">
                                <span style="font-size: 14px; color: #333;">Apply to All Rows</span>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="modal-btn modal-btn-secondary" onclick="closeModal('dateShiftModal')">Cancel</button>
                    <button class="modal-btn modal-btn-primary" onclick="applyDateShift()">Apply</button>
                </div>
            </div>
        </div>
        
        <!-- Accommodation Command Center Modal -->
        <div class="modal-overlay" id="accommodationCommandModal" onclick="if(event.target === this) closeModal('accommodationCommandModal')">
            <div class="modal" onclick="event.stopPropagation()" style="max-width: 900px;">
                <div class="modal-header">
                    <h2>Accommodation Command Center</h2>
                    <button class="modal-close" onclick="closeModal('accommodationCommandModal')">×</button>
                </div>
                <div class="modal-content">
                    <!-- Accommodation Types Selection -->
                    <div class="modal-form-group" style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #ddd;">
                        <h3 style="margin-bottom: 15px; color: #2d3e50; font-size: 16px;">Select Accommodation Types</h3>
                        <div id="accommodationTypesContainer" style="display: flex; flex-direction: column; gap: 8px; max-height: 200px; overflow-y: auto; padding: 10px; border: 1px solid #ddd; border-radius: 4px; background: #f9f9f9;">
                            <!-- Checkboxes will be populated dynamically -->
                        </div>
                    </div>
                    
                    <!-- Plan of Action Preview -->
                    <div class="modal-form-group" style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #ddd;">
                        <h3 style="margin-bottom: 15px; color: #2d3e50; font-size: 16px;">Plan of Action</h3>
                        <div id="accommodationPlanPreview" style="padding: 12px; background: #f0f7ff; border: 1px solid #b3d9ff; border-radius: 4px; font-size: 13px; line-height: 1.6; color: #333; min-height: 60px;">
                            Select accommodation types to see the plan...
                        </div>
                    </div>
                    
                    <!-- Progress Log -->
                    <div class="modal-form-group" style="margin-bottom: 25px; display: none;" id="accommodationProgressContainer">
                        <h3 style="margin-bottom: 15px; color: #2d3e50; font-size: 16px;">Progress Log</h3>
                        <div id="accommodationProgressLog" style="padding: 12px; background: #f9f9f9; border: 1px solid #ddd; border-radius: 4px; font-size: 12px; line-height: 1.5; color: #333; max-height: 300px; overflow-y: auto; font-family: monospace;">
                            <!-- Progress messages will appear here -->
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="modal-btn modal-btn-secondary" onclick="closeModal('accommodationCommandModal')">Cancel</button>
                    <button class="modal-btn modal-btn-primary" id="accommodationExecuteBtn" onclick="executeAccommodations()">Execute Accommodations</button>
                </div>
            </div>
        </div>
        
        <!-- Assignment Group Modal -->
        <div class="modal-overlay" id="assignmentGroupModal" onclick="if(event.target === this) closeModal('assignmentGroupModal')">
            <div class="modal" onclick="event.stopPropagation()" style="max-width: 900px;">
                <div class="modal-header">
                    <h2>Assignment Group Manager</h2>
                    <button class="modal-close" onclick="closeModal('assignmentGroupModal')">&times;</button>
                </div>
                <div class="modal-content">
                    <div style="margin-bottom: 15px;">
                        <button class="sidebar-btn" onclick="addNewGroupRow()" style="width: 100%;">
                            + Create New Group
                        </button>
                    </div>
                    <div id="modalGroupTableContainer" style="margin-bottom: 20px;">
                    </div>
                    <div style="margin-bottom: 20px;">
                        <button id="mergeGroupsBtn" class="sidebar-btn" onclick="handleMergeGroups()" disabled style="width: 100%;">
                            Merge Selected
                        </button>
                    </div>
                    <div style="padding-top: 15px; border-top: 1px solid #ddd; font-weight: bold;">
                        <span>Total Weight: </span>
                        <span id="totalWeightDisplay">0.00%</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="modal-btn modal-btn-secondary" onclick="closeModal('assignmentGroupModal')">Cancel</button>
                    <button class="modal-btn modal-btn-primary" onclick="saveAssignmentGroups()">Save</button>
                </div>
            </div>
        </div>
        
        <!-- Module Delete Options Modal -->
        <div class="modal-overlay" id="moduleDeleteOptionsModal" onclick="if(event.target === this) closeModal('moduleDeleteOptionsModal')">
            <div class="modal" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <h2>Delete Module(s)</h2>
                    <button class="modal-close" onclick="closeModal('moduleDeleteOptionsModal')">&times;</button>
                </div>
                <div class="modal-content">
                    <p id="moduleDeleteMessage" style="margin-bottom: 20px;"></p>
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                        <button id="deleteModuleOnlyBtn" class="modal-btn modal-btn-secondary" style="width: 100%;">
                            Delete Module Only
                        </button>
                        <button id="deleteModuleAndItemsBtn" class="modal-btn modal-btn-primary" style="width: 100%; background: var(--danger);">
                            Delete Module and All Items
                        </button>
                        <button class="modal-btn modal-btn-secondary" onclick="closeModal('moduleDeleteOptionsModal')" style="width: 100%;">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Search and Replace Modal -->
        <div class="modal-overlay" id="searchReplaceModal" onclick="if(event.target === this) closeModal('searchReplaceModal')">
            <div class="modal" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <h2>Search & Replace</h2>
                    <button class="modal-close" onclick="closeModal('searchReplaceModal')">×</button>
                </div>
                <div class="modal-content">
                    <div id="searchReplaceSummary" class="modal-confirm-summary"></div>
                    <div class="modal-form-group">
                        <label for="searchReplaceFind">Find:</label>
                        <input type="text" id="searchReplaceFind" placeholder="Text to find">
                    </div>
                    <div class="modal-form-group">
                        <label for="searchReplaceWith">Replace With:</label>
                        <input type="text" id="searchReplaceWith" placeholder="Replacement text">
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="modal-btn modal-btn-secondary" onclick="closeModal('searchReplaceModal')">Cancel</button>
                    <button class="modal-btn modal-btn-primary" onclick="applySearchReplace()">Apply Search & Replace</button>
                </div>
            </div>
        </div>
        
        <!-- Duplicate Quantity Modal -->
        <div class="modal-overlay" id="duplicateQuantityModal" onclick="if(event.target === this) closeModal('duplicateQuantityModal')">
            <div class="modal" onclick="event.stopPropagation()" style="max-width: 400px;">
                <div class="modal-header">
                    <h2>Duplicate Items</h2>
                    <button class="modal-close" onclick="closeModal('duplicateQuantityModal')">×</button>
                </div>
                <div class="modal-content">
                    <div class="modal-form-group">
                        <label for="duplicateQuantity">How many copies of each selected item would you like to create?</label>
                        <input type="number" id="duplicateQuantity" min="1" max="100" value="1" style="width: 100%; padding: 8px 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 14px;">
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="modal-btn modal-btn-secondary" onclick="closeModal('duplicateQuantityModal')">Cancel</button>
                    <button class="modal-btn modal-btn-primary" onclick="proceedWithDuplication()">Create Copies</button>
                </div>
            </div>
        </div>
        
        <!-- Module Three-Way Clone Modal -->
        <div class="modal-overlay" id="moduleCloneModal" onclick="if(event.target === this) closeModal('moduleCloneModal')">
            <div class="modal" onclick="event.stopPropagation()" style="max-width: 600px;">
                <div class="modal-header">
                    <h2>Clone Module: Choose Method</h2>
                    <button class="modal-close" onclick="closeModal('moduleCloneModal')">×</button>
                </div>
                <div class="modal-content">
                    <div class="modal-form-group">
                        <p style="margin-bottom: 20px; color: #555;">Select how you want to clone the selected module(s):</p>
                        <div style="display: flex; flex-direction: column; gap: 15px;">
                            <label style="display: flex; align-items: flex-start; cursor: pointer; padding: 15px; border: 2px solid #ddd; border-radius: 8px; transition: all 0.2s;" onmouseover="this.style.borderColor='#2196F3'; this.style.backgroundColor='#f0f7ff';" onmouseout="this.style.borderColor='#ddd'; this.style.backgroundColor='transparent';">
                                <input type="radio" name="cloneType" value="structureOnly" style="margin-right: 12px; margin-top: 3px; width: 18px; height: 18px; cursor: pointer;" checked>
                                <div style="flex: 1;">
                                    <div style="font-weight: 600; margin-bottom: 5px; color: #2d3e50;">Structure Only</div>
                                    <div style="font-size: 13px; color: #666; line-height: 1.5;">Create a new, empty module with an incremented name (e.g., "Week 1" → "Week 2"). No content is copied.</div>
                                </div>
                            </label>
                            <label style="display: flex; align-items: flex-start; cursor: pointer; padding: 15px; border: 2px solid #ddd; border-radius: 8px; transition: all 0.2s;" onmouseover="this.style.borderColor='#2196F3'; this.style.backgroundColor='#f0f7ff';" onmouseout="this.style.borderColor='#ddd'; this.style.backgroundColor='transparent';">
                                <input type="radio" name="cloneType" value="structureShared" style="margin-right: 12px; margin-top: 3px; width: 18px; height: 18px; cursor: pointer;">
                                <div style="flex: 1;">
                                    <div style="font-weight: 600; margin-bottom: 5px; color: #2d3e50;">Structure + Shared Content</div>
                                    <div style="font-size: 13px; color: #666; line-height: 1.5;">Create a new module and add links to the existing assignments/pages/quizzes. Points to the original source items.</div>
                                </div>
                            </label>
                            <label style="display: flex; align-items: flex-start; cursor: pointer; padding: 15px; border: 2px solid #ddd; border-radius: 8px; transition: all 0.2s;" onmouseover="this.style.borderColor='#2196F3'; this.style.backgroundColor='#f0f7ff';" onmouseout="this.style.borderColor='#ddd'; this.style.backgroundColor='transparent';">
                                <input type="radio" name="cloneType" value="deepCopy" style="margin-right: 12px; margin-top: 3px; width: 18px; height: 18px; cursor: pointer;">
                                <div style="flex: 1;">
                                    <div style="font-weight: 600; margin-bottom: 5px; color: #2d3e50;">Deep Copy (Full Content)</div>
                                    <div style="font-size: 13px; color: #666; line-height: 1.5;">Create a new module AND brand-new clones of every assignment, quiz, and page inside it, then link those new clones to the new module.</div>
                                </div>
                            </label>
                        </div>
                    </div>
                    <div id="moduleCloneProgressContainer" style="display: none; margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee;">
                        <div style="margin-bottom: 10px; font-weight: 500; color: #2d3e50;">Progress:</div>
                        <div style="background: #f0f0f0; border-radius: 4px; height: 24px; overflow: hidden; margin-bottom: 10px;">
                            <div id="moduleCloneProgressBar" style="background: #2196F3; height: 100%; width: 0%; transition: width 0.3s; display: flex; align-items: center; justify-content: center; color: white; font-size: 12px; font-weight: 500;">0%</div>
                        </div>
                        <div id="moduleCloneProgressText" style="font-size: 13px; color: #666; font-family: monospace; max-height: 150px; overflow-y: auto; padding: 10px; background: #f9f9f9; border-radius: 4px;"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="modal-btn modal-btn-secondary" onclick="closeModal('moduleCloneModal')">Cancel</button>
                    <button class="modal-btn modal-btn-primary" id="moduleCloneExecuteBtn" onclick="executeModuleClone()">Clone Module(s)</button>
                </div>
            </div>
        </div>
        
        <!-- File Operations Modal -->
        <div class="modal-overlay" id="fileOperationsModal" onclick="if(event.target === this) closeModal('fileOperationsModal')">
            <div class="modal" onclick="event.stopPropagation()" style="max-width: 700px;">
                <div class="modal-header">
                    <h2>File Operations</h2>
                    <button class="modal-close" onclick="closeModal('fileOperationsModal')">×</button>
                </div>
                <div class="modal-content">
                    <div class="modal-form-group" style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #ddd;">
                        <h3 style="margin-bottom: 15px; color: #2d3e50; font-size: 16px;">Selected Files</h3>
                        <div id="fileOperationsFileList" style="max-height: 200px; overflow-y: auto; padding: 10px; border: 1px solid #ddd; border-radius: 4px; background: #f9f9f9;">
                        </div>
                    </div>
                    
                    <div class="modal-form-group" style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #ddd;">
                        <h3 style="margin-bottom: 15px; color: #2d3e50; font-size: 16px;">Actions</h3>
                        <div style="display: flex; flex-direction: column; gap: 12px;">
                            <button class="modal-btn modal-btn-primary" onclick="executeFileDownload()" style="width: 100%;">Download Selected</button>
                            <button class="modal-btn modal-btn-secondary" onclick="showFileRenameOptions()" style="width: 100%;">Rename Selected</button>
                            <button class="modal-btn" onclick="executeFileDelete()" style="width: 100%; background: #dc3545; color: white;">Delete Selected</button>
                        </div>
                    </div>
                    
                    <div id="fileRenameOptions" style="display: none; margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee;">
                        <div class="modal-form-group">
                            <label for="fileRenamePattern">Rename Pattern:</label>
                            <input type="text" id="fileRenamePattern" placeholder="Enter new name (for single file) or pattern" style="width: 100%; padding: 8px 12px; border: 1px solid #ddd; border-radius: 4px;">
                            <small style="color: #666; display: block; margin-top: 5px;">For single file: enter new name. For multiple files: use {name} for original name, {ext} for extension.</small>
                        </div>
                        <button class="modal-btn modal-btn-primary" onclick="executeFileRename()" style="width: 100%; margin-top: 10px;">Apply Rename</button>
                    </div>
                    
                    <div id="fileOperationsProgressContainer" style="display: none; margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee;">
                        <div style="margin-bottom: 10px; font-weight: 500; color: #2d3e50;">Progress:</div>
                        <div id="fileOperationsProgressText" style="font-size: 13px; color: #666; font-family: monospace; max-height: 150px; overflow-y: auto; padding: 10px; background: #f9f9f9; border-radius: 4px;"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="modal-btn modal-btn-secondary" onclick="closeModal('fileOperationsModal')">Close</button>
                </div>
            </div>
        </div>
        
        <!-- Publish Status Modal -->
        <div class="modal-overlay" id="publishStatusModal" onclick="if(event.target === this) closeModal('publishStatusModal')">
            <div class="modal" onclick="event.stopPropagation()">
                <div class="modal-header">
                    <h2>Publish Status</h2>
                    <button class="modal-close" onclick="closeModal('publishStatusModal')">×</button>
                </div>
                <div class="modal-content">
                    <div id="publishStatusSummary" class="modal-confirm-summary"></div>
                    <p>Change publish status for all selected items?</p>
                </div>
                <div class="modal-footer">
                    <button class="modal-btn modal-btn-secondary" onclick="closeModal('publishStatusModal')">Cancel</button>
                    <button class="modal-btn modal-btn-primary" id="publishStatusBtn" onclick="applyPublishStatus()">Apply</button>
                </div>
            </div>
        </div>
        
        <div class="main-content-wrapper">
            <div class="main-content">
                <div class="tabs-container hidden" id="tabsContainer">
            <div class="tabs">
                <button class="tab-button active" onclick="switchTab('students')">Students</button>
                <button class="tab-button" onclick="switchTab('quizzes')">Quizzes</button>
                <button class="tab-button" onclick="switchTab('assignments')">Assignments</button>
                <button class="tab-button" onclick="switchTab('discussions')">Discussions</button>
                <button class="tab-button" onclick="switchTab('pages')">Pages</button>
                <button class="tab-button" onclick="switchTab('announcements')">Announcements</button>
                <button class="tab-button" onclick="switchTab('modules')">Modules</button>
                <button class="tab-button" onclick="switchTab('files')">Files</button>
                <button class="tab-button" onclick="switchTab('accommodations')">Accommodations</button>
                <button class="tab-button" onclick="switchTab('test-report')">Editing Test Report</button>
            </div>
            
            <%
            // Tabs configuration
            const tabs = [
                { 
                    name: 'students', 
                    displayName: 'Students', 
                    isActive: true,
                    customThead: ['Last Name', 'First Name', 'Student ID', 'SIS User ID', 'Enrollment State', 'Accommodations']
                },
                { 
                    name: 'quizzes', 
                    displayName: 'Quizzes', 
                    isActive: false
                },
                { 
                    name: 'assignments', 
                    displayName: 'Assignments', 
                    isActive: false
                },
                { 
                    name: 'discussions', 
                    displayName: 'Discussions', 
                    isActive: false
                },
                { 
                    name: 'pages', 
                    displayName: 'Pages', 
                    isActive: false,
                    customThead: ['title', 'url', 'preview', 'view', 'published', 'front_page', 'editing_roles', 'notify_of_update', 'locked_for_user']
                },
                { 
                    name: 'announcements', 
                    displayName: 'Announcements', 
                    isActive: false
                },
                { 
                    name: 'modules', 
                    displayName: 'Modules', 
                    isActive: false,
                    customThead: ['name', 'items_count', 'published', 'unlock_at', 'position']
                },
                { 
                    name: 'files', 
                    displayName: 'Files', 
                    isActive: false,
                    customThead: ['Name', 'Location', 'Type', 'Size', 'Modified', 'Used By']
                },
                { 
                    name: 'accommodations', 
                    displayName: 'Accommodations', 
                    isActive: false,
                    customThead: ['Type', 'Assignment/Quiz', 'Students', 'Due Date', 'Unlock Date']
                }
            ];
            %>
            
            <% tabs.forEach(tab => { %>
                <%- include('partials/tab', { tab }) %>
            <% }); %>
            
            <!-- Editing Test Report Tab -->
            <div class="tab-content" id="tab-test-report">
                <div class="tab-header">
                    <div class="count-badge" id="test-reportCount">0 results</div>
                </div>
                <div class="table-container">
                    <table class="data-table" id="test-reportTable">
                        <thead>
                            <tr>
                                <th>Endpoint</th>
                                <th>Parameter</th>
                                <th>Result</th>
                                <th>Error Message</th>
                            </tr>
                        </thead>
                        <tbody id="test-reportTableBody"></tbody>
                    </table>
                </div>
            </div>
                </div>
            </div>
            
            <!-- Sidebar -->
            <div class="sidebar hidden" id="sidebar">
                <div class="sidebar-header">
                    <h2>Command Center</h2>
                </div>
                <div class="sidebar-content">
                    <div id="sidebarEmptyState" class="sidebar-empty-state hidden">
                        Select rows to edit
                    </div>
                    <div id="sidebarEditMode" class="hidden">
                        <div style="margin-bottom: 20px;">
                            <label for="editModeDropdown" style="display: block; margin-bottom: 10px; color: #555; font-weight: 500;">Bulk Actions:</label>
                            <div style="position: relative;">
                                <select id="editModeDropdown" class="sidebar-dropdown" onchange="handleEditModeChange()">
                                    <option value="">-- Select an action --</option>
                                    <option value="accommodations">Apply Accommodations</option>
                                    <option value="assignTo" id="assignToOption">Assign To</option>
                                    <option value="dateShift">Date Shift</option>
                                    <option value="publishStatus">Publish Status</option>
                                    <option value="searchReplace">Search & Replace</option>
                                </select>
                                <span id="assignToInfoIcon" class="assign-to-info-icon" style="display: none; position: absolute; right: 25px; top: 50%; transform: translateY(-50%); color: #6c757d; cursor: help; font-size: 14px;" title="Canvas only supports individual student assignments for graded items (Assignments, Quizzes, and Graded Discussions).">ℹ️</span>
                            </div>
                        </div>
                        <div style="margin-bottom: 20px;">
                            <label for="viewOptionsDropdown" style="display: block; margin-bottom: 10px; color: #555; font-weight: 500;">View Options:</label>
                            <select id="viewOptionsDropdown" class="sidebar-dropdown" onchange="handleViewOptionChange()">
                                <option value="">-- Select an option --</option>
                                <option value="filterRows">Filter Rows</option>
                                <option value="columnVisibility">Hide/Show Columns</option>
                            </select>
                        </div>
                        <div style="margin-bottom: 20px; padding-top: 20px; border-top: 1px solid #ddd;">
                            <label style="display: block; margin-bottom: 10px; color: #555; font-weight: 500;">Content Duplication and Deletion:</label>
                            <button id="duplicateSelectedBtn" class="sidebar-btn" onclick="handleDuplicateSelected()" disabled style="width: 100%; margin-bottom: 10px;">
                                ➕ Duplicate Selected
                            </button>
                            <button id="deleteSelectedBtn" class="sidebar-btn sidebar-btn-danger" onclick="handleDeleteSelected()" disabled style="width: 100%;">
                                🗑️ Delete Selected
                            </button>
                        </div>
                    </div>
                    <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #ddd;">
                        <button class="sync-btn" id="sync-sidebar" onclick="syncCurrentTab()" disabled style="width: 100%;">
                            <span>💾</span>
                            Sync to Canvas
                            <span class="changes-count hidden" id="changesCount-sidebar">0</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Debug Panel -->
        <div class="debug-panel collapsed" id="debugPanel">
            <div class="debug-panel-header" onclick="toggleDebugPanel()">
                <span>Debug Log</span>
                <span id="debugToggle">▲</span>
            </div>
            <div class="debug-panel-content" id="debugContent"></div>
        </div>

    <script>
        (function() {
            const originalFetch = window.fetch;
            const API_BASE = '/bulk-canvas-editor';

            window.fetch = function(url, options) {
                if (typeof url === 'string' && url.startsWith('/canvas') && !url.startsWith(API_BASE)) {
                    url = API_BASE + url;
                }
                return originalFetch(url, options);
            };
        })();
        function getEditableFields(tabName) {
            const fieldDefs = FIELD_DEFINITIONS[tabName];
            if (fieldDefs) {
                // Extract editable field keys from FIELD_DEFINITIONS
                return fieldDefs.filter(field => field.editable).map(field => field.key);
            }
            
            // Fallback for tabs without FIELD_DEFINITIONS
            const fallbackFields = {
                pages: ['title', 'published', 'front_page'],
                modules: ['name', 'published', 'unlock_at', 'position', 'require_sequential_progress'],
                students: [],
                accommodations: []
            };
            return fallbackFields[tabName] || [];
        }

        // Centralized date formatting functions
        function formatDateForDisplay(dateString) {
            if (!dateString) return '-';
            const date = new Date(dateString);
            return date.toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'short', 
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function formatDateForInput(dateString) {
            // Convert Canvas API date (ISO string) to datetime-local format (local time)
            if (!dateString) return '';
            const date = new Date(dateString);
            if (isNaN(date.getTime())) return '';
            
            // Format as YYYY-MM-DDTHH:MM in local time
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');
            return `${year}-${month}-${day}T${hours}:${minutes}`;
        }

        function formatDateForAPI(inputValue) {
            // Convert datetime-local input value to ISO string for Canvas API
            if (!inputValue) return null;
            try {
                const date = new Date(inputValue);
                if (isNaN(date.getTime())) return null;
                return date.toISOString();
            } catch (e) {
                return null;
            }
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function toggleDebugPanel() {
            const panel = document.getElementById('debugPanel');
            const toggle = document.getElementById('debugToggle');
            panel.classList.toggle('collapsed');
            toggle.textContent = panel.classList.contains('collapsed') ? '▲' : '▼';
        }

        function debugLog(message, type = 'info') {
            const content = document.getElementById('debugContent');
            const time = new Date().toLocaleTimeString();
            const logEntry = document.createElement('div');
            logEntry.className = `debug-log ${type}`;
            logEntry.textContent = `[${time}]${type !== 'info' ? ' ' + type.toUpperCase() + ':' : ''} ${message}`;
            content.appendChild(logEntry);
            content.scrollTop = content.scrollHeight;
            console.log(`[${type.toUpperCase()}]`, message);
        }

        let currentCourseId = null;
        let isTesting = false;
        const loadedTabs = new Set();
        const selectedItems = {};
        const changes = {};
        const originalData = {};
        let assignmentGroups = []; // Store assignment groups for the current course
        let courseModules = []; // Store modules for the current course
        const filters = {}; // Store filter state: { tabName: { fieldKey: filterValue } }
        const sortState = {}; // Store sort state: { tabName: { field: 'fieldKey', direction: 'asc'|'desc'|null } }

        // Table keyboard navigation function
        function initializeTableKeyboard(tableElement) {
            if (!tableElement) return;

            let activeCell = null;
            let anchorCell = null; // Anchor cell for range selection
            let selectedCells = new Set(); // Set of selected cells for range

            function clearSelectedCells() {
                selectedCells.forEach(cell => {
                    cell.classList.remove('cell-selected');
                });
                selectedCells.clear();
            }

            function clearActiveCell() {
                if (activeCell) {
                    activeCell.classList.remove('active-cell');
                    // Don't clear selection if it's part of a range
                    if (!selectedCells.has(activeCell)) {
                        activeCell.classList.remove('cell-selected');
                    }
                    activeCell = null;
                }
            }

            function setActiveCell(cell, extendSelection = false) {
                if (!cell) return;
                
                // If extending selection (Shift key), maintain anchor and extend range
                if (extendSelection && anchorCell) {
                    // Extend selection from anchor to current cell
                    clearSelectedCells();
                    selectRange(anchorCell, cell);
                } else if (!extendSelection) {
                    // Regular selection - clear previous range
                    clearSelectedCells();
                    anchorCell = cell;
                }
                
                // Update active cell
                if (activeCell) {
                    activeCell.classList.remove('active-cell');
                }
                activeCell = cell;
                if (activeCell) {
                    activeCell.classList.add('active-cell');
                    // Add to selection if we have a range
                    if (selectedCells.size > 0) {
                        activeCell.classList.add('cell-selected');
                        selectedCells.add(activeCell);
                    }
                    activeCell.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
            }

            function getCellPosition(cell) {
                const tbody = tableElement.querySelector('tbody');
                if (!tbody) return null;
                
                const allRows = Array.from(tbody.querySelectorAll('tr'));
                const currentRow = cell.parentElement;
                const rowIndex = allRows.indexOf(currentRow);
                
                const currentRowCells = Array.from(currentRow.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                const colIndex = currentRowCells.indexOf(cell);
                
                return { rowIndex, colIndex };
            }

            function selectRange(fromCell, toCell) {
                const fromPos = getCellPosition(fromCell);
                const toPos = getCellPosition(toCell);
                
                if (!fromPos || !toPos) return;
                
                const tbody = tableElement.querySelector('tbody');
                if (!tbody) return;
                
                const allRows = Array.from(tbody.querySelectorAll('tr'));
                
                // Calculate min/max for row and column
                const minRow = Math.min(fromPos.rowIndex, toPos.rowIndex);
                const maxRow = Math.max(fromPos.rowIndex, toPos.rowIndex);
                const minCol = Math.min(fromPos.colIndex, toPos.colIndex);
                const maxCol = Math.max(fromPos.colIndex, toPos.colIndex);
                
                // Select all cells in the range
                for (let r = minRow; r <= maxRow; r++) {
                    const row = allRows[r];
                    if (!row) continue;
                    const rowCells = Array.from(row.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                    
                    for (let c = minCol; c <= maxCol; c++) {
                        const cell = rowCells[c];
                        if (cell && cell.getAttribute('data-item-id') && cell.getAttribute('data-field')) {
                            cell.classList.add('cell-selected');
                            selectedCells.add(cell);
                        }
                    }
                }
            }

            function selectAllCells() {
                // Select all non-header cells in the table
                const tbody = tableElement.querySelector('tbody');
                if (!tbody) return;
                
                clearSelectedCells();
                anchorCell = null;
                
                const allRows = Array.from(tbody.querySelectorAll('tr'));
                let firstCell = null;
                
                allRows.forEach(row => {
                    const rowCells = Array.from(row.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                    rowCells.forEach(cell => {
                        if (cell.getAttribute('data-item-id') && cell.getAttribute('data-field')) {
                            cell.classList.add('cell-selected');
                            selectedCells.add(cell);
                            if (!firstCell) {
                                firstCell = cell;
                                anchorCell = cell;
                            }
                        }
                    });
                });
                
                if (firstCell) {
                    setActiveCell(firstCell, false);
                    firstCell.focus();
                }
            }

            function selectEntireColumn(sourceCell) {
                // Select entire column based on the current cell
                const pos = getCellPosition(sourceCell);
                if (!pos) return;
                
                const tbody = tableElement.querySelector('tbody');
                if (!tbody) return;
                
                clearSelectedCells();
                anchorCell = sourceCell;
                
                const allRows = Array.from(tbody.querySelectorAll('tr'));
                
                allRows.forEach(row => {
                    const rowCells = Array.from(row.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                    const cell = rowCells[pos.colIndex];
                    if (cell && cell.getAttribute('data-item-id') && cell.getAttribute('data-field')) {
                        cell.classList.add('cell-selected');
                        selectedCells.add(cell);
                    }
                });
                
                setActiveCell(sourceCell, false);
                sourceCell.focus();
            }

            function selectEntireRow(sourceCell) {
                // Select entire row based on the current cell
                const tbody = tableElement.querySelector('tbody');
                if (!tbody) return;
                
                const allRows = Array.from(tbody.querySelectorAll('tr'));
                const currentRow = sourceCell.parentElement;
                const rowIndex = allRows.indexOf(currentRow);
                if (rowIndex === -1) return;
                
                clearSelectedCells();
                anchorCell = sourceCell;
                
                const row = allRows[rowIndex];
                const rowCells = Array.from(row.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                
                rowCells.forEach(cell => {
                    if (cell.getAttribute('data-item-id') && cell.getAttribute('data-field')) {
                        cell.classList.add('cell-selected');
                        selectedCells.add(cell);
                    }
                });
                
                setActiveCell(sourceCell, false);
                sourceCell.focus();
            }

            function getCurrentCell() {
                const activeElement = document.activeElement;
                // Check if active element is a cell
                if (activeElement instanceof HTMLTableCellElement && tableElement.contains(activeElement)) {
                    return activeElement;
                }
                // Check if active element is an input/select inside a cell
                if (activeElement && (activeElement.tagName === 'INPUT' || activeElement.tagName === 'SELECT' || activeElement.tagName === 'TEXTAREA')) {
                    const cell = activeElement.closest('td');
                    if (cell && tableElement.contains(cell)) {
                        return cell;
                    }
                }
                return activeCell;
            }

            function getCellValue(cell) {
                // Check if cell is currently being edited (has an input)
                const input = cell.querySelector('input, select, textarea');
                if (input) {
                    if (input.type === 'checkbox') {
                        return input.checked;
                    }
                    return input.value;
                }

                // Get value from data attributes and changes/originalData
                const itemId = cell.getAttribute('data-item-id');
                const fieldName = cell.getAttribute('data-field');
                if (!itemId || !fieldName) return null;

                // Find the tab name from the table's parent
                const tabContent = tableElement.closest('.tab-content');
                if (!tabContent) return null;
                const tabName = tabContent.id.replace('tab-', '');

                // Get the value (check changes first, then originalData)
                let value = null;
                if (changes[tabName] && changes[tabName][itemId] && changes[tabName][itemId][fieldName] !== undefined) {
                    value = changes[tabName][itemId][fieldName];
                } else if (originalData[tabName] && originalData[tabName][itemId]) {
                    value = originalData[tabName][itemId][fieldName];
                }

                return value;
            }

            function getFieldType(tabName, fieldName) {
                const fieldDefs = FIELD_DEFINITIONS[tabName];
                if (!fieldDefs) return 'text';
                const field = fieldDefs.find(f => f.key === fieldName);
                return field ? field.type : 'text';
            }

            function getNextCell(currentCell, direction) {
                const currentRow = currentCell.parentElement;
                if (!currentRow || currentRow.tagName !== 'TR') return null;

                const tbody = tableElement.querySelector('tbody');
                if (!tbody) return null;

                const allRows = Array.from(tbody.querySelectorAll('tr'));
                const currentRowIndex = allRows.indexOf(currentRow);
                
                // Skip checkbox cells when calculating index
                const currentRowCells = Array.from(currentRow.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                const currentCellIndex = currentRowCells.indexOf(currentCell);
                if (currentCellIndex === -1) return null; // Current cell not found (might be checkbox cell)

                let targetRow = null;
                let targetCellIndex = currentCellIndex;

                switch (direction) {
                    case 'up':
                        if (currentRowIndex > 0) {
                            targetRow = allRows[currentRowIndex - 1];
                        }
                        break;
                    case 'down':
                        if (currentRowIndex < allRows.length - 1) {
                            targetRow = allRows[currentRowIndex + 1];
                        }
                        break;
                    case 'left':
                        if (currentCellIndex > 0) {
                            targetRow = currentRow;
                            targetCellIndex = currentCellIndex - 1;
                        }
                        break;
                    case 'right':
                        if (currentCellIndex < currentRowCells.length - 1) {
                            targetRow = currentRow;
                            targetCellIndex = currentCellIndex + 1;
                        }
                        break;
                }

                if (!targetRow) return null;
                const targetRowCells = Array.from(targetRow.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                return targetRowCells[targetCellIndex] || null;
            }

            function focusCell(cell, extendSelection = false) {
                setActiveCell(cell, extendSelection);
                // Trigger click to start editing if cell is editable
                if (cell.classList.contains('cell-editable')) {
                    cell.click();
                } else {
                    cell.focus();
                }
            }

            function copyCellValue(sourceCell, targetCell) {
                if (!sourceCell || !targetCell) return false;

                // Get source value
                const sourceValue = getCellValue(sourceCell);
                if (sourceValue === null) return false;

                // Get metadata for target cell
                const itemId = targetCell.getAttribute('data-item-id');
                const fieldName = targetCell.getAttribute('data-field');
                if (!itemId || !fieldName) return false;

                const tabContent = tableElement.closest('.tab-content');
                if (!tabContent) return false;
                const tabName = tabContent.id.replace('tab-', '');

                const fieldType = getFieldType(tabName, fieldName);

                // Check if target cell is currently being edited
                const targetInput = targetCell.querySelector('input, select, textarea');
                if (targetInput) {
                    // Update the existing input
                    if (targetInput.type === 'checkbox') {
                        targetInput.checked = sourceValue === true || sourceValue === 'true' || sourceValue === 1;
                    } else {
                        targetInput.value = String(sourceValue || '');
                    }
                    // Trigger change and input events
                    targetInput.dispatchEvent(new Event('change', { bubbles: true, cancelable: true }));
                    targetInput.dispatchEvent(new Event('input', { bubbles: true, cancelable: true }));
                } else {
                    // Need to programmatically set the value
                    // Use trackChange and displayCellValue to update it properly
                    if (!originalData[tabName] || !originalData[tabName][itemId]) return false;
                    
                    const originalValue = originalData[tabName][itemId][fieldName];
                    
                    // Convert sourceValue to appropriate type
                    let newValue = sourceValue;
                    if (fieldType === 'number') {
                        newValue = parseFloat(sourceValue) || null;
                    } else if (fieldType === 'boolean') {
                        newValue = sourceValue === true || sourceValue === 'true' || sourceValue === 1;
                    } else if (fieldType === 'datetime') {
                        newValue = sourceValue; // Keep as-is for datetime
                    } else {
                        newValue = String(sourceValue || '');
                    }

                    // Track the change
                    trackChange(tabName, itemId, fieldName, newValue, originalValue);
                    
                    // Update the display
                    const fieldDefs = FIELD_DEFINITIONS[tabName];
                    const fieldDef = fieldDefs ? fieldDefs.find(f => f.key === fieldName) : null;
                    displayCellValue(targetCell, tabName, itemId, fieldName, newValue, fieldType, fieldDef);
                }
                
                return true;
            }

            function getNextCellInTable(sourceCell, direction) {
                // Wrapper around getNextCell for consistency with handleDirectionalFill
                return getNextCell(sourceCell, direction);
            }

            function handleDirectionalFill(sourceCell, direction = 'down') {
                if (selectedCells.size > 0) {
                    const tbody = tableElement.querySelector('tbody');
                    if (!tbody) return;
                    const allRows = Array.from(tbody.querySelectorAll('tr'));

                    // 1. Sort the selection so we copy sequentially based on the direction
                    const cellsToCopy = Array.from(selectedCells).sort((a, b) => {
                        const posA = getCellPosition(a);
                        const posB = getCellPosition(b);
                        if (direction === 'down') return posA.rowIndex - posB.rowIndex;
                        if (direction === 'up') return posB.rowIndex - posA.rowIndex;
                        if (direction === 'right') return posA.colIndex - posB.colIndex;
                        if (direction === 'left') return posB.colIndex - posA.colIndex;
                        return 0;
                    });

                    // 2. Perform the copy only if the target is in the selection
                    cellsToCopy.forEach(cell => {
                        const pos = getCellPosition(cell);
                        if (!pos) return;
                        let targetCell = null;

                        if (direction === 'down' || direction === 'up') {
                            const targetIdx = direction === 'down' ? pos.rowIndex + 1 : pos.rowIndex - 1;
                            const targetRow = allRows[targetIdx];
                            if (targetRow) {
                                const rowCells = Array.from(targetRow.querySelectorAll('td'))
                                    .filter(td => !td.classList.contains('checkbox-cell'));
                                targetCell = rowCells[pos.colIndex];
                            }
                        } else {
                            const targetIdx = direction === 'right' ? pos.colIndex + 1 : pos.colIndex - 1;
                            const row = allRows[pos.rowIndex];
                            if (row) {
                                const rowCells = Array.from(row.querySelectorAll('td'))
                                    .filter(td => !td.classList.contains('checkbox-cell'));
                                targetCell = rowCells[targetIdx];
                            }
                        }

                        if (targetCell && selectedCells.has(targetCell)) {
                            copyCellValue(cell, targetCell);
                        }
                    });
                } else {
                    // Single-cell fallback logic
                    const targetCell = getNextCellInTable(sourceCell, direction);
                    if (targetCell && !isCellFilled(targetCell)) {
                        copyCellValue(sourceCell, targetCell);
                        setActiveCell(targetCell, false);
                        targetCell.focus();
                    }
                }
            }

            function isCellFilled(cell) {
                // Check if a cell has data - either stored value or displayed text
                if (!cell) return false;
                
                // First check if there's an input/select with a value
                const input = cell.querySelector('input, select, textarea');
                if (input) {
                    if (input.type === 'checkbox') {
                        return input.checked;
                    }
                    const inputValue = input.value || '';
                    if (inputValue.trim() !== '') {
                        return true;
                    }
                }
                
                // Check displayed text content
                const textContent = cell.textContent || cell.innerText || '';
                const trimmedText = textContent.trim();
                
                // Consider cell filled if it has non-empty text (not just "-" or empty)
                if (trimmedText !== '' && trimmedText !== '-') {
                    return true;
                }
                
                // Also check stored value
                const storedValue = getCellValue(cell);
                if (storedValue !== null && storedValue !== undefined && storedValue !== '') {
                    if (typeof storedValue === 'string' && storedValue.trim() !== '') {
                        return true;
                    } else if (typeof storedValue !== 'string') {
                        return true; // Numbers, booleans, etc.
                    }
                }
                
                return false;
            }

            function getEndOfContiguousData(startCell, direction = 'down') {
                const tbody = tableElement.querySelector('tbody');
                const allRows = Array.from(tbody.querySelectorAll('tr'));
                const startPos = getCellPosition(startCell);
                if (!startPos) return startCell;
                
                let previousCell = startCell;

                if (direction === 'down') {
                    for (let i = startPos.rowIndex + 1; i < allRows.length; i++) {
                        const row = allRows[i];
                        const rowCells = Array.from(row.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                        const currentCell = rowCells[startPos.colIndex];
                        if (!currentCell || isCellFilled(currentCell)) return previousCell;
                        previousCell = currentCell;
                    }
                } 
                else if (direction === 'up') {
                    for (let i = startPos.rowIndex - 1; i >= 0; i--) {
                        const row = allRows[i];
                        const rowCells = Array.from(row.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                        const currentCell = rowCells[startPos.colIndex];
                        if (!currentCell || isCellFilled(currentCell)) return previousCell;
                        previousCell = currentCell;
                    }
                } 
                else if (direction === 'right') {
                    const row = allRows[startPos.rowIndex];
                    const rowCells = Array.from(row.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                    for (let i = startPos.colIndex + 1; i < rowCells.length; i++) {
                        const currentCell = rowCells[i];
                        if (!currentCell || isCellFilled(currentCell)) return previousCell;
                        previousCell = currentCell;
                    }
                } 
                else if (direction === 'left') {
                    const row = allRows[startPos.rowIndex];
                    const rowCells = Array.from(row.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                    for (let i = startPos.colIndex - 1; i >= 0; i--) {
                        const currentCell = rowCells[i];
                        if (!currentCell || isCellFilled(currentCell)) return previousCell;
                        previousCell = currentCell;
                    }
                }

                return previousCell;
            }

            function handleKeyDown(event) {
                // Only handle if the event is within our table
                const target = event.target;
                if (!tableElement.contains(target)) {
                    return;
                }

                const currentCell = getCurrentCell();
                if (!currentCell || !tableElement.contains(currentCell)) {
                    return;
                }

                const activeElement = document.activeElement;
                const isEditing = activeElement && (activeElement.tagName === 'INPUT' || activeElement.tagName === 'SELECT' || activeElement.tagName === 'TEXTAREA');

                // Handle Ctrl+Shift+Arrow (Windows/Linux) or Cmd+Shift+Arrow (Mac) - select to next filled cell in any direction
                // This should work even when editing
                if ((event.ctrlKey || event.metaKey) && event.shiftKey && 
                    (event.key === 'ArrowDown' || event.key === 'ArrowUp' || 
                     event.key === 'ArrowLeft' || event.key === 'ArrowRight')) {
                    event.preventDefault();
                    event.stopPropagation();
                    
                    // Get the cell - prefer the cell containing the active element if editing
                    let cellToUse = currentCell;
                    if (isEditing) {
                        const cellFromInput = activeElement.closest('td');
                        if (cellFromInput && tableElement.contains(cellFromInput)) {
                            cellToUse = cellFromInput;
                        }
                    }
                    
                    if (!cellToUse || !tableElement.contains(cellToUse)) {
                        return;
                    }
                    
                    // Set anchor if not already set
                    if (!anchorCell) {
                        anchorCell = cellToUse;
                    }
                    
                    // Convert arrow key to direction
                    let direction = 'down';
                    if (event.key === 'ArrowUp') direction = 'up';
                    else if (event.key === 'ArrowDown') direction = 'down';
                    else if (event.key === 'ArrowLeft') direction = 'left';
                    else if (event.key === 'ArrowRight') direction = 'right';
                    
                    // Find the end of contiguous data
                    const endCell = getEndOfContiguousData(cellToUse, direction);
                    if (endCell) {
                        // If we were editing, finish editing first by blurring
                        if (isEditing && activeElement.blur) {
                            activeElement.blur();
                        }
                        // Extend selection to the end cell
                        setActiveCell(endCell, true);
                        endCell.focus();
                    }
                    return;
                }

                // Handle Ctrl+A (Windows/Linux) or Cmd+A (Mac) - select all cells
                if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'a') {
                    event.preventDefault();
                    event.stopPropagation();
                    const tbody = tableElement.querySelector('tbody');
                    const allRows = Array.from(tbody.querySelectorAll('tr'));
                    if (allRows.length === 0) return;

                    const firstRowCells = Array.from(allRows[0].querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                    const lastRowCells = Array.from(allRows[allRows.length - 1].querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                    
                    const startCell = firstRowCells[0];
                    const endCell = lastRowCells[lastRowCells.length - 1];

                    if (startCell && endCell) {
                        anchorCell = startCell;
                        setActiveCell(endCell, true);
                    }
                    return;
                }

                // Handle Ctrl+Spacebar (Windows/Linux) or Cmd+Spacebar (Mac) - select entire column
                if ((event.ctrlKey || event.metaKey) && event.code === 'Space') {
                    event.preventDefault();
                    event.stopPropagation();
                    const pos = getCellPosition(activeCell || currentCell);
                    const tbody = tableElement.querySelector('tbody');
                    const allRows = Array.from(tbody.querySelectorAll('tr'));
                    
                    if (pos && allRows.length > 0) {
                        const firstRowCells = Array.from(allRows[0].querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                        const lastRowCells = Array.from(allRows[allRows.length - 1].querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                        
                        if (firstRowCells[pos.colIndex] && lastRowCells[pos.colIndex]) {
                            anchorCell = firstRowCells[pos.colIndex];
                            setActiveCell(lastRowCells[pos.colIndex], true);
                        }
                    }
                    return;
                }

                // Handle Shift+Spacebar - select entire row
                if (event.shiftKey && !event.ctrlKey && !event.metaKey && event.code === 'Space') {
                    event.preventDefault();
                    event.stopPropagation();
                    const cellToUse = activeCell || currentCell;
                    if (!cellToUse) return;
                    
                    const row = cellToUse.parentElement;
                    const rowCells = Array.from(row.querySelectorAll('td')).filter(td => !td.classList.contains('checkbox-cell'));
                    
                    if (rowCells.length > 0) {
                        anchorCell = rowCells[0];
                        setActiveCell(rowCells[rowCells.length - 1], true);
                    }
                    return;
                }

                // Handle Ctrl+D (Windows/Linux) or Cmd+D (Mac) - copy down
                if ((event.ctrlKey || event.metaKey) && !event.shiftKey && (event.key === 'd' || event.key === 'D')) {
                    event.preventDefault();
                    event.stopPropagation();
                    handleDirectionalFill(currentCell, 'down');
                    return;
                }

                // Handle Ctrl+Down (Windows/Linux) or Cmd+Down (Mac) for range selection (extend one row)
                if ((event.ctrlKey || event.metaKey) && !event.shiftKey && event.key === 'ArrowDown') {
                    event.preventDefault();
                    event.stopPropagation();
                    
                    if (!anchorCell) {
                        anchorCell = currentCell;
                    }
                    
                    // Find the bottommost selected cell or current cell
                    let bottomCell = currentCell;
                    if (selectedCells.size > 0) {
                        const tbody = tableElement.querySelector('tbody');
                        if (tbody) {
                            const allRows = Array.from(tbody.querySelectorAll('tr'));
                            let maxRow = -1;
                            selectedCells.forEach(cell => {
                                const pos = getCellPosition(cell);
                                if (pos && pos.rowIndex > maxRow) {
                                    maxRow = pos.rowIndex;
                                    bottomCell = cell;
                                }
                            });
                        }
                    }
                    
                    const nextCell = getNextCell(bottomCell, 'down');
                    if (nextCell) {
                        setActiveCell(nextCell, true); // Extend selection
                        nextCell.focus();
                    }
                    return;
                }

                // Handle Shift+Arrow keys for extending selection (even when editing)
                if (event.shiftKey && !event.ctrlKey && !event.metaKey) {
                    let nextCell = null;
                    let handled = false;

                    switch (event.key) {
                        case 'ArrowUp':
                            event.preventDefault();
                            event.stopPropagation();
                            nextCell = getNextCell(currentCell, 'up');
                            handled = true;
                            break;
                        case 'ArrowDown':
                            event.preventDefault();
                            event.stopPropagation();
                            nextCell = getNextCell(currentCell, 'down');
                            handled = true;
                            break;
                        case 'ArrowLeft':
                            event.preventDefault();
                            event.stopPropagation();
                            nextCell = getNextCell(currentCell, 'left');
                            handled = true;
                            break;
                        case 'ArrowRight':
                            event.preventDefault();
                            event.stopPropagation();
                            nextCell = getNextCell(currentCell, 'right');
                            handled = true;
                            break;
                    }

                    if (handled) {
                        if (nextCell) {
                            // Set anchor if not already set
                            if (!anchorCell) {
                                anchorCell = currentCell;
                            }
                            setActiveCell(nextCell, true); // Extend selection
                            nextCell.focus();
                        }
                        return;
                    }
                }

                // Only prevent arrow keys if not currently editing (not in an input/select)
                // Exception: Shift+Arrow and Ctrl+Arrow are handled above
                if (isEditing) {
                    // Allow default behavior when editing (let Enter/Escape work normally)
                    // But allow arrow keys to move if they're not in an input
                    if (activeElement.closest('td') !== currentCell) {
                        return;
                    }
                    // If we're in an input and press arrow keys without modifiers, don't navigate
                    // (Shift+Arrow and Ctrl+Arrow are already handled above)
                    return;
                }

                // Handle regular arrow keys (no modifiers)
                if (!event.shiftKey && !event.ctrlKey && !event.metaKey && !event.altKey) {
                    let nextCell = null;

                    switch (event.key) {
                        case 'ArrowUp':
                            event.preventDefault();
                            nextCell = getNextCell(currentCell, 'up');
                            break;
                        case 'ArrowDown':
                            event.preventDefault();
                            nextCell = getNextCell(currentCell, 'down');
                            break;
                        case 'ArrowLeft':
                            event.preventDefault();
                            nextCell = getNextCell(currentCell, 'left');
                            break;
                        case 'ArrowRight':
                            event.preventDefault();
                            nextCell = getNextCell(currentCell, 'right');
                            break;
                        default:
                            return; // Ignore other keys
                    }

                    if (nextCell) {
                        // Clear selection when moving without Shift
                        clearSelectedCells();
                        anchorCell = null;
                        focusCell(nextCell, false);
                    }
                }
            }

            function handleCellClick(event) {
                const cell = event.target.closest('td');
                if (!cell || !tableElement.contains(cell)) return;
                
                // Ignore clicks on checkboxes or inputs
                if (event.target.type === 'checkbox' || event.target.tagName === 'INPUT' || event.target.tagName === 'SELECT' || event.target.tagName === 'TEXTAREA') {
                    return;
                }
                
                // Ignore clicks on cells that don't have data attributes (like checkbox cells)
                if (!cell.getAttribute('data-item-id') || !cell.getAttribute('data-field')) {
                    return;
                }

                if (event.shiftKey && anchorCell) {
                    // Shift+Click: extend selection from anchor to clicked cell
                    event.preventDefault();
                    setActiveCell(cell, true);
                    cell.focus();
                } else {
                    // Regular click: set new anchor and clear previous selection
                    clearSelectedCells();
                    anchorCell = cell;
                    setActiveCell(cell, false);
                    cell.focus();
                }
            }

            // Make all editable cells focusable by adding tabindex
            function makeCellsFocusable() {
                const tbody = tableElement.querySelector('tbody');
                if (!tbody) return;
                const cells = tbody.querySelectorAll('td[data-item-id][data-field]');
                cells.forEach(cell => {
                    if (!cell.hasAttribute('tabindex')) {
                        cell.setAttribute('tabindex', '0');
                    }
                });
            }
            
            // Initialize focusable cells
            makeCellsFocusable();
            
            // Re-run when table content changes (using MutationObserver)
            const observer = new MutationObserver(() => {
                makeCellsFocusable();
            });
            observer.observe(tableElement, { childList: true, subtree: true });

            // Attach event listeners to the table
            tableElement.addEventListener('keydown', handleKeyDown);
            tableElement.addEventListener('click', handleCellClick, true);

            // Set initial active cell when table is focused
            tableElement.addEventListener('focus', () => {
                if (!activeCell) {
                    const tbody = tableElement.querySelector('tbody');
                    if (tbody) {
                        const firstRow = tbody.querySelector('tr');
                        if (firstRow) {
                            const firstCell = firstRow.querySelector('td:not(.checkbox-cell)');
                            if (firstCell) {
                                setActiveCell(firstCell, false);
                                anchorCell = firstCell;
                            }
                        }
                    }
                }
            }, true);

            // Clear active cell and selection when clicking outside
            document.addEventListener('click', (event) => {
                if (!tableElement.contains(event.target)) {
                    clearActiveCell();
                    clearSelectedCells();
                    anchorCell = null;
                }
            });
        }

