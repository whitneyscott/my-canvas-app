        function calculateDateDiff() {
            const oldDateInput = document.getElementById('oldSemesterStart');
            const newDateInput = document.getElementById('newSemesterStart');
            const shiftDaysInput = document.getElementById('dateShiftDays');
            
            if (!oldDateInput.value || !newDateInput.value) {
                alert('Please enter both Old Semester Start and New Semester Start dates.');
                return;
            }
            
            const oldDate = new Date(oldDateInput.value);
            const newDate = new Date(newDateInput.value);
            
            if (isNaN(oldDate.getTime()) || isNaN(newDate.getTime())) {
                alert('Please enter valid dates.');
                return;
            }
            
            // Calculate difference in days
            const diffTime = newDate.getTime() - oldDate.getTime();
            const diffDays = Math.round(diffTime / (1000 * 60 * 60 * 24));
            
            // Update the shift value field
            shiftDaysInput.value = diffDays;
        }

