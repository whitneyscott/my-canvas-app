        async function openAccommodationsModal() {
            const tabName = getCurrentTabName();
            if (!tabName) {
                alert('Please select a tab first.');
                return;
            }
            
            // Only allow for assignments, quizzes, and discussions
            if (tabName !== 'assignments' && tabName !== 'quizzes' && tabName !== 'discussions') {
                alert('Accommodation Command Center is only available for Assignments, Quizzes, and Discussions.');
                return;
            }
            
            const selected = getSelectedItems();
            if (selected.length === 0) {
                alert('Please select at least one item.');
                return;
            }
            
            const courseId = getCurrentCourseId();
            if (!courseId) {
                alert('No course selected.');
                return;
            }
            
            // For Quizzes: Check if they have time_limit > 0 (auto-apply extensions)
            if (tabName === 'quizzes') {
                let hasTimeLimit = false;
                let processedCount = 0;
                
                // Check if any selected quiz has time_limit > 0
                for (const quizId of selected) {
                    try {
                        const quizResponse = await fetch(`/canvas/courses/${courseId}/quizzes/${quizId}`);
                        if (quizResponse.ok) {
                            const quiz = await quizResponse.json();
                            if (quiz.time_limit && quiz.time_limit > 0) {
                                hasTimeLimit = true;
                                break;
                            }
                        }
                    } catch (error) {
                        console.error(`Error checking quiz ${quizId}:`, error);
                    }
                }
                
                if (hasTimeLimit) {
                    // Auto-apply extensions (skip modal)
                    processedCount = await autoApplyQuizExtensions(courseId, selected);
                    const remainingCount = selected.length - processedCount;
                    
                    if (remainingCount > 0) {
                        // Some quizzes don't have time_limit, show modal for those
                        console.log(`Automatically extended ${processedCount} quiz/quizzes. Opening clone settings for ${remainingCount} quiz/quizzes without time limits.`);
                        // For now, show modal for all selected items (user can manually handle)
                        // TODO: Filter to only quizzes without time_limit
                        showCloneModal(tabName, selected);
                    } else {
                        console.log(`Automatically extended ${processedCount} quiz/quizzes.`);
                        await refreshTab(tabName);
                    }
                    return;
                }
            }
            
            // For Assignments, Discussions, or Quizzes without time_limit: Show modal for cloning
            showCloneModal(tabName, selected);
        }
        
        function showCloneModal(tabName, selected) {
            // Scrape unique accommodation types from Students tab
            const uniqueAccommodations = scrapeUniqueAccommodations();
            
            // Populate accommodation types checkboxes
            populateAccommodationTypes(uniqueAccommodations);
            
            // Update plan preview
            updateAccommodationPlanPreview(tabName, selected, uniqueAccommodations);
            
            // Reset progress log
            const progressContainer = document.getElementById('accommodationProgressContainer');
            const progressLog = document.getElementById('accommodationProgressLog');
            if (progressContainer) progressContainer.style.display = 'none';
            if (progressLog) progressLog.innerHTML = '';
            
            openModal('accommodationCommandModal');
        }
        
        async function autoApplyQuizExtensions(courseId, selectedQuizIds) {
            let successCount = 0;
            const errors = [];
            const successfulQuizzes = [];
            
            addProgressLog('Auto-applying quiz extensions...', 'info');
            
            for (const quizId of selectedQuizIds) {
                try {
                    // Fetch quiz data
                    const quizResponse = await fetch(`/canvas/courses/${courseId}/quizzes/${quizId}`);
                    if (!quizResponse.ok) {
                        throw new Error(`Failed to fetch quiz: ${quizResponse.status}`);
                    }
                    const quiz = await quizResponse.json();
                    
                    // Skip quizzes without time_limit
                    if (!quiz.time_limit || quiz.time_limit <= 0) {
                        continue;
                    }
                    
                    // Prepare extensions based on all student accommodations
                    const extensions = [];
                    
                    // Get all students with accommodations from Students tab
                    Object.keys(studentAccommodations).forEach(studentIdStr => {
                        const studentId = parseInt(studentIdStr);
                        const accType = studentAccommodations[studentIdStr];
                        
                        if (!accType) return;
                        
                        const extension = { user_id: studentId };
                        
                        // Check for time multiplier
                        const multiplier = extractTimeMultiplier(accType);
                        if (multiplier) {
                            const extraTime = Math.round(quiz.time_limit * (multiplier - 1));
                            extension.extra_time = extraTime;
                        }
                        
                        // Check for additional attempt
                        const isExtraAttempt = accType.toLowerCase().includes('attempt') || accType.toLowerCase().includes('extra');
                        if (isExtraAttempt) {
                            extension.extra_attempts = (extension.extra_attempts || 0) + 1;
                        }
                        
                        if (extension.extra_time || extension.extra_attempts) {
                            extensions.push(extension);
                        }
                    });
                    
                    if (extensions.length > 0) {
                        addProgressLog(`POST /canvas/courses/${courseId}/quizzes/${quizId}/extensions (${extensions.length} extension(s))`, 'info');
                        const extResponse = await fetch(`/canvas/courses/${courseId}/quizzes/${quizId}/extensions`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ quiz_extensions: extensions })
                        });
                        
                        if (!extResponse.ok) {
                            const errorText = await extResponse.text();
                            throw new Error(`Failed to create extensions: ${extResponse.status} - ${errorText}`);
                        }
                        
                        addProgressLog(`✓ Auto-applied extensions for quiz "${quiz.title}"`, 'success');
                        successfulQuizzes.push(quiz.title);
                        successCount++;
                    }
                } catch (error) {
                    addProgressLog(`✗ Error auto-applying extensions for quiz ${quizId}: ${error.message}`, 'error');
                    errors.push({ quizId, error: error.message });
                }
            }
            
            // Show notification if quizzes were successfully updated
            if (successfulQuizzes.length > 0) {
                const quizList = successfulQuizzes.length <= 3 
                    ? successfulQuizzes.join(', ')
                    : `${successfulQuizzes.slice(0, 3).join(', ')} and ${successfulQuizzes.length - 3} more`;
                alert(`✓ Accommodations have been automatically updated for:\n\n${quizList}`);
            }
            
            return successCount;
        }
        
        function scrapeUniqueAccommodations() {
            const uniqueAccommodations = new Set();
            
            // Get accommodation data from studentAccommodations object
            Object.values(studentAccommodations).forEach(accType => {
                if (accType && accType.trim()) {
                    uniqueAccommodations.add(accType.trim());
                }
            });
            
            // Also check the students table for accommodations
            const rows = document.querySelectorAll('#studentsTableBody tr');
            rows.forEach(row => {
                const checkboxes = row.querySelectorAll('.accommodation-checkbox:checked');
                checkboxes.forEach(cb => {
                    const accType = cb.value.trim();
                    if (accType) {
                        uniqueAccommodations.add(accType);
                    }
                });
            });
            
            return Array.from(uniqueAccommodations).sort();
        }
        
        function populateAccommodationTypes(accommodationTypes) {
            const container = document.getElementById('accommodationTypesContainer');
            if (!container) return;
            
            container.innerHTML = '';
            
            if (accommodationTypes.length === 0) {
                const message = document.createElement('div');
                message.textContent = 'No accommodation types found in the Students tab.';
                message.style.cssText = 'padding: 10px; color: #999; font-style: italic; text-align: center;';
                container.appendChild(message);
                return;
            }
            
            accommodationTypes.forEach(accType => {
                const label = document.createElement('label');
                label.style.cssText = 'display: flex; align-items: center; cursor: pointer; padding: 8px; border-radius: 4px; transition: background 0.2s;';
                label.onmouseover = function() { this.style.background = '#f0f0f0'; };
                label.onmouseout = function() { this.style.background = 'transparent'; };
                label.onchange = function() { updateAccommodationPlanPreview(getCurrentTabName(), getSelectedItems(), accommodationTypes); };
                
                const checkbox = document.createElement('input');
                checkbox.type = 'checkbox';
                checkbox.value = accType;
                checkbox.id = `accType-${accType.replace(/\s+/g, '-')}`;
                checkbox.style.cssText = 'margin-right: 10px; width: 18px; height: 18px; cursor: pointer; flex-shrink: 0;';
                checkbox.onchange = function() { updateAccommodationPlanPreview(getCurrentTabName(), getSelectedItems(), accommodationTypes); };
                
                const span = document.createElement('span');
                span.textContent = accType;
                span.style.cssText = 'font-size: 14px; color: #333;';
                
                label.appendChild(checkbox);
                label.appendChild(span);
                container.appendChild(label);
            });
        }
        
        function getSelectedAccommodationTypes() {
            const checkboxes = document.querySelectorAll('#accommodationTypesContainer input[type="checkbox"]:checked');
            return Array.from(checkboxes).map(cb => cb.value);
        }
        
        function updateAccommodationPlanPreview(tabName, selectedItems, allAccommodations) {
            const preview = document.getElementById('accommodationPlanPreview');
            if (!preview) return;
            
            const selectedAccTypes = getSelectedAccommodationTypes();
            
            if (selectedAccTypes.length === 0) {
                preview.textContent = 'Select accommodation types to see the plan...';
                return;
            }
            
            let planText = '';
            
            if (tabName === 'quizzes') {
                // For quizzes: time multipliers and extra attempts
                const timeMultipliers = selectedAccTypes.filter(acc => acc.includes('x') || acc.includes('Time'));
                const extraAttempts = selectedAccTypes.filter(acc => acc.toLowerCase().includes('attempt') || acc.toLowerCase().includes('extra'));
                
                if (timeMultipliers.length > 0) {
                    planText += `Applying time multipliers (${timeMultipliers.join(', ')}) to ${selectedItems.length} quiz/quizzes via extensions endpoint.\n`;
                }
                if (extraAttempts.length > 0) {
                    planText += `Adding 1 extra attempt for ${extraAttempts.length} accommodation type(s) to ${selectedItems.length} quiz/quizzes.\n`;
                }
            } else if (tabName === 'assignments') {
                // For assignments: clone & tag
                planText += `Creating ${selectedAccTypes.length} twin(s) for each of ${selectedItems.length} selected assignment(s).\n`;
                planText += `Accommodation types: ${selectedAccTypes.join(', ')}\n`;
                planText += `Each twin will be tagged with integration_id (acc_[type]) and title append ([type]).\n`;
                planText += `Twins will be assigned only to students with matching accommodations.\n`;
                planText += `Original assignments will be set to only_visible_to_overrides (excluding accommodated students).\n`;
            }
            
            preview.textContent = planText || 'No plan available.';
        }
        
        function addProgressLog(message, type = 'info') {
            const progressLog = document.getElementById('accommodationProgressLog');
            const progressContainer = document.getElementById('accommodationProgressContainer');
            if (!progressLog) return;
            
            if (progressContainer) progressContainer.style.display = 'block';
            
            const logEntry = document.createElement('div');
            logEntry.style.cssText = `margin: 4px 0; padding: 4px 8px; border-radius: 3px; font-family: monospace; font-size: 12px;`;
            
            if (type === 'error') {
                logEntry.style.background = '#ffe6e6';
                logEntry.style.color = '#cc0000';
            } else if (type === 'success') {
                logEntry.style.background = '#e6ffe6';
                logEntry.style.color = '#006600';
            } else {
                logEntry.style.background = '#f0f0f0';
                logEntry.style.color = '#333';
            }
            
            const timestamp = new Date().toLocaleTimeString();
            logEntry.textContent = `[${timestamp}] ${message}`;
            progressLog.appendChild(logEntry);
            progressLog.scrollTop = progressLog.scrollHeight;
        }
        
        function getStudentsByAccommodationType(accType) {
            const studentIds = [];
            Object.keys(studentAccommodations).forEach(studentId => {
                if (studentAccommodations[studentId] === accType) {
                    studentIds.push(parseInt(studentId));
                }
            });
            return studentIds;
        }
        
        function extractTimeMultiplier(accType) {
            // Extract multiplier from strings like "1.5x", "Time 2.0x", "2x"
            const match = accType.match(/(\d+\.?\d*)x/i);
            if (match) {
                return parseFloat(match[1]);
            }
            return null;
        }
        
        async function getAllCourseStudentIds(courseId) {
            try {
                const response = await fetch(`/canvas/courses/${courseId}/students`);
                if (!response.ok) {
                    throw new Error(`Failed to fetch students: ${response.status}`);
                }
                const students = await response.json();
                return students.map(s => s.id || s.user_id).filter(id => id);
            } catch (error) {
                console.error('Error fetching course students:', error);
                return [];
            }
        }
        
        async function cleanSlateAssignmentOverrides(
            courseId,
            assignmentId,
            accommodatedStudentIds,
            allStudentIds
        ) {
            try {
                addProgressLog(`Starting override reconciliation for assignment ${assignmentId}`, 'info');

                const assignmentRes = await fetch(
                    `/canvas/courses/${courseId}/assignments/${assignmentId}`,
                    { headers: { Accept: 'application/json' } }
                );
                if (!assignmentRes.ok) throw new Error(`Assignment fetch failed`);
                const assignment = await assignmentRes.json();

                const preservedDates = {
                    due_at: assignment.due_at || null,
                    unlock_at: assignment.unlock_at || null,
                    lock_at: assignment.lock_at || null
                };

                await fetch(
                    `/canvas/courses/${courseId}/assignments/${assignmentId}`,
                    {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                        body: JSON.stringify({
                            assignment: { only_visible_to_overrides: true }
                        })
                    }
                );

                const overridesRes = await fetch(
                    `/canvas/courses/${courseId}/assignments/${assignmentId}/overrides`,
                    { headers: { Accept: 'application/json' } }
                );
                const overrides = await overridesRes.json();

                for (const o of overrides) {
                    await fetch(
                        `/canvas/courses/${courseId}/assignments/${assignmentId}/overrides/${o.id}`,
                        {
                            method: 'DELETE',
                            headers: { Accept: 'application/json' }
                        }
                    );
                }

                await fetch(
                    `/canvas/courses/${courseId}/assignments/${assignmentId}`,
                    {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                        body: JSON.stringify({
                            assignment: {
                                due_at: null,
                                unlock_at: null,
                                lock_at: null
                            }
                        })
                    }
                );

                const standardStudentIds = allStudentIds
                    .map(id => parseInt(id))
                    .filter(id => !accommodatedStudentIds.has(id));

                if (standardStudentIds.length === 0) return;

                await new Promise(r => setTimeout(r, 500));

                await fetch(
                    `/canvas/courses/${courseId}/assignments/${assignmentId}/overrides`,
                    {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                        body: JSON.stringify({
                            assignment_override: {
                                title: 'Standard Students',
                                student_ids: standardStudentIds,
                                due_at: preservedDates.due_at,
                                unlock_at: preservedDates.unlock_at,
                                lock_at: preservedDates.lock_at
                            }
                        })
                    }
                );

                addProgressLog(`Overrides reconciled successfully`, 'success');

            } catch (e) {
                addProgressLog(`Override reconciliation failed: ${e.message}`, 'error');
                throw e;
            }
        }
        
        async function executeAccommodations() {
            const tabName = getCurrentTabName();
            // This function is now only for modal-based cloning (assignments, discussions, quizzes without time_limit)
            if (!tabName || (tabName !== 'assignments' && tabName !== 'discussions' && tabName !== 'quizzes')) {
                alert('This feature is only available for Assignments, Discussions, and Quizzes.');
                return;
            }
            
            const selectedItems = getSelectedItems();
            if (selectedItems.length === 0) {
                alert('Please select at least one item.');
                return;
            }
            
            const selectedAccTypes = getSelectedAccommodationTypes();
            if (selectedAccTypes.length === 0) {
                alert('Please select at least one accommodation type.');
                return;
            }
            
            const courseId = getCurrentCourseId();
            if (!courseId) {
                alert('No course selected.');
                return;
            }
            
            // Disable execute button
            const executeBtn = document.getElementById('accommodationExecuteBtn');
            if (executeBtn) {
                executeBtn.disabled = true;
                executeBtn.textContent = 'Processing...';
            }
            
            // Show progress container
            const progressContainer = document.getElementById('accommodationProgressContainer');
            if (progressContainer) progressContainer.style.display = 'block';
            
            addProgressLog('Starting accommodation cloning...', 'info');
            
            // Get all students in the course for cleanup logic
            const allStudentIds = await getAllCourseStudentIds(courseId);
            
            let totalSuccess = 0;
            let totalErrors = 0;
            const errors = [];
            
            try {
                // Get all accommodated student IDs (for cleanup)
                const allAccommodatedStudentIds = new Set();
                selectedAccTypes.forEach(accType => {
                    const studentIds = getStudentsByAccommodationType(accType);
                    studentIds.forEach(id => allAccommodatedStudentIds.add(id));
                });
                
                // Get non-accommodated student IDs (for standard version override)
                const nonAccommodatedStudentIds = allStudentIds.filter(id => !allAccommodatedStudentIds.has(id));
                
                if (tabName === 'assignments' || tabName === 'discussions') {
                    // Assignment workflow: Clone & tag
                    addProgressLog(`Processing ${selectedItems.length} assignment(s)...`, 'info');
                    
                    for (const assignmentId of selectedItems) {
                        try {
                            addProgressLog(`GET /canvas/courses/${courseId}/assignments/${assignmentId}`, 'info');
                            const assignmentResponse = await fetch(`/canvas/courses/${courseId}/assignments/${assignmentId}`, {
                                headers: { 'Accept': 'application/json' }
                            });
                            if (!assignmentResponse.ok) {
                                throw new Error(`Failed to fetch assignment: ${assignmentResponse.status}`);
                            }
                            const originalAssignment = await assignmentResponse.json();
                            const assignmentName = originalAssignment.name || 'Untitled';
                            
                            addProgressLog(`PUT /canvas/courses/${courseId}/assignments/${assignmentId} (setting only_visible_to_overrides)`, 'info');
                            const updateResponse = await fetch(`/canvas/courses/${courseId}/assignments/${assignmentId}`, {
                                method: 'PUT',
                                headers: { 
                                    'Content-Type': 'application/json',
                                    'Accept': 'application/json'
                                },
                                body: JSON.stringify({
                                    assignment: {
                                        only_visible_to_overrides: true,
                                        integration_id: 'standard'
                                    }
                                })
                            });
                            
                            if (!updateResponse.ok) {
                                const errorText = await updateResponse.text();
                                throw new Error(`Failed to update assignment: ${updateResponse.status} - ${errorText}`);
                            }
                            
                            // Create twin for each accommodation type
                            for (const accType of selectedAccTypes) {
                                try {
                                    const studentIds = getStudentsByAccommodationType(accType);
                                    if (studentIds.length === 0) {
                                        addProgressLog(`  No students found for accommodation type: ${accType}`, 'info');
                                        continue;
                                    }
                                    
                                    // Sanitize assignment data for duplication
                                    const systemReadOnlyFields = [
                                        'id', 'uuid', 'created_at', 'updated_at', 'html_url', 'url',
                                        'locked_for_user', 'position', 'assignment_id', 'quiz_id',
                                        'workflow_state', 'user_count', 'view_count', 'reply_count',
                                        'pinned', 'posted_at', 'last_reply_at', 'has_submitted_submissions',
                                        'lti_context_id', 'global_id', 'secure_params', 'original_lti_resource_link_id'
                                    ];
                                    
                                    const sanitizedAssignment = {};
                                    const safeIdFields = ['assignment_group_id', 'grading_standard_id'];
                                    Object.keys(originalAssignment).forEach(key => {
                                        if (systemReadOnlyFields.includes(key)) {
                                            return; // Skip system read-only fields
                                        }
                                        if (key.endsWith('_id') && !safeIdFields.includes(key)) {
                                            return; // Skip ID fields except safe ones
                                        }
                                        sanitizedAssignment[key] = originalAssignment[key];
                                    });
                                    
                                    // Update title and integration_id
                                    const accTypeClean = accType.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();
                                    const newTitle = originalAssignment.name.replace(/\[\s*[^\]]*\s*\]\s*$/, '') + ` [${accType}]`;
                                    sanitizedAssignment.name = newTitle;
                                    sanitizedAssignment.integration_id = `acc_${accTypeClean}`;
                                    sanitizedAssignment.only_visible_to_overrides = true;
                                    
                                    addProgressLog(`POST /canvas/courses/${courseId}/assignments (creating twin for ${accType})`, 'info');
                                    const createResponse = await fetch(`/canvas/courses/${courseId}/assignments`, {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ assignment: sanitizedAssignment })
                                    });
                                    
                                    if (!createResponse.ok) {
                                        const errorText = await createResponse.text();
                                        throw new Error(`Failed to create twin: ${createResponse.status} - ${errorText}`);
                                    }
                                    
                                    const newAssignment = await createResponse.json();
                                    
                                    // Create assignment override for students with this accommodation
                                    addProgressLog(`POST /canvas/courses/${courseId}/assignments/${newAssignment.id}/overrides`, 'info');
                                    const overrideResponse = await fetch(`/canvas/courses/${courseId}/assignments/${newAssignment.id}/overrides`, {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({
                                            assignment_override: {
                                                student_ids: studentIds
                                            }
                                        })
                                    });
                                    
                                    if (!overrideResponse.ok) {
                                        const errorText = await overrideResponse.text();
                                        throw new Error(`Failed to create override: ${overrideResponse.status} - ${errorText}`);
                                    }
                                    
                                    // Clean Slate: Reset original assignment overrides after clone is created
                                    // This ensures the original assignment only has standard students (Group B)
                                    await cleanSlateAssignmentOverrides(
                                        courseId,
                                        assignmentId,
                                        allAccommodatedStudentIds,
                                        allStudentIds
                                    );
                                    
                                    addProgressLog(`✓ Created twin "${newTitle}" for ${accType} (${studentIds.length} student(s))`, 'success');
                                    totalSuccess++;
                                } catch (error) {
                                    addProgressLog(`✗ Error creating twin for ${accType}: ${error.message}`, 'error');
                                    errors.push({ itemId: assignmentId, accType, error: error.message });
                                    totalErrors++;
                                }
                            }
                        } catch (error) {
                            addProgressLog(`✗ Error processing assignment ${assignmentId}: ${error.message}`, 'error');
                            errors.push({ itemId: assignmentId, error: error.message });
                            totalErrors++;
                        }
                    }
                }
                
                // Summary
                addProgressLog('', 'info');
                addProgressLog(`=== Processing Complete ===`, 'info');
                addProgressLog(`Success: ${totalSuccess}`, 'success');
                if (totalErrors > 0) {
                    addProgressLog(`Errors: ${totalErrors}`, 'error');
                    errors.forEach(err => {
                        addProgressLog(`  - Item ${err.itemId}${err.accType ? ` (${err.accType})` : ''}: ${err.error}`, 'error');
                    });
                }
                
                // Refresh the tab to show new items
                await refreshTab(tabName);
                
            } catch (error) {
                addProgressLog(`Fatal error: ${error.message}`, 'error');
                alert(`Accommodation processing failed: ${error.message}`);
            } finally {
                if (executeBtn) {
                    executeBtn.disabled = false;
                    executeBtn.textContent = 'Execute Accommodations';
                }
            }
        }

