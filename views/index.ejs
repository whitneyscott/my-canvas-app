        async function proceedWithDuplication() {
            if (!pendingDuplication) {
                closeModal('duplicateQuantityModal');
                return;
            }
            
            const { tabName, selected } = pendingDuplication;
            const quantityInput = document.getElementById('duplicateQuantity');
            const quantity = parseInt(quantityInput.value, 10);
            
            if (isNaN(quantity) || quantity < 1) {
                alert('Please enter a valid number (1 or greater).');
                return;
            }
            
            closeModal('duplicateQuantityModal');
            
            const courseId = getCurrentCourseId();
            if (!courseId) {
                alert('No course selected.');
                pendingDuplication = null;
                return;
            }
            
            // Disable button during duplication
            const duplicateBtn = document.getElementById('duplicateSelectedBtn');
            if (duplicateBtn) {
                duplicateBtn.disabled = true;
                duplicateBtn.textContent = 'Creating copies...';
            }
            
            const nameField = getNameFieldName(tabName);
            const createEndpoint = getCanvasCreateEndpoint(tabName);
            const createdItems = [];
            let successCount = 0;
            let failedItems = [];
            
            try {
                // Nested loop: For each selected item -> For 1 to N copies
                for (const itemId of selected) {
                    try {
                        // 1. Fetch the full object data from Canvas
                        const getEndpoint = getCanvasItemEndpoint(tabName, itemId);
                        debugLog(`Fetching full data for ${tabName} ${itemId} from ${getEndpoint}`, 'info');
                        
                        const getResponse = await fetch(getEndpoint);
                        if (!getResponse.ok) {
                            const errorText = await getResponse.text();
                            throw new Error(`Failed to fetch item: ${getResponse.status} ${getResponse.statusText} - ${errorText}`);
                        }
                        
                        const fullData = await getResponse.json();
                        const originalName = fullData[nameField] || fullData.title || fullData.name || 'Untitled';
                        
                        // 2. Sanitize: Remove read-only system fields
                        // Start with common system/read-only fields that Canvas API doesn't accept on create
                        const systemReadOnlyFields = [
                            'id', 'uuid', 'created_at', 'updated_at', 'html_url', 'url', 
                            'locked_for_user', 'position', 'assignment_id', 'quiz_id', 
                            'workflow_state', 'user_count', 'view_count', 'reply_count',
                            'pinned', 'posted_at', 'last_reply_at', 'require_initial_post',
                            'delayed_post_at', 'locked', 'group_category_id', 'is_section_specific',
                            'due_date_string', 'lock_at_string', 'unlock_at_string', 'lock_info',
                            'lock_explanation', 'speed_grader_url', 'quiz_extensions_url',
                            'permissions', 'submission', 'overrides', 'all_dates',
                            'can_duplicate', 'original_assignment_id', 'original_assignment_name',
                            'original_quiz_id', 'original_course_id', 'original_course_name',
                            'course_id', 'context_type', 'context_id',
                            // LTI identifiers
                            'lti_context_id', 'global_id', 'secure_params', 'original_lti_resource_link_id'
                        ];
                        
                        // Known safe ID fields that are editable and should be kept
                        const safeIdFields = new Set([
                            'assignment_group_id', 'grading_standard_id', 'prerequisite_module_ids'
                        ]);
                        
                        // Get read-only fields from FIELD_DEFINITIONS (editable: false)
                        const forbiddenKeys = new Set(systemReadOnlyFields);
                        const fieldDefs = FIELD_DEFINITIONS[tabName];
                        if (fieldDefs) {
                            fieldDefs.forEach(field => {
                                if (field.editable === false) {
                                    forbiddenKeys.add(field.name);
                                }
                            });
                        }
                        
                        // Build sanitized payload - only include fields that are NOT forbidden
                        // (forbiddenKeys already includes all read-only fields from FIELD_DEFINITIONS)
                        let sanitizedBase = {};
                        Object.keys(fullData).forEach(key => {
                            // Skip if explicitly forbidden
                            if (forbiddenKeys.has(key)) {
                                return;
                            }
                            
                            // Strip any keys ending in "_id" that aren't in our safe list
                            // This catches any remaining ID fields we might have missed
                            if (key.endsWith('_id') && !safeIdFields.has(key)) {
                                return;
                            }
                            
                            // Include the field
                            sanitizedBase[key] = fullData[key];
                        });
                        
                        // 3. Loop through requested number of copies
                        // Track items created in this batch to ensure unique names
                        const batchCreatedItems = [];
                        
                        for (let copyNum = 1; copyNum <= quantity; copyNum++) {
                            try {
                                // Show progress
                                const progressMsg = `Creating Copy ${copyNum} of ${quantity} for '${originalName}'...`;
                                debugLog(progressMsg, 'info');
                                
                                const payload = { ...sanitizedBase };
                                
                                // Handle incrementing names - pass batchCreatedItems to avoid duplicates
                                const newName = generateIncrementedName(originalName, tabName, copyNum, batchCreatedItems);
                                
                                if (payload.title !== undefined) payload.title = newName;
                                else if (payload.name !== undefined) payload.name = newName;
                                
                                // For pages, generate a new URL from the original
                                if (tabName === 'pages' && fullData.url) {
                                    const baseUrl = fullData.url.replace(/[^/]+$/, ''); // Get directory part
                                    const urlSafeTitle = newName.toLowerCase()
                                        .replace(/[^a-z0-9]+/g, '-')
                                        .replace(/^-+|-+$/g, '');
                                    payload.url = baseUrl + urlSafeTitle;
                                }
                                
                                // Prepare request body based on tab type
                                let requestBody;
                                if (tabName === 'assignments') {
                                    requestBody = { assignment: payload };
                                } else if (tabName === 'quizzes') {
                                    requestBody = { quiz: payload };
                                } else if (tabName === 'pages') {
                                    requestBody = { wiki_page: payload };
                                } else {
                                    // discussions and announcements
                                    requestBody = payload;
                                    if (tabName === 'announcements') {
                                        requestBody.is_announcement = true;
                                    }
                                }
                                
                                // 4. POST the new item back to Canvas
                                const postResponse = await fetch(createEndpoint, {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json',
                                    },
                                    body: JSON.stringify(requestBody),
                                });
                                
                                if (!postResponse.ok) {
                                    const errorText = await postResponse.text();
                                    throw new Error(`${postResponse.status} ${postResponse.statusText}: ${errorText}`);
                                }
                                
                                const newItem = await postResponse.json();
                                
                                // Immediately add to originalData so next iteration sees it
                                const newItemId = newItem.id || newItem.url;
                                if (!originalData[tabName]) originalData[tabName] = {};
                                originalData[tabName][newItemId] = newItem;
                                
                                // Add to batch created items for name checking
                                batchCreatedItems.push(newItem);
                                
                                createdItems.push(newItem);
                                successCount++;
                                
                            } catch (error) {
                                debugLog(`Failed to create copy ${copyNum} of ${itemId}: ${error.message}`, 'error');
                                failedItems.push({ itemId, copyNum, name: originalName, error: error.message });
                            }
                        }
                        
                    } catch (error) {
                        debugLog(`Failed to fetch item ${itemId}: ${error.message}`, 'error');
                        failedItems.push({ itemId, copyNum: 0, name: 'Unknown', error: `Failed to fetch: ${error.message}` });
                    }
                }
                
                // Add successfully created items to the table
                if (createdItems.length > 0) {
                    await addItemsToTable(tabName, createdItems);
                }
                
                // Show summary
                let message = `Successfully created ${successCount} copy/copies.`;
                if (failedItems.length > 0) {
                    message += `\n\nFailed to create ${failedItems.length} copy/copies:`;
                    failedItems.forEach(item => {
                        if (item.copyNum === 0) {
                            message += `\n- Item ${item.itemId}: ${item.error}`;
                        } else {
                            message += `\n- Copy ${item.copyNum} of '${item.name}': ${item.error}`;
                        }
                    });
                }
                alert(message);
                
            } catch (error) {
                debugLog(`Duplicate operation failed: ${error.message}`, 'error');
                alert(`Error during duplication: ${error.message}`);
            } finally {
                // Re-enable button
                if (duplicateBtn) {
                    duplicateBtn.disabled = false;
                    duplicateBtn.textContent = '➕ Duplicate Selected';
                }
                pendingDuplication = null;
            }
        }

        // Module Three-Way Clone execution
        async function executeModuleClone() {
            if (!pendingModuleClone) {
                closeModal('moduleCloneModal');
                return;
            }

            const { tabName, selected } = pendingModuleClone;
            const courseId = getCurrentCourseId();
            if (!courseId) {
                alert('No course selected.');
                closeModal('moduleCloneModal');
                pendingModuleClone = null;
                return;
            }

            // Get selected clone type
            const cloneTypeRadio = document.querySelector('input[name="cloneType"]:checked');
            if (!cloneTypeRadio) {
                alert('Please select a clone type.');
                return;
            }
            const cloneType = cloneTypeRadio.value;

            // Show progress container for deep copy
            const progressContainer = document.getElementById('moduleCloneProgressContainer');
            const progressBar = document.getElementById('moduleCloneProgressBar');
            const progressText = document.getElementById('moduleCloneProgressText');
            const executeBtn = document.getElementById('moduleCloneExecuteBtn');

            if (cloneType === 'deepCopy' && progressContainer) {
                progressContainer.style.display = 'block';
            }

            if (executeBtn) {
                executeBtn.disabled = true;
                executeBtn.textContent = 'Cloning...';
            }

            const createdModules = [];
            let totalItems = 0;
            let processedItems = 0;
            let errors = [];

            try {
                // Count total items for progress (only for deep copy)
                if (cloneType === 'deepCopy') {
                    for (const moduleId of selected) {
                        try {
                            const moduleResponse = await fetch(`/canvas/courses/${courseId}/modules/${moduleId}`);
                            if (moduleResponse.ok) {
                                const moduleData = await moduleResponse.json();
                                totalItems += (moduleData.items_count || 0);
                            }
                        } catch (e) {
                            // Continue counting
                        }
                    }
                }

                // Process each selected module
                for (const moduleId of selected) {
                    try {
                        // Fetch full module data (with items)
                        const moduleResponse = await fetch(`/canvas/courses/${courseId}/modules/${moduleId}`);
                        if (!moduleResponse.ok) {
                            throw new Error(`Failed to fetch module: ${moduleResponse.status}`);
                        }
                        const originalModule = await moduleResponse.json();
                        const moduleName = originalModule.name || 'Untitled';

                        // Generate incremented name
                        const newModuleName = generateIncrementedName(moduleName, 'modules', 1);

                        // Sanitize module data (remove read-only fields) - use same pattern as item duplication
                        const systemReadOnlyFields = [
                            'id', 'uuid', 'created_at', 'updated_at', 'items_count', 'items',
                            'html_url', 'workflow_state', 'publish_at', 'course_id', 'context_type', 'context_id',
                            'lti_context_id', 'global_id', 'secure_params', 'original_lti_resource_link_id',
                            'items_url'
                        ];
                        
                        // Known safe ID fields that are editable and should be kept
                        const safeIdFields = new Set(['prerequisite_module_ids']);
                        
                        // Get read-only fields from FIELD_DEFINITIONS (editable: false)
                        const forbiddenKeys = new Set(systemReadOnlyFields);
                        const fieldDefs = FIELD_DEFINITIONS['modules'];
                        if (fieldDefs) {
                            fieldDefs.forEach(field => {
                                if (field.editable === false) {
                                    forbiddenKeys.add(field.name);
                                }
                            });
                        }
                        
                        // Build sanitized payload - only include fields that are NOT forbidden
                        const sanitizedModule = {};
                        Object.keys(originalModule).forEach(key => {
                            // Skip if explicitly forbidden
                            if (forbiddenKeys.has(key)) {
                                return;
                            }
                            
                            // Strip any keys ending in "_id" that aren't in our safe list
                            if (key.endsWith('_id') && !safeIdFields.has(key)) {
                                return;
                            }
                            
                            // On creation, Canvas assigns position automatically, so we shouldn't include it
                            if (key === 'position') {
                                return;
                            }
                            
                            // Include the field
                            sanitizedModule[key] = originalModule[key];
                        });
                        sanitizedModule.name = newModuleName;

                        let newModule;
                        const clonedItemIds = []; // For deep copy: store new item IDs

                        if (cloneType === 'structureOnly') {
                            // Structure Only: Create empty module
                            const createResponse = await fetch(`/canvas/courses/${courseId}/modules`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(sanitizedModule)
                            });

                            if (!createResponse.ok) {
                                const errorText = await createResponse.text();
                                throw new Error(`Failed to create module: ${createResponse.status} - ${errorText}`);
                            }

                            newModule = await createResponse.json();

                        } else if (cloneType === 'structureShared') {
                            // Structure + Shared Content: Create module, then link to original items
                            const createResponse = await fetch(`/canvas/courses/${courseId}/modules`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(sanitizedModule)
                            });

                            if (!createResponse.ok) {
                                const errorText = await createResponse.text();
                                throw new Error(`Failed to create module: ${createResponse.status} - ${errorText}`);
                            }

                            newModule = await createResponse.json();

                            // Add module items pointing to original items
                            if (originalModule.items && originalModule.items.length > 0) {
                                for (const item of originalModule.items) {
                                    try {
                                        console.log(`Adding module item: ${item.title || 'Unknown'} (Type: ${item.type}, Content ID: ${item.content_id})`);
                                        const itemPayload = {
                                            module_item: {
                                                content_id: item.content_id,
                                                type: item.type,
                                                position: item.position,
                                                indent: item.indent || 0
                                            }
                                        };

                                        const itemResponse = await fetch(`/canvas/courses/${courseId}/modules/${newModule.id}/items`, {
                                            method: 'POST',
                                            headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify(itemPayload)
                                        });

                                        if (!itemResponse.ok) {
                                            const errorText = await itemResponse.text();
                                            throw new Error(`Failed to add item: ${itemResponse.status} - ${errorText}`);
                                        }
                                    } catch (error) {
                                        errors.push({ module: moduleName, item: item.title || 'Unknown', error: error.message });
                                    }
                                }
                            }

                        } else if (cloneType === 'deepCopy') {
                            // Deep Copy: Create module, duplicate all items, then link new items
                            const createResponse = await fetch(`/canvas/courses/${courseId}/modules`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(sanitizedModule)
                            });

                            if (!createResponse.ok) {
                                const errorText = await createResponse.text();
                                throw new Error(`Failed to create module: ${createResponse.status} - ${errorText}`);
                            }

                            newModule = await createResponse.json();

                            // Deep copy each item
                            // Track which items were successfully cloned to maintain correct mapping
                            const clonedItemsMap = new Map(); // Maps original item index to cloned item data
                            // Track items created in this batch for unique naming
                            const batchCreatedItems = [];
                            
                            if (originalModule.items && originalModule.items.length > 0) {
                                // Use for...of loop with async/await instead of forEach
                                for (let itemIndex = 0; itemIndex < originalModule.items.length; itemIndex++) {
                                    const item = originalModule.items[itemIndex];
                                    try {
                                        processedItems++;
                                        if (progressBar) {
                                            const percent = Math.round((processedItems / totalItems) * 100);
                                            progressBar.style.width = percent + '%';
                                            progressBar.textContent = percent + '%';
                                        }
                                        if (progressText) {
                                            progressText.textContent = `Cloning item ${processedItems} of ${totalItems}: ${item.title || 'Unknown'}...\n` + (progressText.textContent || '');
                                        }

                                        // Map Canvas item types to our tab names and Canvas API types
                                        let itemTabName;
                                        let canvasType;
                                        if (item.type === 'Assignment') {
                                            itemTabName = 'assignments';
                                            canvasType = 'Assignment';
                                        } else if (item.type === 'Quiz') {
                                            itemTabName = 'quizzes';
                                            canvasType = 'Quiz';
                                        } else if (item.type === 'Page') {
                                            itemTabName = 'pages';
                                            canvasType = 'WikiPage';
                                        } else if (item.type === 'Discussion') {
                                            itemTabName = 'discussions';
                                            canvasType = 'Discussion';
                                        } else if (item.type === 'File') {
                                            canvasType = 'Attachment';
                                            // For files, we can't clone, so link to original (use original name)
                                            clonedItemsMap.set(itemIndex, { 
                                                id: item.content_id, 
                                                type: canvasType, 
                                                originalItem: item,
                                                clonedName: item.title || 'Untitled'
                                            });
                                            continue;
                                        } else if (item.type === 'ExternalTool' || item.type === 'ExternalUrl') {
                                            canvasType = 'ContextExternalTool';
                                            // For external tools, we can't clone, so link to original (use original name)
                                            clonedItemsMap.set(itemIndex, { 
                                                id: item.content_id, 
                                                type: canvasType, 
                                                originalItem: item,
                                                clonedName: item.title || 'Untitled'
                                            });
                                            continue;
                                        } else {
                                            // For other unsupported types, link to original (use original name)
                                            clonedItemsMap.set(itemIndex, { 
                                                id: item.content_id, 
                                                type: item.type, 
                                                originalItem: item,
                                                clonedName: item.title || 'Untitled'
                                            });
                                            continue;
                                        }

                                        // Fetch the full item data
                                        // For pages, module items may have page_url or url field instead of using content_id
                                        // Canvas API uses page_url for Page type items, but sometimes it's just url
                                        let itemIdentifier = item.content_id;
                                        if (itemTabName === 'pages') {
                                            if (item.page_url) {
                                                itemIdentifier = item.page_url;
                                            } else if (item.url) {
                                                itemIdentifier = item.url;
                                            } else {
                                                // Last resort: try to construct URL from title or use content_id as URL
                                                // But this is unlikely to work, so throw an error
                                                throw new Error(`Page item missing page_url/url. Cannot fetch page with content_id: ${item.content_id}. Item: ${JSON.stringify(item)}`);
                                            }
                                        }
                                        const itemGetEndpoint = getCanvasItemEndpoint(itemTabName, itemIdentifier);
                                        const itemGetResponse = await fetch(itemGetEndpoint);
                                        if (!itemGetResponse.ok) {
                                            throw new Error(`Failed to fetch ${itemTabName} ${itemIdentifier}`);
                                        }
                                        const originalItem = await itemGetResponse.json();

                                        // Sanitize item data (reuse logic from proceedWithDuplication)
                                        const systemReadOnlyFields = [
                                            'id', 'uuid', 'created_at', 'updated_at', 'html_url', 'url',
                                            'locked_for_user', 'position', 'assignment_id', 'quiz_id',
                                            'workflow_state', 'user_count', 'view_count', 'reply_count',
                                            'pinned', 'posted_at', 'last_reply_at', 'require_initial_post',
                                            'delayed_post_at', 'locked', 'group_category_id', 'is_section_specific',
                                            'due_date_string', 'lock_at_string', 'unlock_at_string', 'lock_info',
                                            'lock_explanation', 'speed_grader_url', 'quiz_extensions_url',
                                            'permissions', 'submission', 'overrides', 'all_dates',
                                            'can_duplicate', 'original_assignment_id', 'original_assignment_name',
                                            'original_quiz_id', 'original_course_id', 'original_course_name',
                                            'course_id', 'context_type', 'context_id',
                                            'lti_context_id', 'global_id', 'secure_params', 'original_lti_resource_link_id'
                                        ];

                                        const safeIdFields = new Set(['assignment_group_id', 'grading_standard_id', 'prerequisite_module_ids']);
                                        const forbiddenKeys = new Set(systemReadOnlyFields);
                                        const fieldDefs = FIELD_DEFINITIONS[itemTabName];
                                        if (fieldDefs) {
                                            fieldDefs.forEach(field => {
                                                if (field.editable === false) {
                                                    forbiddenKeys.add(field.name);
                                                }
                                            });
                                        }

                                        let sanitizedItem = {};
                                        const nameField = getNameFieldName(itemTabName);
                                        const originalName = originalItem[nameField] || originalItem.title || originalItem.name || 'Untitled';
                                        // Pass batchCreatedItems to ensure unique names during deep copy
                                        const newItemName = generateIncrementedName(originalName, itemTabName, 1, batchCreatedItems);

                                        Object.keys(originalItem).forEach(key => {
                                            if (forbiddenKeys.has(key)) return;
                                            if (key.endsWith('_id') && !safeIdFields.has(key)) return;
                                            sanitizedItem[key] = originalItem[key];
                                        });

                                        // Update name
                                        if (sanitizedItem.title !== undefined) sanitizedItem.title = newItemName;
                                        else if (sanitizedItem.name !== undefined) sanitizedItem.name = newItemName;

                                        // Handle pages URL
                                        if (itemTabName === 'pages' && originalItem.url) {
                                            const baseUrl = originalItem.url.replace(/[^/]+$/, '');
                                            const urlSafeTitle = newItemName.toLowerCase()
                                                .replace(/[^a-z0-9]+/g, '-')
                                                .replace(/^-+|-+$/g, '');
                                            sanitizedItem.url = baseUrl + urlSafeTitle;
                                        }

                                        // Prepare request body
                                        let requestBody;
                                        const createEndpoint = getCanvasCreateEndpoint(itemTabName);
                                        if (itemTabName === 'assignments') {
                                            requestBody = { assignment: sanitizedItem };
                                        } else if (itemTabName === 'quizzes') {
                                            requestBody = { quiz: sanitizedItem };
                                        } else if (itemTabName === 'pages') {
                                            requestBody = { wiki_page: sanitizedItem };
                                        } else {
                                            requestBody = sanitizedItem;
                                        }

                                        // Create the duplicate item
                                        const itemCreateResponse = await fetch(createEndpoint, {
                                            method: 'POST',
                                            headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify(requestBody)
                                        });

                                        if (!itemCreateResponse.ok) {
                                            const errorText = await itemCreateResponse.text();
                                            throw new Error(`Failed to create ${itemTabName}: ${itemCreateResponse.status} - ${errorText}`);
                                        }

                                        const newItem = await itemCreateResponse.json();
                                        // For pages, use URL (slug) property - Canvas Pages use URL slugs, not numeric IDs
                                        // The url property is the page slug that must be used for module_item[page_url]
                                        const itemId = itemTabName === 'pages' ? (newItem.url || newItem.page_url) : (newItem.id);
                                        if (!itemId) {
                                            throw new Error(`Failed to get URL for cloned page. Response: ${JSON.stringify(newItem)}`);
                                        }
                                        
                                        // Immediately add to originalData so next iteration sees it for unique naming
                                        if (!originalData[itemTabName]) originalData[itemTabName] = {};
                                        originalData[itemTabName][itemId] = newItem;
                                        
                                        // Add to batch created items for name checking
                                        batchCreatedItems.push(newItem);
                                        
                                        // Get the new item's name/title (the cloned name, not the original)
                                        // nameField is already declared above, so reuse it
                                        const clonedItemName = newItem[nameField] || newItem.title || newItem.name || newItemName;
                                        
                                        console.log(`Cloned ${itemTabName} "${originalName}" -> "${clonedItemName}" (New URL/ID: ${itemId}). Now adding to Module ${newModule.id}...`);
                                        // Store cloned item with its original index for correct mapping, including the new name
                                        clonedItemsMap.set(itemIndex, { 
                                            id: itemId, 
                                            type: canvasType, 
                                            originalItem: item,
                                            clonedName: clonedItemName
                                        });
                                        
                                        // Add brief delay to allow Canvas to finish processing the clone
                                        await new Promise(resolve => setTimeout(resolve, 500));

                                    } catch (error) {
                                        errors.push({ module: moduleName, item: item.title || 'Unknown', error: error.message });
                                        processedItems--;
                                        // Don't add to clonedItemsMap if cloning failed
                                    }
                                }

                                // Add module items pointing to the new duplicated items
                                // Use the map to ensure we only add successfully cloned items in the correct order
                                for (let itemIndex = 0; itemIndex < originalModule.items.length; itemIndex++) {
                                    const originalItem = originalModule.items[itemIndex];
                                    const clonedItemData = clonedItemsMap.get(itemIndex);
                                    
                                    // Skip if this item wasn't successfully cloned
                                    if (!clonedItemData) {
                                        console.log(`Skipping item ${itemIndex} (${originalItem.title || 'Unknown'}) - cloning failed`);
                                        continue;
                                    }
                                    
                                    const clonedItem = clonedItemData;
                                    
                                    try {
                                        // Use the cloned item's name, not the original item's name
                                        const itemTitle = clonedItem.clonedName || originalItem.title || 'Untitled';
                                        console.log(`Adding cloned item to module: "${itemTitle}" (Type: ${clonedItem.type}, ID: ${clonedItem.id})`);
                                        const itemPayload = {
                                            module_item: {
                                                type: clonedItem.type,
                                                title: itemTitle,
                                                position: originalItem.position,
                                                indent: originalItem.indent || 0
                                            }
                                        };
                                        
                                        // For pages (WikiPage), use page_url instead of content_id
                                        if (clonedItem.type === 'WikiPage') {
                                            itemPayload.module_item.page_url = clonedItem.id;
                                        } else {
                                            itemPayload.module_item.content_id = clonedItem.id;
                                        }

                                        const itemResponse = await fetch(`/canvas/courses/${courseId}/modules/${newModule.id}/items`, {
                                            method: 'POST',
                                            headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify(itemPayload)
                                        });

                                        if (!itemResponse.ok) {
                                            const errorText = await itemResponse.text();
                                            throw new Error(`Failed to add item: ${itemResponse.status} - ${errorText}`);
                                        }
                                    } catch (error) {
                                        errors.push({ module: moduleName, item: originalItem.title || 'Module Item', error: error.message });
                                    }
                                }
                            }
                        }

                        createdModules.push(newModule);

                    } catch (error) {
                        errors.push({ module: 'Unknown', item: 'Module', error: error.message });
                    }
                }

                // Add created modules to table
                if (createdModules.length > 0) {
                    await addItemsToTable('modules', createdModules);
                }

                // Show summary
                let message = `Successfully cloned ${createdModules.length} module(s) using "${cloneType === 'structureOnly' ? 'Structure Only' : cloneType === 'structureShared' ? 'Structure + Shared Content' : 'Deep Copy'}" method.`;
                if (errors.length > 0) {
                    message += `\n\nErrors encountered: ${errors.length}`;
                    errors.slice(0, 5).forEach(err => {
                        message += `\n- ${err.module}: ${err.item} - ${err.error}`;
                    });
                    if (errors.length > 5) {
                        message += `\n... and ${errors.length - 5} more errors`;
                    }
                }
                alert(message);

                closeModal('moduleCloneModal');
                pendingModuleClone = null;

            } catch (error) {
                debugLog(`Module clone failed: ${error.message}`, 'error');
                alert(`Error during module cloning: ${error.message}`);
            } finally {
                if (executeBtn) {
                    executeBtn.disabled = false;
                    executeBtn.textContent = 'Clone Module(s)';
                }
                if (progressContainer) {
                    progressContainer.style.display = 'none';
                }
            }
        }


        // Backup function - creates a course export
        async function runCanvasBackup() {
            const courseId = getCurrentCourseId();
            if (!courseId) {
                throw new Error('No course selected');
            }

            try {
                const response = await fetch(`/canvas/courses/${courseId}/content_exports`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        export_type: 'common_cartridge',
                    }),
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`Failed to create backup: ${response.status} ${response.statusText} - ${errorText}`);
                }

                const result = await response.json();
                debugLog(`Course export backup initiated successfully: ${JSON.stringify(result)}`, 'info');
                return true;
            } catch (error) {
                debugLog(`Failed to create backup: ${error.message}`, 'error');
                throw error;
            }
        }

        async function handleDeleteSelected() {
            const tabName = getCurrentTabName();
            if (!tabName) {
                alert('Please select a tab first.');
                return;
            }

            const courseId = getCurrentCourseId();
            if (!courseId) {
                alert('No course selected.');
                return;
            }

            const selected = getSelectedItems();
            if (selected.length === 0) {
                alert('Please select at least one item.');
                return;
            }

            const itemType = tabName === 'assignments' ? 'Assignments' : 
                            tabName === 'quizzes' ? 'Quizzes' : 
                            tabName.charAt(0).toUpperCase() + tabName.slice(1);

            // Ask about backup first
            const wantBackup = confirm(`Do you want to generate a Course Export (Backup) before deleting these ${selected.length} items?`);
            let backupInitiated = false;

            if (wantBackup) {
                try {
                    // Disable button during backup
                    const deleteBtn = document.getElementById('deleteSelectedBtn');
                    if (deleteBtn) {
                        deleteBtn.disabled = true;
                        deleteBtn.textContent = 'Creating backup...';
                    }

                    await runCanvasBackup();
                    backupInitiated = true;
                    
                    if (deleteBtn) {
                        deleteBtn.textContent = '🗑️ Delete Selected';
                    }
                } catch (error) {
                    // Show error but allow user to proceed with deletion if they want
                    const proceedAnyway = confirm(`Backup failed: ${error.message}\n\nDo you want to proceed with deletion anyway?`);
                    if (!proceedAnyway) {
                        const deleteBtn = document.getElementById('deleteSelectedBtn');
                        if (deleteBtn) deleteBtn.disabled = false;
                        return;
                    }
                }
            }

            let deleteOption = null;
            
            if (tabName === 'files') {
                openFileOperationsModal();
                return;
            }
            
            if (tabName === 'modules') {
                showModuleDeleteOptions(selected, async (option) => {
                    deleteOption = option;
                    await proceedWithModuleDeletion(selected, deleteOption, backupInitiated, tabName, courseId);
                });
                return;
            }

            // Final confirmation for non-module items
            const confirmed = confirm(`Are you sure you want to permanently delete ${selected.length} items from Canvas?`);
            if (!confirmed) {
                const deleteBtn = document.getElementById('deleteSelectedBtn');
                if (deleteBtn) deleteBtn.disabled = false;
                return;
            }

            // Disable button during deletion
            const deleteBtn = document.getElementById('deleteSelectedBtn');
            if (deleteBtn) {
                deleteBtn.disabled = true;
                deleteBtn.textContent = 'Deleting...';
            }

            let successCount = 0;
            let failedItems = [];

            // Delete items one by one
            for (const itemId of selected) {
                try {
                    const endpoint = getCanvasItemEndpoint(tabName, itemId);
                    debugLog(`Deleting ${tabName} ${itemId} via ${endpoint}`, 'info');

                    const response = await fetch(endpoint, {
                        method: 'DELETE',
                    });

                    if (!response.ok) {
                        const errorText = await response.text();
                        throw new Error(`${response.status} ${response.statusText}: ${errorText}`);
                    }

                    // Successfully deleted - remove from UI
                    // Find a cell with this item-id and get its parent row
                    const cell = document.querySelector(`#tab-${tabName} [data-item-id="${itemId}"]`);
                    if (cell) {
                        const row = cell.closest('tr');
                        if (row) {
                            row.remove();
                        }
                    }

                    // Remove from selectedItems
                    if (selectedItems[tabName]) {
                        selectedItems[tabName].delete(itemId);
                    }

                    // Remove from originalData
                    if (originalData[tabName] && originalData[tabName][itemId]) {
                        delete originalData[tabName][itemId];
                    }

                    // Remove from changes if present
                    if (changes[tabName] && changes[tabName][itemId]) {
                        delete changes[tabName][itemId];
                    }

                    successCount++;
                } catch (error) {
                    debugLog(`Failed to delete ${tabName} ${itemId}: ${error.message}`, 'error');
                    failedItems.push({ id: itemId, error: error.message });
                    // Keep the row in the table so user knows it failed
                }
            }

            // Re-enable button
            if (deleteBtn) {
                deleteBtn.disabled = false;
                deleteBtn.textContent = '🗑️ Delete Selected';
            }

            // Update sidebar content (to handle empty selection case)
            updateSidebarContent();

            // Show summary
            const backupStatus = backupInitiated ? 'Yes' : 'No';
            let message = `Successfully deleted ${successCount} item(s) (Backup initiated: ${backupStatus}).`;
            if (failedItems.length > 0) {
                message += `\n\nFailed to delete ${failedItems.length} item(s):`;
                failedItems.forEach(item => {
                    message += `\n- Item ${item.id}: ${item.error}`;
                });
            }
            alert(message);
        }

        function showModuleDeleteOptions(moduleIds, callback) {
            const modal = document.getElementById('moduleDeleteOptionsModal');
            const messageEl = document.getElementById('moduleDeleteMessage');
            const deleteModuleOnlyBtn = document.getElementById('deleteModuleOnlyBtn');
            const deleteModuleAndItemsBtn = document.getElementById('deleteModuleAndItemsBtn');
            
            if (!modal || !messageEl || !deleteModuleOnlyBtn || !deleteModuleAndItemsBtn) {
                alert('Modal elements not found');
                return;
            }
            
            const count = moduleIds.length;
            const plural = count !== 1 ? 's' : '';
            messageEl.textContent = `You are about to delete ${count} module${plural}. Choose an option:`;
            
            const cleanup = () => {
                deleteModuleOnlyBtn.onclick = null;
                deleteModuleAndItemsBtn.onclick = null;
                closeModal('moduleDeleteOptionsModal');
            };
            
            deleteModuleOnlyBtn.onclick = () => {
                cleanup();
                callback('module-only');
            };
            
            deleteModuleAndItemsBtn.onclick = () => {
                cleanup();
                callback('module-and-items');
            };
            
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        async function proceedWithModuleDeletion(selected, deleteOption, backupInitiated, tabName, courseId) {
            const deleteBtn = document.getElementById('deleteSelectedBtn');
            if (deleteBtn) {
                deleteBtn.disabled = true;
                deleteBtn.textContent = 'Deleting...';
            }

            let successCount = 0;
            let failedItems = [];
            let deletedItemsCount = 0;
            let failedItemDetails = [];

            for (const moduleId of selected) {
                let moduleItemErrors = [];
                let allItemsSucceeded = true;
                
                try {
                    if (deleteOption === 'module-and-items') {
                        try {
                            const itemsResponse = await fetch(`/canvas/courses/${courseId}/modules/${moduleId}/items`);
                            if (!itemsResponse.ok) {
                                throw new Error(`Failed to fetch module items: ${itemsResponse.status}`);
                            }
                            
                            const moduleItems = await itemsResponse.json();
                            
                            for (const item of moduleItems) {
                                if (item.type === 'ExternalTool' || item.type === 'ExternalUrl' || item.type === 'SubHeader' || item.type === 'ContextExternalTool') {
                                    debugLog(`Skipping unsupported module item type: ${item.type}`, 'warn');
                                    continue;
                                }
                                
                                try {
                                    const deleteItemResponse = await fetch(`/canvas/courses/${courseId}/modules/${moduleId}/items/${item.id}`, {
                                        method: 'DELETE',
                                        headers: {
                                            'Content-Type': 'application/json',
                                        },
                                        body: JSON.stringify({
                                            type: item.type,
                                            content_id: item.type === 'Page' ? (item.content_id || item.page_url || item.url || item.id) : (item.content_id || item.id)
                                        })
                                    });
                                    
                                    if (!deleteItemResponse.ok) {
                                        const errorText = await deleteItemResponse.text();
                                        throw new Error(`${deleteItemResponse.status} ${deleteItemResponse.statusText}: ${errorText}`);
                                    }
                                    
                                    deletedItemsCount++;
                                } catch (error) {
                                    allItemsSucceeded = false;
                                    const itemInfo = {
                                        type: item.type,
                                        content_id: item.type === 'Page' ? (item.content_id || item.page_url || item.url || item.id) : (item.content_id || item.id),
                                        title: item.title || 'Unknown',
                                        error: error.message
                                    };
                                    moduleItemErrors.push(itemInfo);
                                    failedItemDetails.push({
                                        moduleId: moduleId,
                                        item: itemInfo
                                    });
                                    debugLog(`Failed to delete module item ${item.id} (${item.type}): ${error.message}`, 'error');
                                }
                            }
                            
                            if (!allItemsSucceeded) {
                                failedItems.push({
                                    id: moduleId,
                                    error: `Failed to delete ${moduleItemErrors.length} item(s) in module`,
                                    itemErrors: moduleItemErrors
                                });
                                continue;
                            }
                        } catch (error) {
                            allItemsSucceeded = false;
                            failedItems.push({
                                id: moduleId,
                                error: `Failed to fetch items: ${error.message}`,
                                itemErrors: []
                            });
                            debugLog(`Failed to fetch items for module ${moduleId}: ${error.message}`, 'error');
                            continue;
                        }
                    }
                    
                    const endpoint = getCanvasItemEndpoint(tabName, moduleId);
                    debugLog(`Deleting ${tabName} ${moduleId} via ${endpoint}`, 'info');

                    const response = await fetch(endpoint, {
                        method: 'DELETE',
                    });

                    if (!response.ok) {
                        const errorText = await response.text();
                        throw new Error(`${response.status} ${response.statusText}: ${errorText}`);
                    }

                    const cell = document.querySelector(`#tab-${tabName} [data-item-id="${moduleId}"]`);
                    if (cell) {
                        const row = cell.closest('tr');
                        if (row) {
                            row.remove();
                        }
                    }

                    if (selectedItems[tabName]) {
                        selectedItems[tabName].delete(moduleId);
                    }

                    if (originalData[tabName] && originalData[tabName][moduleId]) {
                        delete originalData[tabName][moduleId];
                    }

                    if (changes[tabName] && changes[tabName][moduleId]) {
                        delete changes[tabName][moduleId];
                    }

                    successCount++;
                } catch (error) {
                    debugLog(`Failed to delete ${tabName} ${moduleId}: ${error.message}`, 'error');
                    failedItems.push({ id: moduleId, error: error.message, itemErrors: [] });
                }
            }

            if (deleteBtn) {
                deleteBtn.disabled = false;
                deleteBtn.textContent = '🗑️ Delete Selected';
            }

            updateSidebarContent();

            const backupStatus = backupInitiated ? 'Yes' : 'No';
            let message = '';
            
            if (successCount > 0) {
                message = `Successfully deleted ${successCount} module(s) (Backup initiated: ${backupStatus}).`;
                if (deleteOption === 'module-and-items') {
                    message += `\n\nDeleted ${deletedItemsCount} item(s) from module(s).`;
                }
            } else {
                message = `No modules were deleted (Backup initiated: ${backupStatus}).`;
            }
            
            if (failedItems.length > 0) {
                message += `\n\nFailed to delete ${failedItems.length} module(s):`;
                failedItems.forEach(module => {
                    message += `\n\nModule ${module.id}: ${module.error}`;
                    if (module.itemErrors && module.itemErrors.length > 0) {
                        message += `\n  Failed items:`;
                        module.itemErrors.forEach(item => {
                            message += `\n    - ${item.type} "${item.title}" (ID: ${item.content_id}): ${item.error}`;
                        });
                    }
                });
            }
            
            alert(message);
            document.body.style.overflow = '';
        }

        // Update Assign To button visibility based on active tab
        function updateButtonVisibility(tabName) {
            const assignToOption = document.getElementById('assignToOption');
            const assignToInfoIcon = document.getElementById('assignToInfoIcon');
            const dropdown = document.getElementById('editModeDropdown');
            
            if (!assignToOption || !assignToInfoIcon || !dropdown) return;
            
            // Tabs that support Assign To: assignments, quizzes, discussions
            const supportedTabs = ['assignments', 'quizzes', 'discussions'];
            const isSupported = supportedTabs.includes(tabName);
            
            if (isSupported) {
                // Enable the option
                assignToOption.disabled = false;
                assignToOption.title = '';
                assignToInfoIcon.style.display = 'none';
                
                // If the dropdown currently has assignTo selected and we're switching to an unsupported tab,
                // clear the selection (this is handled by the fact that we disable it, but let's be explicit)
                if (dropdown.value === 'assignTo') {
                    dropdown.value = '';
                }
            } else {
                // Disable the option
                assignToOption.disabled = true;
                assignToOption.title = 'Canvas only supports individual student assignments for graded items (Assignments, Quizzes, and Graded Discussions).';
                
                // Show info icon
                assignToInfoIcon.style.display = 'block';
                
                // Clear the selection if it was set to assignTo
                if (dropdown.value === 'assignTo') {
                    dropdown.value = '';
                }
            }
            
            // Clear any pending Assign To selections in the table
            // This would clear any UI state related to Assign To if it exists
            clearAssignToSelections(tabName);
        }
        
        // Clear any pending Assign To selections when switching tabs
        function clearAssignToSelections(tabName) {
