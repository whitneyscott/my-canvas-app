                fileList.innerHTML = files.map(f => `<div style="padding: 5px 0;">${escapeHtml(f)}</div>`).join('');
            }

            const renameOptions = document.getElementById('fileRenameOptions');
            if (renameOptions) renameOptions.style.display = 'none';
            
            const progressContainer = document.getElementById('fileOperationsProgressContainer');
            if (progressContainer) {
                progressContainer.style.display = 'none';
                const progressText = document.getElementById('fileOperationsProgressText');
                if (progressText) progressText.innerHTML = '';
            }

            openModal('fileOperationsModal');
        }

        function showFileRenameOptions() {
            const renameOptions = document.getElementById('fileRenameOptions');
            if (renameOptions) {
                renameOptions.style.display = renameOptions.style.display === 'none' ? 'block' : 'none';
            }
        }

        async function executeFileDownload() {
            if (!pendingFileOperations) {
                closeModal('fileOperationsModal');
                return;
            }

            const { selected } = pendingFileOperations;
            const courseId = getCurrentCourseId();
            if (!courseId) {
                alert('No course selected.');
                return;
            }

            const progressContainer = document.getElementById('fileOperationsProgressContainer');
            const progressText = document.getElementById('fileOperationsProgressText');
            if (progressContainer) progressContainer.style.display = 'block';
            if (progressText) progressText.innerHTML = 'Downloading files...<br>';

            for (const fileId of selected) {
                try {
                    const file = originalData['files']?.[fileId];
                    if (!file) continue;
                    
                    const downloadUrl = file.url || file.download_url;
                    if (downloadUrl) {
                        window.open(downloadUrl, '_blank');
                        if (progressText) progressText.innerHTML += `✓ Opened download for: ${escapeHtml(file.display_name || file.filename || fileId)}<br>`;
                    } else {
                        if (progressText) progressText.innerHTML += `✗ No download URL for: ${escapeHtml(file.display_name || file.filename || fileId)}<br>`;
                    }
                } catch (error) {
                    if (progressText) progressText.innerHTML += `✗ Error downloading file ${fileId}: ${error.message}<br>`;
                }
            }
        }

        async function executeFileRename() {
            if (!pendingFileOperations) {
                closeModal('fileOperationsModal');
                return;
            }

            const { selected } = pendingFileOperations;
            const courseId = getCurrentCourseId();
            if (!courseId) {
                alert('No course selected.');
                return;
            }

            const renamePattern = document.getElementById('fileRenamePattern')?.value?.trim();
            if (!renamePattern) {
                alert('Please enter a rename pattern.');
                return;
            }

            const progressContainer = document.getElementById('fileOperationsProgressContainer');
            const progressText = document.getElementById('fileOperationsProgressText');
            if (progressContainer) progressContainer.style.display = 'block';
            if (progressText) progressText.innerHTML = 'Renaming files...<br>';

            for (const fileId of selected) {
                try {
                    const file = originalData['files']?.[fileId];
                    if (!file) continue;

                    let newName = renamePattern;
                    if (selected.length > 1) {
                        const fileName = file.display_name || file.filename || '';
                        const nameWithoutExt = fileName.replace(/\.[^/.]+$/, '');
                        const ext = fileName.match(/\.[^/.]+$/)?.[0] || '';
                        newName = renamePattern.replace(/{name}/g, nameWithoutExt).replace(/{ext}/g, ext);
                    }

                    const response = await fetch(`/canvas/courses/${courseId}/files/${fileId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ name: newName })
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }

                    if (progressText) progressText.innerHTML += `✓ Renamed: ${escapeHtml(file.display_name || fileId)} → ${escapeHtml(newName)}<br>`;
                } catch (error) {
                    if (progressText) progressText.innerHTML += `✗ Error renaming file ${fileId}: ${error.message}<br>`;
                }
            }

            setTimeout(() => {
                closeModal('fileOperationsModal');
                refreshTab('files');
            }, 2000);
        }

        async function executeFileDelete() {
            if (!pendingFileOperations) {
                closeModal('fileOperationsModal');
                return;
            }

            const { selected } = pendingFileOperations;
            const courseId = getCurrentCourseId();
            if (!courseId) {
                alert('No course selected.');
                return;
            }

            const fileItems = selected.map(id => {
                const file = originalData['files']?.[id];
                return {
                    id: parseInt(id),
                    isFolder: file?.is_folder || file?.folder || false,
                    name: file?.display_name || file?.filename || id
                };
            });
            
            const folderCount = fileItems.filter(f => f.isFolder).length;
            const fileCount = fileItems.length - folderCount;
            let confirmMessage = `Are you sure you want to delete ${fileItems.length} item(s)?`;
            if (folderCount > 0 && fileCount > 0) {
                confirmMessage += `\n- ${folderCount} folder(s)\n- ${fileCount} file(s)`;
            } else if (folderCount > 0) {
                confirmMessage += `\n- ${folderCount} folder(s)`;
            } else {
                confirmMessage += `\n- ${fileCount} file(s)`;
            }
            confirmMessage += '\n\nThis action cannot be undone.';
            
            if (!confirm(confirmMessage)) {
                return;
            }

            const progressContainer = document.getElementById('fileOperationsProgressContainer');
            const progressText = document.getElementById('fileOperationsProgressText');
            if (progressContainer) progressContainer.style.display = 'block';
            if (progressText) progressText.innerHTML = 'Deleting items...<br>';

            try {
                const response = await fetch(`/canvas/courses/${courseId}/files/bulk`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        fileIds: fileItems.map(f => f.id),
                        isFolders: fileItems.map(f => f.isFolder)
                    })
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`HTTP ${response.status}: ${errorText}`);
                }

                if (progressText) progressText.innerHTML += `✓ Successfully deleted ${fileItems.length} item(s)<br>`;
                
                setTimeout(() => {
                    closeModal('fileOperationsModal');
                    refreshTab('files');
                }, 1500);
            } catch (error) {
                if (progressText) progressText.innerHTML += `✗ Error deleting files: ${error.message}<br>`;
                alert(`Error deleting files: ${error.message}`);
            }
        }

        let accommodationColumns = null;
        let accommodationOptions = ['Time 1.25x', 'Time 1.5x', 'Time 2.0x', 'Extra Attempt', 'Quiet Room'];
        let studentAccommodations = {};
        let originalAccommodations = {};

        async function loadAccommodations(courseId) {
            if (!courseId) {
                console.error('[loadAccommodations] No course ID provided');
                return;
            }
            
            try {
                const ensureResponse = await fetch(`/canvas/courses/${courseId}/accommodations/ensure-columns`);
                if (!ensureResponse.ok) {
                    console.error('[loadAccommodations] Failed to ensure accommodation columns');
                    return;
                }
                accommodationColumns = await ensureResponse.json();
                
                const dataResponse = await fetch(`/canvas/courses/${courseId}/accommodations/data`);
                if (!dataResponse.ok) {
                    console.error('[loadAccommodations] Failed to fetch accommodation data');
                    return;
                }
                
                const accommodationsData = await dataResponse.json();
                
                studentAccommodations = {};
                Object.keys(accommodationsData).forEach(userId => {
                    const accommodationType = accommodationsData[userId];
                    if (accommodationType && accommodationType.trim()) {
                        studentAccommodations[String(userId)] = accommodationType.trim();
                    }
                });
                
                originalAccommodations = JSON.parse(JSON.stringify(studentAccommodations));
                renderAccommodationColumn();
            } catch (error) {
                console.error('[loadAccommodations] Error:', error);
            }
        }

        function renderAccommodationColumn() {
            const rows = document.querySelectorAll('#studentsTableBody tr');
            
            rows.forEach(row => {
                const checkbox = row.querySelector('.row-checkbox');
                if (!checkbox) return;
                
                const studentId = checkbox.getAttribute('data-id');
                const selectedAccommodation = studentAccommodations[studentId] || null;
                
                let accommodationCell = row.querySelector('td.accommodation-cell');
                if (!accommodationCell) {
                    const cells = row.querySelectorAll('td');
                    // Find the first_name cell (second cell with data-item-id after last_name)
                    const firstNameCellIndex = Array.from(cells).findIndex(cell => 
                        cell.getAttribute('data-item-id') === studentId && cell.getAttribute('data-field') === 'first_name'
                    );
                    if (firstNameCellIndex >= 0 && firstNameCellIndex < cells.length - 1) {
                        accommodationCell = document.createElement('td');
                        accommodationCell.className = 'accommodation-cell';
                        row.insertBefore(accommodationCell, cells[firstNameCellIndex + 1]);
                    } else {
                        return;
                    }
                }
                
                let accommodationCheckboxes = '';
                if (accommodationOptions.length === 0) {
                    accommodationCheckboxes = '<span style="color: #999; font-style: italic;">No accommodations available</span>';
                } else {
                    accommodationCheckboxes = '<div class="accommodation-checkboxes">';
                    accommodationOptions.forEach(option => {
                        const checked = selectedAccommodation === option ? 'checked' : '';
                        accommodationCheckboxes += `
                            <label class="accommodation-checkbox-label">
                                <input type="checkbox" 
                                       class="accommodation-checkbox" 
                                       data-student-id="${studentId}" 
                                       value="${escapeHtml(option)}" 
                                       ${checked} 
                                       onchange="onAccommodationChange('${studentId}', '${escapeHtml(option)}', this)">
                                <span>${escapeHtml(option)}</span>
                            </label>
                        `;
                    });
                    accommodationCheckboxes += '</div>';
                }
                
                accommodationCell.innerHTML = accommodationCheckboxes;
            });
        }

        function onAccommodationChange(studentId, optionName, checkbox) {
            if (checkbox.checked) {
                const allCheckboxes = document.querySelectorAll(`.accommodation-checkbox[data-student-id="${studentId}"]`);
                allCheckboxes.forEach(cb => {
                    if (cb !== checkbox) {
                        cb.checked = false;
                    }
                });
                studentAccommodations[studentId] = optionName;
            } else {
                studentAccommodations[studentId] = null;
                delete studentAccommodations[studentId];
            }
            
            if (!changes['students']) {
                changes['students'] = {};
            }
            changes['students']['__accommodations'] = true;
            
            const row = document.querySelector(`.row-checkbox[data-id="${studentId}"]`)?.closest('tr');
            if (row) {
                row.classList.add('modified');
            }
            
            updateSyncButton('students');
        }

        async function syncAccommodations() {
            if (!currentCourseId) {
                throw new Error('No course selected');
            }

            if (!accommodationColumns) {
                throw new Error('Accommodation columns not initialized');
            }

            debugLog('=== SYNCING ACCOMMODATIONS ===', 'info');
            
            const allStudentIds = new Set([
                ...Object.keys(studentAccommodations),
                ...Object.keys(originalAccommodations)
            ]);
            
            const studentsToSync = [];
            
            for (const studentId of allStudentIds) {
                const current = studentAccommodations[studentId] || null;
                const original = originalAccommodations[studentId] || null;
                
                if (current !== original) {
                    studentsToSync.push({ studentId, current, original });
                }
            }
            
            if (studentsToSync.length === 0) {
                debugLog('No accommodation changes to sync', 'info');
                return 0;
            }
            
            debugLog(`Syncing accommodations for ${studentsToSync.length} student(s)...`, 'info');
            
            const syncResults = [];
            
            for (const { studentId, current, original } of studentsToSync) {
                try {
                    const studentIdNum = parseInt(studentId);
                    const valueToSet = current || '';
                    
                    const response = await fetch(`/canvas/courses/${currentCourseId}/accommodations/columns/${accommodationColumns.column.id}/users/${studentIdNum}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ content: valueToSet })
                    });
                    
                    if (!response.ok) {
                        const errorText = await response.text();
                        throw new Error(`Failed to save accommodation: ${response.status} - ${errorText}`);
                    }
                    
                    debugLog(`Saved accommodation "${current || '(none)'}" for student ${studentId}`, 'success');
                    originalAccommodations[studentId] = current;
                    syncResults.push({ studentId, success: true });
                } catch (error) {
                    debugLog(`Failed to sync accommodations for student ${studentId}: ${error.message}`, 'error');
                    syncResults.push({ studentId, success: false, error: error.message });
                }
            }
            
            const successCount = syncResults.filter(r => r.success).length;
            const failCount = syncResults.filter(r => !r.success).length;
            
            debugLog(`Accommodation sync complete: ${successCount} succeeded, ${failCount} failed`, successCount > 0 ? 'success' : 'error');
            
            if (failCount > 0) {
                const failedStudents = syncResults.filter(r => !r.success);
                debugLog(`Failed students: ${JSON.stringify(failedStudents)}`, 'error');
                throw new Error(`Accommodation sync completed with ${failCount} error(s). Check debug log for details.`);
            }
            
            return successCount;
        }

        function displayStudents(students) {
            // Generate custom headers with sort/filter controls
            generateCustomHeaders('students');
            
            const countEl = document.getElementById('studentsCount');
            const tbody = document.getElementById('studentsTableBody');
            
            if (!selectedItems['students']) {
                selectedItems['students'] = new Set();
            }
            
            countEl.textContent = `${students.length} student${students.length !== 1 ? 's' : ''}`;
            tbody.innerHTML = '';
            
            const selectAllCheckbox = document.getElementById('selectAll-students');
            if (selectAllCheckbox) selectAllCheckbox.checked = false;

            const table = document.getElementById('studentsTable');
            if (students.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="empty-state">No students found</td></tr>';
                if (table) table.style.display = '';
                return;
            }

            debugLog(`Rendering ${students.length} student rows...`, 'info');
            
            students.forEach((student, index) => {
                const row = document.createElement('tr');
                const itemId = String(student.id);
                const isChecked = selectedItems['students'].has(itemId);
                
                if (!originalData['students']) originalData['students'] = {};
                originalData['students'][itemId] = student;
                
                // Split name into last name and first name
                let lastName = '-';
                let firstName = '-';
                if (student.name) {
                    const nameParts = student.name.trim().split(/\s+/);
                    if (nameParts.length === 1) {
                        // Only one name part, use it as last name
                        lastName = nameParts[0];
                    } else if (nameParts.length >= 2) {
                        // Last part is last name, all others are first name
                        lastName = nameParts[nameParts.length - 1];
                        firstName = nameParts.slice(0, -1).join(' ');
                    }
                }
                
                const selectedAccommodation = studentAccommodations[itemId] || null;
                
                let accommodationCheckboxes = '';
                if (accommodationOptions.length === 0) {
                    accommodationCheckboxes = '<span style="color: #999; font-style: italic;">Loading...</span>';
                } else {
                    accommodationCheckboxes = '<div class="accommodation-checkboxes">';
                    accommodationOptions.forEach(option => {
                        const checked = selectedAccommodation === option ? 'checked' : '';
                        accommodationCheckboxes += `
                            <label class="accommodation-checkbox-label">
                                <input type="checkbox" 
                                       class="accommodation-checkbox" 
                                       data-student-id="${itemId}" 
                                       value="${escapeHtml(option)}" 
                                       ${checked} 
                                       onchange="onAccommodationChange('${itemId}', '${escapeHtml(option)}', this)">
                                <span>${escapeHtml(option)}</span>
                            </label>
                        `;
                    });
                    accommodationCheckboxes += '</div>';
                }
                
                row.innerHTML = `
                    <td class="checkbox-cell">
                        <input type="checkbox" class="row-checkbox" data-tab="students" data-id="${itemId}" ${isChecked ? 'checked' : ''} onchange="toggleRowSelection('students', '${itemId}', this.checked)">
                    </td>
                    <td data-item-id="${itemId}" data-field="last_name">${escapeHtml(lastName)}</td>
                    <td data-item-id="${itemId}" data-field="first_name">${escapeHtml(firstName)}</td>
                    <td class="accommodation-cell">
                        ${accommodationCheckboxes}
                    </td>
                    <td>${escapeHtml(student.email || '-')}</td>
                    <td>${escapeHtml(student.sis_user_id || '-')}</td>
                    <td class="readonly-cell">${escapeHtml((student.enrollment_state || 'unknown').charAt(0).toUpperCase() + (student.enrollment_state || 'unknown').slice(1))}</td>
                `;
                if (isChecked) row.classList.add('selected');
                tbody.appendChild(row);
            });
            
            if (table) table.style.display = '';
            
            // Apply any existing filters/sorts
            applySortAndFilter('students');
            
            // Initialize keyboard navigation for students table
            const studentsTable = document.getElementById('studentsTable');
            if (studentsTable) {
                initializeTableKeyboard(studentsTable);
            }
            
            debugLog(`Successfully displayed ${students.length} students`, 'success');
        }

        function getStateColor(state) {
            const colors = {
                active: '#28a745',
                invited: '#ffc107',
                creation_pending: '#17a2b8',
                deleted: '#dc3545',
                rejected: '#dc3545',
                completed: '#6c757d',
                inactive: '#6c757d'
            };
