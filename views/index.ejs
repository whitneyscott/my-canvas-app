            const weightCell = row.querySelector('[data-field="group_weight"]');
            if (weightCell) {
                const input = weightCell.querySelector('input');
                if (input) {
                    input.addEventListener('input', updateTotalWeightDisplay);
                    input.addEventListener('change', updateTotalWeightDisplay);
                }
            }
            
            const nameCell = row.querySelector('[data-field="name"]');
            if (nameCell) {
                const input = nameCell.querySelector('input');
                if (input) {
                    input.focus();
                }
            }
