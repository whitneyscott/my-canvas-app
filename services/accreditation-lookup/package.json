{
  "name": "accreditation-lookup-service",
  "version": "0.1.0",
  "description": "CIP-to-accreditor lookup (CHEA/DAPIP); runs inside Canvas Bulk Editor repo",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "docker compose up --build",
    "start:api": "node dist/main.js",
    "dev": "ts-node-dev --respawn src/main.ts",
    "db:migrate": "ts-node src/db/migrate.ts",
    "generate-admin-secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "apply-proposed-chea": "ts-node scripts/apply-proposed-chea.ts",
    "db:setup": "ts-node scripts/db-setup-with-scraper.ts",
    "propose-cip-mappings": "ts-node scripts/propose-cip-mappings.ts",
    "propose-cip-mappings-static": "ts-node scripts/propose-cip-mappings-static.ts",
    "db:migrate-cip6": "ts-node src/db/migrate-cip6.ts",
    "propose-cip6-mappings": "ts-node scripts/propose-cip6-mappings.ts",
    "apply-cip6-mappings": "ts-node scripts/apply-cip6-mappings.ts",
    "apply-cip-mappings": "ts-node scripts/apply-cip-mappings.ts",
    "remap-accreditors": "ts-node scripts/remap-accreditors.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "adm-zip": "^0.5.16",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
